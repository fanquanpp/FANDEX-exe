#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# commit-msg 钩子
# 校验提交信息是否符合 Conventional Commits 规范
# 期望格式：<type>(<scope>): <subject>
# 允许 type：feat / fix / docs / style / refactor / perf / test / chore / build / ci / revert / merge
# 参考：https://www.conventionalcommits.org/zh-hans/

msg_file="$1"
msg_first_line=$(head -n 1 "$msg_file")

# 允许 Merge / Revert 开头的自动提交（git 自身生成的提交信息）
# 允许空首行（多行消息体在前），但首行存在时必须符合规范
if [ -z "$msg_first_line" ]; then
  exit 0
fi

case "$msg_first_line" in
  Merge*|Revert*)
    exit 0
    ;;
esac

# Conventional Commits 正则（POSIX 兼容，使用 grep -E）
pattern='^(feat|fix|docs|style|refactor|perf|test|chore|build|ci|revert|merge)(\(.+\))?: .{1,100}'

if ! echo "$msg_first_line" | grep -qE "$pattern"; then
  echo "[commit-msg] Commit message 不符合 Conventional Commits 规范" >&2
  echo "" >&2
  echo "期望格式：<type>(<scope>): <subject>" >&2
  echo "" >&2
  echo "允许 type：" >&2
  echo "  feat      新增功能" >&2
  echo "  fix       修复 Bug" >&2
  echo "  docs      文档变更" >&2
  echo "  style     代码格式调整" >&2
  echo "  refactor  重构（不新增功能也不修复 Bug）" >&2
  echo "  perf      性能优化" >&2
  echo "  test      测试用例变更" >&2
  echo "  chore     构建、依赖、工具链等杂项" >&2
  echo "  build     构建系统或依赖变更" >&2
  echo "  ci        CI 配置变更" >&2
  echo "  revert    回滚某次提交" >&2
  echo "  merge     合并分支" >&2
  echo "" >&2
  echo "示例：" >&2
  echo "  feat(auth): 新增基于 JWT 的访问令牌签发接口" >&2
  echo "  fix: 修复深色模式下侧边栏文字对比度不足问题" >&2
  echo "  docs(readme): 更新构建命令说明" >&2
  echo "" >&2
  echo "当前提交信息首行：$msg_first_line" >&2
  echo "" >&2
  echo "如需紧急绕过校验（不推荐），可使用 git commit --no-verify" >&2
  exit 1
fi
