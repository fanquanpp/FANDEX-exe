# pnpm/npm 配置
# - auto-install-peers：自动安装 peer 依赖，避免手动维护
# - strict-peer-dependencies：放宽 peer 冲突，避免 latest 版本组合时构建中断
# - shamefully-hoist=false：不向上提升依赖，保持严格的隔离安装
# - node-linker=isolated：使用 isolated 链接器，符合 pnpm 推荐做法
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false
node-linker=isolated
