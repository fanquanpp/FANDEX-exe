{
  "name": "fandex",
  "version": "4.0.0",
  "private": true,
  "type": "module",
  "description": "循序渐进的自学之旅 — 51 模块 · 2031 篇文档 · 从第一行代码到理解整个世界",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node ../../scripts/generate-cheatsheet-highlights.js",
    "build": "node ../../scripts/copy-metadata-to-public.mjs && node ../../scripts/build-glossary-index.mjs && node ../../scripts/build-module-docs-index.mjs && node ../../scripts/build-tag-index.mjs && node ../../scripts/build-search-index.mjs && node ../../scripts/generate-knowledge-graph.mjs && node ../../scripts/generate-embedding-index.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "prepare": "husky",
    "qa": "node ../../scripts/qa-check.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:docs": "remark src/content/docs --ext .md,.mdx",
    "lint:docs:fix": "remark src/content/docs --ext .md,.mdx --output",
    "build:mobile": "node ../../scripts/build-mobile/export-mobile-content.mjs && node ../../scripts/build-mobile/extract-mobile-html.mjs && node ../../scripts/build-mobile/pack-dist-mobile.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/vue": "^5.0.0",
    "astro": "^5.5.0",
    "dompurify": "^3.4.10",
    "fuse.js": "^7.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "mermaid": "^11.15.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "remark-cli": "^12.0.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "svgdom": "^0.1.23",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{astro,ts,js,mjs,css,json,md}": [
      "prettier --write"
    ]
  }
}
