---
/**
 * AI 知识图谱问答组件
 *
 * 功能：
 * - 对话式问答界面
 * - 用户输入问题
 * - 显示 AI 回答（含知识图谱引用）
 * - 显示相关节点（可点击跳转）
 * - AI 不可用时：显示关键词搜索结果
 *
 * 依赖服务：GraphRAGService（通过 services/index.ts 统一引入）
 */
const base = import.meta.env.BASE_URL;
---

<div class="ai-graphrag" id="ai-graphrag">
  <!-- 对话区域 -->
  <div class="ai-chat" id="ai-chat">
    <!-- 欢迎消息 -->
    <div class="ai-chat-msg ai-chat-system">
      <div class="ai-msg-avatar">AI</div>
      <div class="ai-msg-body">
        <div class="ai-msg-content">
          你好，我是 FANDEX 知识库的 AI
          助手。你可以向我提问关于编程、技术栈、学习路线等问题，我会基于知识图谱为你提供结构化的回答。
        </div>
      </div>
    </div>
  </div>

  <!-- 相关节点展示区 -->
  <div class="ai-related-nodes" id="ai-related-nodes" style="display:none">
    <div class="ai-nodes-header">相关知识节点</div>
    <div class="ai-nodes-list" id="ai-nodes-list"></div>
  </div>

  <!-- 输入区域 -->
  <div class="ai-chat-input">
    <input type="text" id="ai-question" class="ai-question-input" placeholder="输入你的问题..." />
    <button class="ai-send-btn" id="ai-send-btn" title="发送">
      <svg
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        ><line x1="22" y1="2" x2="11" y2="13"></line><polygon points="22 2 15 22 11 13 2 9 22 2"
        ></polygon></svg
      >
    </button>
  </div>
</div>

<style>
  /* AI 问答容器 */
  .ai-graphrag {
    display: flex;
    flex-direction: column;
    height: calc(100vh - var(--nav-height) - 80px);
    height: calc(100dvh - var(--nav-height) - 80px);
    max-width: 800px;
    margin: 0 auto;
    background: var(--color-bg);
  }

  /* 对话区域 */
  .ai-chat {
    flex: 1;
    overflow-y: auto;
    padding: var(--spacing-lg);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  /* 消息 */
  .ai-chat-msg {
    display: flex;
    gap: var(--spacing-sm);
    max-width: 90%;
  }

  .ai-chat-user {
    align-self: flex-end;
    flex-direction: row-reverse;
  }

  .ai-chat-system {
    align-self: flex-start;
  }

  .ai-msg-avatar {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary);
    color: var(--color-text-inverse);
    font-family: var(--font-display);
    font-size: 0.7em;
    font-weight: 700;
    flex-shrink: 0;
  }

  .ai-chat-user .ai-msg-avatar {
    background: var(--color-border);
    color: var(--color-text-secondary);
  }

  .ai-msg-body {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .ai-msg-content {
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: 2px;
    font-size: 0.9em;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
  }

  .ai-chat-system .ai-msg-content {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-light);
    color: var(--color-text);
  }

  .ai-chat-user .ai-msg-content {
    background: var(--color-primary);
    color: var(--color-text-inverse);
  }

  /* AI 回答中的来源标签 */
  .ai-msg-source {
    display: inline-block;
    padding: 1px 6px;
    background: rgba(79, 91, 213, 0.1);
    color: var(--color-primary);
    font-size: 0.8em;
    border: 1px solid rgba(79, 91, 213, 0.2);
    margin: 2px;
    cursor: pointer;
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .ai-msg-source:hover {
    background: rgba(79, 91, 213, 0.2);
  }

  /* AI 标识 */
  .ai-msg-badge {
    display: inline-block;
    padding: 1px 6px;
    background: var(--color-primary);
    color: var(--color-text-inverse);
    font-size: 0.65em;
    font-weight: 700;
    letter-spacing: 0.05em;
    vertical-align: middle;
    margin-right: 4px;
  }

  /* 加载中消息 */
  .ai-chat-loading .ai-msg-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
  }

  .ai-loading-dots {
    display: flex;
    gap: 4px;
  }

  .ai-loading-dots span {
    width: 6px;
    height: 6px;
    background: var(--color-text-tertiary);
    border-radius: 50%;
    animation: ai-dot-bounce 1.2s infinite ease-in-out;
  }

  .ai-loading-dots span:nth-child(2) {
    animation-delay: 0.2s;
  }
  .ai-loading-dots span:nth-child(3) {
    animation-delay: 0.4s;
  }

  @keyframes ai-dot-bounce {
    0%,
    80%,
    100% {
      transform: scale(0.6);
      opacity: 0.4;
    }
    40% {
      transform: scale(1);
      opacity: 1;
    }
  }

  /* 相关节点展示区 */
  .ai-related-nodes {
    padding: var(--spacing-sm) var(--spacing-lg);
    border-top: 1px solid var(--color-border-light);
    background: var(--color-bg-card);
  }

  .ai-nodes-header {
    font-family: var(--font-display);
    font-size: 0.75em;
    font-weight: 700;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: var(--spacing-xs);
  }

  .ai-nodes-list {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .ai-node-tag {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 2px 10px;
    border: 1px solid var(--color-border-light);
    background: var(--color-bg);
    color: var(--color-text-secondary);
    font-size: 0.8em;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .ai-node-tag:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .ai-node-type {
    font-size: 0.7em;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
  }

  /* 输入区域 */
  .ai-chat-input {
    display: flex;
    gap: 0;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg-card);
  }

  .ai-question-input {
    flex: 1;
    padding: var(--spacing-md) var(--spacing-lg);
    border: none;
    background: transparent;
    color: var(--color-text);
    font-size: 0.95em;
    font-family: inherit;
  }

  .ai-question-input:focus {
    outline: none;
  }

  .ai-question-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .ai-send-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-md) var(--spacing-lg);
    background: var(--color-primary);
    color: var(--color-text-inverse);
    border: none;
    cursor: pointer;
    transition: opacity var(--transition-fast);
  }

  .ai-send-btn:hover {
    opacity: 0.9;
  }

  .ai-send-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* 响应式 */
  @media (max-width: 768px) {
    .ai-graphrag {
      height: calc(100vh - var(--nav-height) - 60px);
      height: calc(100dvh - var(--nav-height) - 60px);
    }

    .ai-chat-msg {
      max-width: 95%;
    }

    .ai-msg-avatar {
      width: 28px;
      height: 28px;
      font-size: 0.65em;
    }
  }
</style>

<script>
  /**
   * AI 知识图谱问答交互逻辑
   *
   * 流程：
   * 1. 用户输入问题 -> 发送
   * 2. 调用 GraphRAGService 获取回答
   * 3. 展示 AI 回答（含引用来源）
   * 4. 展示相关节点（可点击跳转）
   */
  import { getGraphRAGService, isAIAvailable } from '@/services/index';
  import type { GraphRAGAnswer, GraphNode } from '@/services/index';

  const chatDiv = document.getElementById('ai-chat') as HTMLDivElement;
  const questionInput = document.getElementById('ai-question') as HTMLInputElement;
  const sendBtn = document.getElementById('ai-send-btn') as HTMLButtonElement;
  const relatedNodesDiv = document.getElementById('ai-related-nodes') as HTMLDivElement;
  const nodesListDiv = document.getElementById('ai-nodes-list') as HTMLDivElement;

  const base = document.querySelector('base')?.getAttribute('href') || '/';
  let isProcessing = false;

  /**
   * 添加用户消息到对话区
   *
   * 输入：消息文本
   * 输出：void（更新 DOM）
   */
  function addUserMessage(text: string): void {
    const msgEl = document.createElement('div');
    msgEl.className = 'ai-chat-msg ai-chat-user';
    msgEl.innerHTML = `
      <div class="ai-msg-avatar">You</div>
      <div class="ai-msg-body">
        <div class="ai-msg-content">${escapeHtml(text)}</div>
      </div>
    `;
    chatDiv.appendChild(msgEl);
    scrollToBottom();
  }

  /**
   * 添加 AI 回答到对话区
   *
   * 输入：GraphRAGAnswer
   * 输出：void（更新 DOM）
   */
  function addAIMessage(answer: GraphRAGAnswer): void {
    const msgEl = document.createElement('div');
    msgEl.className = 'ai-chat-msg ai-chat-system';

    /** 构建来源标签 */
    const sourceTags =
      answer.sources.length > 0
        ? '<div class="ai-msg-sources">' +
          answer.sources
            .map((s) => `<a class="ai-msg-source" href="${base}${s}/">${s}</a>`)
            .join('') +
          '</div>'
        : '';

    const aiBadge = answer.aiGenerated ? '<span class="ai-msg-badge">AI</span>' : '';

    const contentEl = document.createElement('div');
    contentEl.className = 'ai-msg-content';
    contentEl.innerHTML = `${aiBadge}${escapeHtml(answer.content)}${sourceTags}`;

    msgEl.innerHTML = `
      <div class="ai-msg-avatar">AI</div>
      <div class="ai-msg-body"></div>
    `;
    msgEl.querySelector('.ai-msg-body')!.appendChild(contentEl);

    chatDiv.appendChild(msgEl);

    /** 展示相关节点 */
    if (answer.relatedNodes.length > 0) {
      renderRelatedNodes(answer.relatedNodes);
    }

    scrollToBottom();
  }

  /**
   * 添加加载中消息
   *
   * 输入：无
   * 输出：HTMLDivElement（加载消息元素）
   */
  function addLoadingMessage(): HTMLDivElement {
    const msgEl = document.createElement('div');
    msgEl.className = 'ai-chat-msg ai-chat-system ai-chat-loading';
    msgEl.id = 'ai-loading-msg';
    msgEl.innerHTML = `
      <div class="ai-msg-avatar">AI</div>
      <div class="ai-msg-body">
        <div class="ai-msg-content">
          <div class="ai-loading-dots"><span></span><span></span><span></span></div>
          正在检索知识图谱...
        </div>
      </div>
    `;
    chatDiv.appendChild(msgEl);
    scrollToBottom();
    return msgEl;
  }

  /**
   * 渲染相关节点
   *
   * 输入：GraphNode 数组
   * 输出：void（更新 DOM）
   */
  function renderRelatedNodes(nodes: GraphNode[]): void {
    nodesListDiv.innerHTML = '';
    const typeLabels: Record<string, string> = {
      module: '模块',
      doc: '文档',
      term: '术语',
    };

    for (const node of nodes.slice(0, 20)) {
      const tag = document.createElement('a');
      tag.className = 'ai-node-tag';
      tag.href = `${base}${node.id}/`;
      const typeLabel = typeLabels[node.type] ?? node.type;
      tag.innerHTML = `<span class="ai-node-type">${typeLabel}</span> ${escapeHtml(node.label)}`;
      nodesListDiv.appendChild(tag);
    }

    relatedNodesDiv.style.display = 'block';
  }

  /**
   * 滚动对话区到底部
   *
   * 输入：无
   * 输出：void
   */
  function scrollToBottom(): void {
    requestAnimationFrame(() => {
      chatDiv.scrollTop = chatDiv.scrollHeight;
    });
  }

  /**
   * HTML 转义
   *
   * 输入：原始文本
   * 输出：转义后的安全文本
   */
  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  /**
   * 发送问题处理
   *
   * 输入：无
   * 输出：void
   * 流程：校验输入 -> 显示用户消息 -> 调用服务 -> 显示 AI 回答
   */
  async function handleSend(): Promise<void> {
    const question = questionInput.value.trim();
    if (!question || isProcessing) return;

    isProcessing = true;
    sendBtn.disabled = true;
    questionInput.value = '';

    addUserMessage(question);
    const loadingEl = addLoadingMessage();

    try {
      const service = getGraphRAGService();
      const answer = await service.answer({ question });

      /** 移除加载消息 */
      loadingEl.remove();

      addAIMessage(answer);
    } catch (err) {
      loadingEl.remove();
      addAIMessage({
        content: `抱歉，回答生成失败: ${err instanceof Error ? err.message : String(err)}`,
        sources: [],
        relatedNodes: [],
        aiGenerated: false,
      });
    } finally {
      isProcessing = false;
      sendBtn.disabled = false;
      questionInput.focus();
    }
  }

  /* 绑定事件 */
  if (sendBtn) sendBtn.addEventListener('click', handleSend);
  if (questionInput)
    questionInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault();
        handleSend();
      }
    });
</script>
