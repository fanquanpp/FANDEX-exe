---
/**
 * AI Quiz 组件
 *
 * 在文档页面中提供 AI 驱动的知识测验功能。
 * 用户点击"AI 出题"按钮后调用 Quiz 服务生成题目，
 * AI 不可用时显示文档 frontmatter 中已有的 quiz 数据。
 *
 * 功能：
 * - "AI 出题"按钮：点击后调用 Quiz 服务生成题目
 * - 题型选择：填空题 / 选择题 / 代码修复题
 * - 题目展示：根据类型渲染不同交互形式
 * - 答案验证：用户提交后显示正确答案和解析
 * - 降级策略：AI 不可用时显示 frontmatter quiz 数据
 *
 * 数据流：
 * - Props 传入基础信息（moduleId, slug, title, summary, fallbackQuiz）
 * - 用户点击按钮 -> 动态导入 quiz 服务 -> 生成题目 -> 渲染 DOM
 * - 用户提交答案 -> 客户端判题 -> 显示反馈
 */

interface Props {
  /** 模块 ID */
  moduleId: string;
  /** 文档 slug */
  slug: string;
  /** 文档标题 */
  title: string;
  /** 内容摘要 */
  summary: string;
  /** 降级数据：frontmatter 中已有的 quiz */
  fallbackQuiz?: string;
}

const { moduleId, slug, title, summary, fallbackQuiz } = Astro.props;
const fallbackQuizStr = fallbackQuiz || '[]';
---

<div class="ai-quiz" data-module-id={moduleId} data-slug={slug} data-title={title} data-summary={summary} data-fallback-quiz={fallbackQuizStr}>
  <div class="ai-quiz-header">
    <h3 class="ai-quiz-title">知识检测</h3>
    <div class="ai-quiz-actions">
      <select class="ai-quiz-type-select" id={`quiz-type-${slug}`}>
        <option value="choice">选择题</option>
        <option value="fill">填空题</option>
        <option value="fix">代码修复题</option>
      </select>
      <button class="ai-quiz-generate-btn" id={`quiz-generate-${slug}`}>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M12 2L2 7l10 5 10-5-10-5z"/>
          <path d="M2 17l10 5 10-5"/>
          <path d="M2 12l10 5 10-5"/>
        </svg>
        AI 出题
      </button>
    </div>
  </div>
  <!-- 题目容器：由客户端脚本动态填充 -->
  <div class="ai-quiz-list" id={`quiz-list-${slug}`}></div>
  <!-- 加载状态 -->
  <div class="ai-quiz-loading" id={`quiz-loading-${slug}`} style="display:none;">
    <span class="ai-quiz-spinner"></span>
    <span>正在生成题目...</span>
  </div>
  <!-- 降级提示 -->
  <div class="ai-quiz-fallback-hint" id={`quiz-fallback-hint-${slug}`} style="display:none;">
    AI 服务暂不可用，显示文档预设题目
  </div>
</div>

<script define:vars={{ moduleId, slug, title, summary, fallbackQuizStr }}>
  /**
   * AI Quiz 客户端交互逻辑
   *
   * 流程：
   * 1. 绑定"AI 出题"按钮点击事件
   * 2. 点击后动态导入 quiz 服务
   * 3. 调用 generateQuiz 生成题目
   * 4. 渲染题目到 DOM
   * 5. 绑定答案提交事件
   */
  (function initAIQuiz() {
    var generateBtn = document.getElementById('quiz-generate-' + slug);
    var quizList = document.getElementById('quiz-list-' + slug);
    var loadingEl = document.getElementById('quiz-loading-' + slug);
    var fallbackHint = document.getElementById('quiz-fallback-hint-' + slug);
    var typeSelect = document.getElementById('quiz-type-' + slug);

    if (!generateBtn || !quizList) return;

    /* 响应式状态 */
    var quizData = [];
    var answers = {};
    var selectedOption = {};
    var submitted = {};
    var results = {};

    /**
     * 点击"AI 出题"按钮处理
     * 动态导入服务 -> 生成题目 -> 渲染
     */
    generateBtn.addEventListener('click', async function() {
      generateBtn.disabled = true;
      if (loadingEl) loadingEl.style.display = 'flex';
      quizList.innerHTML = '';

      try {
        var { getQuizService } = await import('@/services/index.ts');
        var service = getQuizService();
        var quizType = typeSelect ? typeSelect.value : 'choice';
        var fallback = [];
        try { fallback = JSON.parse(fallbackQuizStr); } catch(e) { fallback = []; }

        quizData = await service.generateQuiz({
          moduleId: moduleId,
          slug: slug,
          title: title,
          summary: summary,
          count: 3,
          quizType: quizType,
          fallbackQuiz: fallback
        });

        /* 检查是否使用了降级数据 */
        if (fallbackHint && quizData.length > 0) {
          var isFallback = quizData === fallback;
          if (isFallback) {
            fallbackHint.style.display = 'block';
          }
        }

        renderQuiz();
      } catch (error) {
        console.error('AI Quiz 初始化失败:', error);
        quizList.innerHTML = '<div class="ai-quiz-error">题目生成失败，请稍后重试</div>';
      } finally {
        generateBtn.disabled = false;
        if (loadingEl) loadingEl.style.display = 'none';
      }
    });

    /**
     * 渲染题目列表到 DOM
     */
    function renderQuiz() {
      if (quizData.length === 0) {
        quizList.innerHTML = '<div class="ai-quiz-empty">暂无题目</div>';
        return;
      }

      var html = '';
      for (var i = 0; i < quizData.length; i++) {
        var q = quizData[i];
        html += '<div class="ai-quiz-item" id="quiz-item-' + slug + '-' + i + '">';
        html += '<div class="ai-quiz-question">';
        html += '<span class="ai-quiz-number">' + (i + 1) + '</span>';
        html += '<span class="ai-quiz-type-badge">' + typeLabel(q.type) + '</span>';
        html += escapeHtml(q.question);
        html += '</div>';

        if (q.type === 'fill') {
          html += '<div class="ai-quiz-answer-area">';
          html += '<input class="ai-quiz-input" data-qi="' + i + '" placeholder="输入答案..." />';
          html += '<button class="ai-quiz-submit-btn" data-qi="' + i + '">提交</button>';
          html += '</div>';
        } else if (q.type === 'choice') {
          html += '<div class="ai-quiz-options">';
          for (var oi = 0; oi < q.options.length; oi++) {
            var letter = String.fromCharCode(65 + oi);
            html += '<button class="ai-quiz-option" data-qi="' + i + '" data-oi="' + oi + '">';
            html += '<span class="ai-option-letter">' + letter + '</span>';
            html += escapeHtml(q.options[oi]);
            html += '</button>';
          }
          html += '</div>';
        } else if (q.type === 'fix') {
          html += '<div class="ai-quiz-answer-area">';
          if (q.code) {
            html += '<pre class="ai-quiz-code">' + escapeHtml(q.code) + '</pre>';
          }
          html += '<textarea class="ai-quiz-textarea" data-qi="' + i + '" placeholder="输入修正后的代码或说明..." rows="2"></textarea>';
          html += '<button class="ai-quiz-submit-btn" data-qi="' + i + '">提交</button>';
          html += '</div>';
        }

        html += '<div class="ai-quiz-feedback" id="quiz-feedback-' + slug + '-' + i + '" style="display:none;"></div>';
        html += '</div>';
      }

      quizList.innerHTML = html;
      bindQuizEvents();
    }

    /**
     * 绑定题目交互事件
     */
    function bindQuizEvents() {
      /* 填空题/修复题提交按钮 */
      var submitBtns = quizList.querySelectorAll('.ai-quiz-submit-btn');
      for (var i = 0; i < submitBtns.length; i++) {
        submitBtns[i].addEventListener('click', function() {
          var qi = parseInt(this.getAttribute('data-qi'));
          submitAnswer(qi);
        });
      }

      /* 填空题输入框 Enter 键提交 */
      var inputs = quizList.querySelectorAll('.ai-quiz-input');
      for (var i = 0; i < inputs.length; i++) {
        inputs[i].addEventListener('keyup', function(e) {
          if (e.key === 'Enter') {
            var qi = parseInt(this.getAttribute('data-qi'));
            submitAnswer(qi);
          }
        });
      }

      /* 选择题选项点击 */
      var options = quizList.querySelectorAll('.ai-quiz-option');
      for (var i = 0; i < options.length; i++) {
        options[i].addEventListener('click', function() {
          var qi = parseInt(this.getAttribute('data-qi'));
          var oi = parseInt(this.getAttribute('data-oi'));
          selectOption(qi, oi);
        });
      }
    }

    /**
     * 选择题：选中选项后立即提交
     */
    function selectOption(qi, oi) {
      selectedOption[qi] = oi;
      /* 更新选中样式 */
      var optBtns = quizList.querySelectorAll('.ai-quiz-option[data-qi="' + qi + '"]');
      for (var i = 0; i < optBtns.length; i++) {
        optBtns[i].classList.remove('selected');
      }
      var selected = quizList.querySelector('.ai-quiz-option[data-qi="' + qi + '"][data-oi="' + oi + '"]');
      if (selected) selected.classList.add('selected');
      submitAnswer(qi);
    }

    /**
     * 提交答案并判题
     */
    function submitAnswer(qi) {
      if (submitted[qi]) return;
      submitted[qi] = true;

      var q = quizData[qi];
      var userAnswer = '';

      if (q.type === 'fill') {
        var input = quizList.querySelector('.ai-quiz-input[data-qi="' + qi + '"]');
        userAnswer = input ? input.value : '';
        var correctAns = q.answer.trim().toLowerCase();
        var userAns = userAnswer.trim().toLowerCase();
        results[qi] = userAns === correctAns;
        if (input) input.disabled = true;
      } else if (q.type === 'choice') {
        results[qi] = selectedOption[qi] === q.answer;
        /* 标记正确/错误选项 */
        var optBtns = quizList.querySelectorAll('.ai-quiz-option[data-qi="' + qi + '"]');
        for (var i = 0; i < optBtns.length; i++) {
          var oi = parseInt(optBtns[i].getAttribute('data-oi'));
          optBtns[i].disabled = true;
          if (oi === q.answer) optBtns[i].classList.add('correct');
          if (oi === selectedOption[qi] && oi !== q.answer) optBtns[i].classList.add('wrong');
        }
      } else {
        results[qi] = null;
        var textarea = quizList.querySelector('.ai-quiz-textarea[data-qi="' + qi + '"]');
        if (textarea) textarea.disabled = true;
      }

      /* 禁用提交按钮 */
      var submitBtn = quizList.querySelector('.ai-quiz-submit-btn[data-qi="' + qi + '"]');
      if (submitBtn) submitBtn.disabled = true;

      /* 更新题目卡片样式 */
      var item = document.getElementById('quiz-item-' + slug + '-' + qi);
      if (item) {
        item.classList.remove('result-correct', 'result-wrong', 'result-neutral');
        if (results[qi] === true) item.classList.add('result-correct');
        else if (results[qi] === false) item.classList.add('result-wrong');
        else item.classList.add('result-neutral');
      }

      /* 显示反馈 */
      var feedback = document.getElementById('quiz-feedback-' + slug + '-' + qi);
      if (feedback) {
        var feedbackHtml = '';
        if (results[qi] === true) {
          feedbackHtml += '<span class="ai-feedback-correct">正确</span>';
        } else if (results[qi] === false) {
          feedbackHtml += '<span class="ai-feedback-wrong">不正确</span>';
        } else {
          feedbackHtml += '<span class="ai-feedback-neutral">已提交</span>';
        }
        if (q.type === 'fill') {
          feedbackHtml += '<span class="ai-feedback-answer">参考答案: ' + escapeHtml(q.answer) + '</span>';
        }
        if (q.type === 'fix') {
          feedbackHtml += '<span class="ai-feedback-answer">参考答案: ' + escapeHtml(q.answer) + '</span>';
        }
        if (q.explanation) {
          feedbackHtml += '<span class="ai-feedback-explanation">' + escapeHtml(q.explanation) + '</span>';
        }
        if (q.hint && results[qi] !== true) {
          feedbackHtml += '<span class="ai-feedback-hint">提示: ' + escapeHtml(q.hint) + '</span>';
        }
        feedback.innerHTML = feedbackHtml;
        feedback.style.display = 'flex';
      }
    }

    /**
     * 获取题型中文标签
     */
    function typeLabel(type) {
      var map = { fill: '填空', choice: '选择', fix: '修复' };
      return map[type] || type;
    }

    /**
     * HTML 转义，防止 XSS
     */
    function escapeHtml(str) {
      if (!str) return '';
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
  })();
</script>

<style>
/* AI Quiz 容器 */
.ai-quiz {
  margin-top: var(--spacing-xl);
  padding-top: var(--spacing-lg);
  border-top: 1px solid var(--color-border-light);
}

/* 标题行：标题 + 操作按钮 */
.ai-quiz-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
  flex-wrap: wrap;
}

/* 标题 */
.ai-quiz-title {
  font-family: var(--font-display);
  font-size: 1.1em;
  font-weight: 700;
  margin: 0;
}

/* 操作区域 */
.ai-quiz-actions {
  display: inline-flex;
  align-items: center;
  gap: var(--spacing-sm);
}

/* 题型选择下拉框 */
.ai-quiz-type-select {
  padding: 4px 8px;
  border: 1px solid var(--color-border-light);
  background: var(--color-bg-card);
  color: var(--color-text);
  font-size: 0.82em;
  font-family: var(--font-display);
  cursor: pointer;
  outline: none;
}

.ai-quiz-type-select:focus {
  border-color: var(--color-primary);
}

/* AI 出题按钮 */
.ai-quiz-generate-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 12px;
  border: 1px solid var(--color-primary);
  background: transparent;
  color: var(--color-primary);
  font-size: 0.85em;
  font-family: var(--font-display);
  cursor: pointer;
  transition: all var(--transition-fast);
  white-space: nowrap;
}

.ai-quiz-generate-btn:hover:not(:disabled) {
  background: var(--color-primary);
  color: var(--color-text-inverse);
}

.ai-quiz-generate-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* 题目列表 */
.ai-quiz-list {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

/* 单个题目卡片 */
.ai-quiz-item {
  padding: var(--spacing-md);
  border: 1px solid var(--color-border-light);
  background: var(--color-bg-card);
  transition: border-color var(--transition-fast);
}

.ai-quiz-item.result-correct {
  border-color: #10b981;
}

.ai-quiz-item.result-wrong {
  border-color: #ef4444;
}

.ai-quiz-item.result-neutral {
  border-color: #f59e0b;
}

/* 题目文字 */
.ai-quiz-question {
  font-size: 0.92em;
  margin-bottom: var(--spacing-sm);
  line-height: 1.6;
}

/* 题号圆圈 */
.ai-quiz-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  background: var(--color-primary);
  color: #fff;
  font-size: 0.75em;
  font-weight: 700;
  margin-right: 6px;
  flex-shrink: 0;
}

/* 题型标签 */
.ai-quiz-type-badge {
  display: inline-block;
  padding: 1px 6px;
  background: var(--color-bg-hover);
  font-size: 0.75em;
  color: var(--color-text-secondary);
  margin-right: 6px;
}

/* 答案输入区域 */
.ai-quiz-answer-area {
  display: flex;
  gap: var(--spacing-sm);
  align-items: flex-start;
  margin-top: var(--spacing-sm);
}

/* 填空输入框 */
.ai-quiz-input {
  flex: 1;
  padding: 6px 10px;
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
  font-size: 0.88em;
  font-family: var(--font-display);
  outline: none;
}

.ai-quiz-input:focus {
  border-color: var(--color-primary);
}

/* 修复题文本域 */
.ai-quiz-textarea {
  flex: 1;
  padding: 6px 10px;
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
  font-size: 0.85em;
  font-family: var(--font-mono, monospace);
  outline: none;
  resize: vertical;
}

.ai-quiz-textarea:focus {
  border-color: var(--color-primary);
}

/* 修复题代码展示 */
.ai-quiz-code {
  width: 100%;
  padding: var(--spacing-sm);
  background: var(--color-bg);
  border: 1px solid var(--color-border-light);
  font-size: 0.82em;
  margin-bottom: var(--spacing-xs);
  overflow-x: auto;
}

/* 提交按钮 */
.ai-quiz-submit-btn {
  padding: 6px 14px;
  border: 1px solid var(--color-border);
  background: transparent;
  color: var(--color-text-secondary);
  font-size: 0.85em;
  cursor: pointer;
  white-space: nowrap;
}

.ai-quiz-submit-btn:hover:not(:disabled) {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.ai-quiz-submit-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* 选择题选项列表 */
.ai-quiz-options {
  display: flex;
  flex-direction: column;
  gap: 4px;
  margin-top: var(--spacing-sm);
}

/* 单个选项按钮 */
.ai-quiz-option {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: 6px 10px;
  border: 1px solid var(--color-border-light);
  background: var(--color-bg);
  color: var(--color-text);
  font-size: 0.88em;
  cursor: pointer;
  text-align: left;
  transition: all var(--transition-fast);
}

.ai-quiz-option:hover:not(:disabled) {
  border-color: var(--color-primary);
}

.ai-quiz-option.selected {
  border-color: var(--color-primary);
  background: var(--color-bg-hover);
}

.ai-quiz-option.correct {
  border-color: #10b981;
  background: rgba(16, 185, 129, 0.08);
  color: #10b981;
}

.ai-quiz-option.wrong {
  border-color: #ef4444;
  background: rgba(239, 68, 68, 0.08);
  color: #ef4444;
}

/* 选项字母标识 */
.ai-option-letter {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  border: 1px solid var(--color-border);
  font-size: 0.78em;
  font-weight: 600;
  flex-shrink: 0;
}

/* 反馈区域 */
.ai-quiz-feedback {
  margin-top: var(--spacing-sm);
  font-size: 0.85em;
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-sm);
  align-items: baseline;
}

.ai-feedback-correct {
  color: #10b981;
  font-weight: 600;
}

.ai-feedback-wrong {
  color: #ef4444;
  font-weight: 600;
}

.ai-feedback-neutral {
  color: #f59e0b;
  font-weight: 600;
}

.ai-feedback-answer {
  color: var(--color-text-secondary);
}

.ai-feedback-explanation {
  color: var(--color-text-secondary);
}

.ai-feedback-hint {
  color: #f59e0b;
}

/* 加载状态 */
.ai-quiz-loading {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: 0.9em;
}

/* 旋转动画 */
.ai-quiz-spinner {
  display: inline-block;
  width: 16px;
  height: 16px;
  border: 2px solid var(--color-border-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: ai-quiz-spin 0.6s linear infinite;
}

@keyframes ai-quiz-spin {
  to { transform: rotate(360deg); }
}

/* 降级提示 */
.ai-quiz-fallback-hint {
  padding: var(--spacing-sm) var(--spacing-md);
  margin-top: var(--spacing-sm);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-left: 3px solid #f59e0b;
  font-size: 0.82em;
  color: var(--color-text-secondary);
}

/* 空状态 */
.ai-quiz-empty {
  padding: var(--spacing-lg);
  text-align: center;
  color: var(--color-text-tertiary);
  font-size: 0.9em;
}

/* 错误状态 */
.ai-quiz-error {
  padding: var(--spacing-md);
  text-align: center;
  color: #ef4444;
  font-size: 0.9em;
}

/* 移动端适配 */
@media (max-width: 768px) {
  .ai-quiz-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .ai-quiz-actions {
    width: 100%;
  }

  .ai-quiz-type-select {
    flex: 1;
  }

  .ai-quiz-generate-btn {
    flex-shrink: 0;
  }
}
</style>
