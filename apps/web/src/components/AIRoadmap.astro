---
/**
 * AI 路线规划组件
 *
 * 功能：
 * - AI 规划按钮：输入学习目标，生成个性化路线
 * - 路线展示：分阶段展示推荐模块
 * - 进度追踪：显示用户在路线中的当前位置
 * - AI 不可用时：显示预设的职业路径
 *
 * 依赖服务：RoadmapService（通过 services/index.ts 统一引入）
 */
const base = import.meta.env.BASE_URL
---

<div class="ai-roadmap" id="ai-roadmap">
  <!-- AI 规划输入区 -->
  <div class="ai-roadmap-input">
    <div class="ai-input-header">
      <span class="ai-badge">AI</span>
      <span class="ai-input-title">个性化路线规划</span>
    </div>
    <div class="ai-input-form">
      <div class="ai-form-row">
        <label class="ai-form-label" for="ai-goal">学习目标</label>
        <input type="text" id="ai-goal" class="ai-form-input" placeholder="如：全栈开发、前端工程师、AI 工程师" />
      </div>
      <div class="ai-form-row">
        <label class="ai-form-label" for="ai-level">当前水平</label>
        <select id="ai-level" class="ai-form-select">
          <option value="beginner">零基础</option>
          <option value="intermediate">有一定基础</option>
          <option value="advanced">较熟练</option>
        </select>
      </div>
      <div class="ai-form-row">
        <label class="ai-form-label" for="ai-weeks">可用时间（周）</label>
        <input type="number" id="ai-weeks" class="ai-form-input" value="12" min="1" max="52" />
      </div>
      <button class="ai-plan-btn" id="ai-plan-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        生成学习路线
      </button>
    </div>
  </div>

  <!-- 路线结果展示区 -->
  <div class="ai-roadmap-result" id="ai-roadmap-result" style="display:none">
    <div class="ai-result-header">
      <div class="ai-result-info">
        <span class="ai-result-goal" id="ai-result-goal"></span>
        <span class="ai-result-meta" id="ai-result-meta"></span>
      </div>
      <div class="ai-result-actions">
        <button class="ai-save-btn" id="ai-save-btn" title="保存路线">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          保存
        </button>
        <button class="ai-reset-btn" id="ai-reset-btn" title="重新规划">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
          重新规划
        </button>
      </div>
    </div>
    <!-- 进度条 -->
    <div class="ai-progress-bar" id="ai-progress-bar">
      <div class="ai-progress-fill" id="ai-progress-fill"></div>
      <span class="ai-progress-text" id="ai-progress-text">0%</span>
    </div>
    <!-- 阶段列表 -->
    <div class="ai-phases" id="ai-phases"></div>
  </div>

  <!-- 加载状态 -->
  <div class="ai-loading" id="ai-loading" style="display:none">
    <div class="ai-loading-spinner"></div>
    <span class="ai-loading-text">正在规划学习路线...</span>
  </div>

  <!-- 错误状态 -->
  <div class="ai-error" id="ai-error" style="display:none">
    <span class="ai-error-text" id="ai-error-text"></span>
  </div>
</div>

<style>
/* AI 路线规划容器 */
.ai-roadmap {
  margin-top: var(--spacing-xl);
  border: 1px solid var(--color-border-light);
  background: var(--color-bg-card);
}

/* AI 标识 */
.ai-badge {
  display: inline-block;
  padding: 2px 8px;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-family: var(--font-display);
  font-size: 0.7em;
  font-weight: 700;
  letter-spacing: 0.05em;
}

/* 输入区 */
.ai-roadmap-input {
  padding: var(--spacing-lg);
  border-bottom: 1px solid var(--color-border-light);
}

.ai-input-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.ai-input-title {
  font-family: var(--font-display);
  font-size: 1em;
  font-weight: 700;
  color: var(--color-text);
}

.ai-input-form {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
  align-items: flex-end;
}

.ai-form-row {
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
  min-width: 150px;
}

.ai-form-label {
  font-size: 0.8em;
  color: var(--color-text-secondary);
  font-weight: 600;
}

.ai-form-input,
.ai-form-select {
  padding: 8px 12px;
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
  font-size: 0.9em;
  font-family: inherit;
  transition: border-color var(--transition-fast);
}

.ai-form-input:focus,
.ai-form-select:focus {
  outline: none;
  border-color: var(--color-primary);
}

.ai-plan-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 8px 20px;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  border: none;
  font-family: var(--font-display);
  font-size: 0.9em;
  font-weight: 600;
  cursor: pointer;
  transition: opacity var(--transition-fast);
  white-space: nowrap;
}

.ai-plan-btn:hover {
  opacity: 0.9;
}

.ai-plan-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* 结果区 */
.ai-roadmap-result {
  padding: var(--spacing-lg);
}

.ai-result-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-md);
  flex-wrap: wrap;
  gap: var(--spacing-sm);
}

.ai-result-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.ai-result-goal {
  font-family: var(--font-display);
  font-size: 1.1em;
  font-weight: 700;
  color: var(--color-text);
}

.ai-result-meta {
  font-size: 0.8em;
  color: var(--color-text-tertiary);
}

.ai-result-actions {
  display: flex;
  gap: var(--spacing-sm);
}

.ai-save-btn,
.ai-reset-btn {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 6px 12px;
  border: 1px solid var(--color-border-light);
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  font-size: 0.8em;
  cursor: pointer;
  transition: all var(--transition-fast);
}

.ai-save-btn:hover,
.ai-reset-btn:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

/* 进度条 */
.ai-progress-bar {
  position: relative;
  height: 24px;
  background: var(--color-border-light);
  margin-bottom: var(--spacing-lg);
  overflow: hidden;
}

.ai-progress-fill {
  height: 100%;
  background: var(--color-primary);
  transition: width 0.5s ease;
  width: 0%;
}

.ai-progress-text {
  position: absolute;
  right: 8px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.75em;
  font-weight: 700;
  color: var(--color-text);
  mix-blend-mode: difference;
}

/* 阶段列表 */
.ai-phases {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}

.ai-phase {
  border: 1px solid var(--color-border-light);
  background: var(--color-bg);
}

.ai-phase-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border-bottom: 1px solid var(--color-border-light);
}

.ai-phase-number {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 24px;
  height: 24px;
  background: var(--color-primary);
  color: var(--color-text-inverse);
  font-family: var(--font-display);
  font-size: 0.75em;
  font-weight: 700;
}

.ai-phase-name {
  font-family: var(--font-display);
  font-size: 0.95em;
  font-weight: 700;
  color: var(--color-text);
}

.ai-phase-goal {
  font-size: 0.8em;
  color: var(--color-text-tertiary);
  margin-left: auto;
}

.ai-phase-steps {
  padding: var(--spacing-sm) var(--spacing-md);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.ai-phase-step {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: 6px 0;
}

.ai-step-status {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 2px solid var(--color-border);
  flex-shrink: 0;
}

.ai-step-status.done {
  background: var(--color-primary);
  border-color: var(--color-primary);
}

.ai-step-link {
  font-size: 0.9em;
  color: var(--color-text);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.ai-step-link:hover {
  color: var(--color-primary);
}

.ai-step-days {
  font-size: 0.75em;
  color: var(--color-text-tertiary);
  margin-left: auto;
}

.ai-phase-checkpoint {
  padding: var(--spacing-xs) var(--spacing-md);
  font-size: 0.8em;
  color: var(--color-text-tertiary);
  border-top: 1px solid var(--color-border-light);
  font-style: italic;
}

/* 加载状态 */
.ai-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-2xl);
}

.ai-loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid var(--color-border-light);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: ai-spin 0.8s linear infinite;
}

@keyframes ai-spin {
  to { transform: rotate(360deg); }
}

.ai-loading-text {
  font-size: 0.9em;
  color: var(--color-text-secondary);
}

/* 错误状态 */
.ai-error {
  padding: var(--spacing-md);
  background: rgba(214, 48, 49, 0.08);
  border-top: 2px solid #d63031;
}

.ai-error-text {
  font-size: 0.85em;
  color: #d63031;
}

/* 响应式 */
@media (max-width: 768px) {
  .ai-input-form {
    flex-direction: column;
  }

  .ai-form-row {
    min-width: auto;
  }

  .ai-result-header {
    flex-direction: column;
    align-items: flex-start;
  }

  .ai-phase-goal {
    display: none;
  }
}
</style>

<script>
  /**
   * AI 路线规划交互逻辑
   *
   * 流程：
   * 1. 用户输入学习目标 -> 点击生成按钮
   * 2. 调用 RoadmapService 生成路线
   * 3. 展示分阶段路线结果
   * 4. 支持保存到 localStorage
   */
  import { getRoadmapService, isAIAvailable } from '@/services/index';
  import type { PersonalizedRoadmap, RoadmapPhase, RoadmapStep } from '@/services/index';

  /** 当前路线数据 */
  let currentRoadmap: PersonalizedRoadmap | null = null;

  const planBtn = document.getElementById('ai-plan-btn') as HTMLButtonElement;
  const goalInput = document.getElementById('ai-goal') as HTMLInputElement;
  const levelSelect = document.getElementById('ai-level') as HTMLSelectElement;
  const weeksInput = document.getElementById('ai-weeks') as HTMLInputElement;
  const resultDiv = document.getElementById('ai-roadmap-result') as HTMLDivElement;
  const loadingDiv = document.getElementById('ai-loading') as HTMLDivElement;
  const errorDiv = document.getElementById('ai-error') as HTMLDivElement;
  const errorText = document.getElementById('ai-error-text') as HTMLSpanElement;
  const resultGoal = document.getElementById('ai-result-goal') as HTMLSpanElement;
  const resultMeta = document.getElementById('ai-result-meta') as HTMLSpanElement;
  const phasesDiv = document.getElementById('ai-phases') as HTMLDivElement;
  const progressFill = document.getElementById('ai-progress-fill') as HTMLDivElement;
  const progressText = document.getElementById('ai-progress-text') as HTMLSpanElement;
  const saveBtn = document.getElementById('ai-save-btn') as HTMLButtonElement;
  const resetBtn = document.getElementById('ai-reset-btn') as HTMLButtonElement;

  const base = document.querySelector('base')?.getAttribute('href') || '/';

  /**
   * 获取用户已学模块列表
   *
   * 输入：无
   * 输出：已完成的模块 ID 数组
   * 流程：从 localStorage 读取进度数据 -> 提取已完成模块
   */
  function getLearnedModules(): string[] {
    try {
      const raw = localStorage.getItem('fandex-progress');
      if (!raw) return [];
      const progress: Record<string, { status: string }> = JSON.parse(raw);
      /** 按模块前缀分组，若模块下所有文档都完成则视为已学 */
      const moduleStatus: Record<string, { total: number; done: number }> = {};
      for (const [key, val] of Object.entries(progress)) {
        const moduleId = key.split('/')[0];
        if (!moduleStatus[moduleId]) {
          moduleStatus[moduleId] = { total: 0, done: 0 };
        }
        moduleStatus[moduleId].total++;
        if (val.status === 'done') {
          moduleStatus[moduleId].done++;
        }
      }
      /** 至少完成 50% 文档的模块视为已学 */
      return Object.entries(moduleStatus)
        .filter(([, s]) => s.total > 0 && s.done / s.total >= 0.5)
        .map(([id]) => id);
    } catch {
      return [];
    }
  }

  /**
   * 渲染路线结果
   *
   * 输入：PersonalizedRoadmap
   * 输出：void（更新 DOM）
   */
  function renderRoadmap(roadmap: PersonalizedRoadmap): void {
    currentRoadmap = roadmap;

    resultGoal.textContent = roadmap.goal;
    const aiLabel = roadmap.aiGenerated ? 'AI 生成' : '规则推荐';
    const phaseCount = roadmap.phases.length;
    const totalSteps = roadmap.phases.reduce((sum, p) => sum + p.steps.length, 0);
    const totalDays = roadmap.phases.reduce(
      (sum, p) => sum + p.steps.reduce((s, step) => s + step.estimatedDays, 0), 0
    );
    resultMeta.textContent = `${aiLabel} | ${phaseCount} 个阶段 | ${totalSteps} 个模块 | 约 ${totalDays} 天`;

    /** 计算进度 */
    const learnedSet = new Set(getLearnedModules());
    const completedSteps = roadmap.phases.reduce(
      (sum, p) => sum + p.steps.filter((s) => learnedSet.has(s.moduleId)).length, 0
    );
    const pct = totalSteps > 0 ? Math.round((completedSteps / totalSteps) * 100) : 0;
    progressFill.style.width = `${pct}%`;
    progressText.textContent = `${pct}%`;

    /** 渲染阶段 */
    phasesDiv.innerHTML = '';
    for (const phase of roadmap.phases) {
      const phaseEl = document.createElement('div');
      phaseEl.className = 'ai-phase';

      const headerEl = document.createElement('div');
      headerEl.className = 'ai-phase-header';
      headerEl.innerHTML = `
        <span class="ai-phase-number">${phase.phase}</span>
        <span class="ai-phase-name">${phase.name}</span>
        <span class="ai-phase-goal">${phase.goal}</span>
      `;
      phaseEl.appendChild(headerEl);

      const stepsEl = document.createElement('div');
      stepsEl.className = 'ai-phase-steps';
      for (const step of phase.steps) {
        const stepEl = document.createElement('div');
        stepEl.className = 'ai-phase-step';
        const isDone = learnedSet.has(step.moduleId);
        stepEl.innerHTML = `
          <span class="ai-step-status${isDone ? ' done' : ''}"></span>
          <a class="ai-step-link" href="${base}${step.moduleId}/">${step.title}</a>
          <span class="ai-step-days">${step.estimatedDays} 天</span>
        `;
        stepsEl.appendChild(stepEl);
      }
      phaseEl.appendChild(stepsEl);

      if (phase.checkpoint) {
        const checkpointEl = document.createElement('div');
        checkpointEl.className = 'ai-phase-checkpoint';
        checkpointEl.textContent = `检验标准：${phase.checkpoint}`;
        phaseEl.appendChild(checkpointEl);
      }

      phasesDiv.appendChild(phaseEl);
    }

    resultDiv.style.display = 'block';
    errorDiv.style.display = 'none';
  }

  /**
   * 显示错误信息
   *
   * 输入：错误消息文本
   * 输出：void
   */
  function showError(message: string): void {
    errorText.textContent = message;
    errorDiv.style.display = 'block';
    resultDiv.style.display = 'none';
  }

  /**
   * 生成路线按钮点击处理
   *
   * 输入：点击事件
   * 输出：void
   * 流程：校验输入 -> 显示加载 -> 调用服务 -> 渲染结果
   */
  async function handlePlan(): Promise<void> {
    const goal = goalInput.value.trim();
    if (!goal) {
      showError('请输入学习目标');
      return;
    }

    const level = levelSelect.value;
    const weeks = parseInt(weeksInput.value, 10);
    if (isNaN(weeks) || weeks < 1) {
      showError('请输入有效的可用时间');
      return;
    }

    planBtn.disabled = true;
    loadingDiv.style.display = 'flex';
    errorDiv.style.display = 'none';
    resultDiv.style.display = 'none';

    try {
      const service = getRoadmapService();
      const roadmap = await service.generateRoadmap({
        goal,
        learnedModules: getLearnedModules(),
        weeksAvailable: weeks,
        level,
      });
      renderRoadmap(roadmap);
    } catch (err) {
      showError(`路线规划失败: ${err instanceof Error ? err.message : String(err)}`);
    } finally {
      planBtn.disabled = false;
      loadingDiv.style.display = 'none';
    }
  }

  /**
   * 保存路线到 localStorage
   *
   * 输入：点击事件
   * 输出：void
   */
  function handleSave(): void {
    if (!currentRoadmap) return;
    try {
      const service = getRoadmapService();
      service.saveRoadmap(currentRoadmap);
      saveBtn.innerHTML = `
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
        已保存
      `;
      setTimeout(() => {
        saveBtn.innerHTML = `
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          保存
        `;
      }, 2000);
    } catch (err) {
      console.error('路线保存失败:', err);
    }
  }

  /**
   * 重新规划
   *
   * 输入：点击事件
   * 输出：void
   */
  function handleReset(): void {
    currentRoadmap = null;
    resultDiv.style.display = 'none';
    errorDiv.style.display = 'none';
    goalInput.value = '';
    goalInput.focus();
  }

  /**
   * 加载已保存的路线
   *
   * 输入：无
   * 输出：void
   */
  function loadSavedRoadmap(): void {
    try {
      const service = getRoadmapService();
      const saved = service.loadLatestRoadmap();
      if (saved) {
        renderRoadmap(saved);
      }
    } catch {
      /* 忽略加载失败 */
    }
  }

  /* 绑定事件 */
  if (planBtn) planBtn.addEventListener('click', handlePlan);
  if (saveBtn) saveBtn.addEventListener('click', handleSave);
  if (resetBtn) resetBtn.addEventListener('click', handleReset);

  /* 回车触发规划 */
  if (goalInput) goalInput.addEventListener('keydown', (e) => {
    if (e.key === 'Enter') handlePlan();
  });

  /* 页面加载时尝试恢复已保存的路线 */
  loadSavedRoadmap();

  /* 进度变更时更新进度条 */
  document.addEventListener('fandex-progress-change', () => {
    if (currentRoadmap) renderRoadmap(currentRoadmap);
  });
</script>
