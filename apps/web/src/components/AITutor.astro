---
/**
 * AI Tutor 组件
 *
 * 在文档页面中提供 AI 驱动的学习推荐和学习进度统计。
 * 用户点击"学习推荐"按钮后调用 Tutor 服务获取推荐，
 * AI 不可用时基于模块前置关系提供简单推荐。
 *
 * 功能：
 * - "学习推荐"按钮：点击后调用 Tutor 服务获取推荐
 * - 推荐列表：显示推荐文档及推荐理由
 * - 学习统计：显示当前学习进度概览
 * - 降级策略：AI 不可用时基于前置关系的简单推荐
 *
 * 数据流：
 * - Props 传入基础信息（moduleId, availableModules）
 * - 用户点击按钮 -> 读取 localStorage 进度 -> 动态导入 tutor 服务 -> 获取推荐 -> 渲染
 * - 学习统计从 localStorage fandex-progress 读取
 */

interface Props {
  /** 当前模块 ID */
  moduleId: string;
  /** 可用模块列表 JSON 字符串 */
  availableModules: string;
}

const { moduleId, availableModules } = Astro.props;
---

<div class="ai-tutor" data-module-id={moduleId} data-available-modules={availableModules}>
  <!-- 学习统计概览 -->
  <div class="ai-tutor-stats" id="ai-tutor-stats">
    <h4 class="ai-tutor-stats-title">学习进度</h4>
    <div class="ai-tutor-stats-grid" id="ai-tutor-stats-grid">
      <div class="ai-tutor-stat-item">
        <span class="ai-tutor-stat-value" id="ai-tutor-stat-docs">--</span>
        <span class="ai-tutor-stat-label">已学文档</span>
      </div>
      <div class="ai-tutor-stat-item">
        <span class="ai-tutor-stat-value" id="ai-tutor-stat-rate">--%</span>
        <span class="ai-tutor-stat-label">知识覆盖率</span>
      </div>
    </div>
  </div>

  <!-- 推荐区域 -->
  <div class="ai-tutor-recommend">
    <div class="ai-tutor-recommend-header">
      <h4 class="ai-tutor-recommend-title">学习推荐</h4>
      <button class="ai-tutor-recommend-btn" id="ai-tutor-recommend-btn">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
        </svg>
        获取推荐
      </button>
    </div>
    <!-- 推荐列表容器 -->
    <div class="ai-tutor-recommend-list" id="ai-tutor-recommend-list"></div>
    <!-- 加载状态 -->
    <div class="ai-tutor-loading" id="ai-tutor-loading" style="display:none;">
      <span class="ai-tutor-spinner"></span>
      <span>正在分析学习进度...</span>
    </div>
  </div>
</div>

<script define:vars={{ moduleId, availableModules }}>
  /**
   * AI Tutor 客户端交互逻辑
   *
   * 流程：
   * 1. 页面加载时读取 localStorage 进度，渲染学习统计
   * 2. 用户点击"获取推荐"按钮 -> 动态导入 tutor 服务 -> 获取推荐 -> 渲染
   */
  (function initAITutor() {
    const recommendBtn = document.getElementById('ai-tutor-recommend-btn');
    const recommendList = document.getElementById('ai-tutor-recommend-list');
    const loadingEl = document.getElementById('ai-tutor-loading');
    const statDocs = document.getElementById('ai-tutor-stat-docs');
    const statRate = document.getElementById('ai-tutor-stat-rate');

    if (!recommendBtn || !recommendList) return;

    /* 页面加载时渲染学习统计 */
    renderStats();

    /**
     * 读取 localStorage 进度数据并渲染统计
     */
    function renderStats() {
      try {
        const raw = localStorage.getItem('fandex-progress');
        const progress = raw ? JSON.parse(raw) : {};
        let completedCount = 0;
        let totalCount = 0;

        for (const key in progress) {
          if (progress[key] && progress[key].status === 'done') {
            completedCount++;
          }
        }

        /* 总文档数从 search-index.json 获取，此处使用简化估算 */
        let modules = [];
        try {
          modules = JSON.parse(availableModules);
        } catch (e) {
          modules = [];
        }
        totalCount = modules.length * 10; /* 粗略估算 */

        const rate = totalCount > 0 ? Math.round((completedCount / totalCount) * 100) : 0;

        if (statDocs) statDocs.textContent = completedCount;
        if (statRate) statRate.textContent = Math.min(rate, 100) + '%';
      } catch (e) {
        if (statDocs) statDocs.textContent = '0';
        if (statRate) statRate.textContent = '0%';
      }
    }

    /**
     * 点击"获取推荐"按钮处理
     */
    recommendBtn.addEventListener('click', async function () {
      recommendBtn.disabled = true;
      if (loadingEl) loadingEl.style.display = 'flex';
      recommendList.innerHTML = '';

      try {
        const { getTutorService } = await import('@/services/index.ts');
        const service = getTutorService();

        /* 读取用户进度 */
        const completedSlugs = [];
        try {
          const raw = localStorage.getItem('fandex-progress');
          const progress = raw ? JSON.parse(raw) : {};
          for (const key in progress) {
            if (progress[key] && progress[key].status === 'done') {
              completedSlugs.push(key);
            }
          }
        } catch (e) {
          /* 进度读取失败，使用空列表 */
        }

        let modules = [];
        try {
          modules = JSON.parse(availableModules);
        } catch (e) {
          modules = [moduleId];
        }

        const recommendations = await service.getRecommendations({
          completedSlugs: completedSlugs,
          currentModule: moduleId,
          availableModules: modules,
        });

        renderRecommendations(recommendations);
      } catch (error) {
        console.error('AI Tutor 推荐失败:', error);
        recommendList.innerHTML = '<div class="ai-tutor-error">推荐获取失败，请稍后重试</div>';
      } finally {
        recommendBtn.disabled = false;
        if (loadingEl) loadingEl.style.display = 'none';
      }
    });

    /**
     * 渲染推荐列表
     */
    function renderRecommendations(recs) {
      if (!recs || recs.length === 0) {
        recommendList.innerHTML = '<div class="ai-tutor-empty">暂无推荐内容</div>';
        return;
      }

      let html = '';
      for (let i = 0; i < recs.length; i++) {
        const rec = recs[i];
        const href = rec.slug
          ? (import.meta.env.BASE_URL || '/') + rec.moduleId + '/' + rec.slug + '/'
          : (import.meta.env.BASE_URL || '/') + rec.moduleId + '/';
        const priorityLabel = getPriorityLabel(rec.priority);

        html += '<a class="ai-tutor-rec-item" href="' + href + '">';
        html += '<div class="ai-tutor-rec-info">';
        html += '<span class="ai-tutor-rec-module">' + escapeHtml(rec.moduleId) + '</span>';
        if (rec.slug) {
          html += '<span class="ai-tutor-rec-slug">/ ' + escapeHtml(rec.slug) + '</span>';
        }
        html += '</div>';
        html += '<div class="ai-tutor-rec-reason">' + escapeHtml(rec.reason) + '</div>';
        html +=
          '<span class="ai-tutor-rec-priority priority-' +
          rec.priority +
          '">' +
          priorityLabel +
          '</span>';
        html += '</a>';
      }

      recommendList.innerHTML = html;
    }

    /**
     * 获取优先级标签
     */
    function getPriorityLabel(priority) {
      if (priority >= 5) return '强烈推荐';
      if (priority >= 4) return '推荐';
      if (priority >= 3) return '建议';
      return '可选';
    }

    /**
     * HTML 转义，防止 XSS
     */
    function escapeHtml(str) {
      if (!str) return '';
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }
  })();
</script>

<style>
  /* AI Tutor 容器 */
  .ai-tutor {
    margin-top: var(--spacing-lg);
    padding: var(--spacing-md);
    border: 1px solid var(--color-border-light);
    background: var(--color-bg-card);
  }

  /* 学习统计区域 */
  .ai-tutor-stats {
    margin-bottom: var(--spacing-md);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border-light);
  }

  .ai-tutor-stats-title,
  .ai-tutor-recommend-title {
    font-family: var(--font-display);
    font-size: 0.95em;
    font-weight: 700;
    margin: 0 0 var(--spacing-sm) 0;
  }

  /* 统计网格 */
  .ai-tutor-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-sm);
  }

  .ai-tutor-stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: var(--spacing-sm);
    background: var(--color-bg);
    border: 1px solid var(--color-border-light);
  }

  .ai-tutor-stat-value {
    font-family: var(--font-display);
    font-size: 1.2em;
    font-weight: 700;
    color: var(--color-primary);
  }

  .ai-tutor-stat-label {
    font-size: 0.75em;
    color: var(--color-text-tertiary);
    margin-top: 2px;
  }

  /* 推荐区域 */
  .ai-tutor-recommend-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  /* 获取推荐按钮 */
  .ai-tutor-recommend-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border: 1px solid var(--color-primary);
    background: transparent;
    color: var(--color-primary);
    font-size: 0.82em;
    font-family: var(--font-display);
    cursor: pointer;
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .ai-tutor-recommend-btn:hover:not(:disabled) {
    background: var(--color-primary);
    color: var(--color-text-inverse);
  }

  .ai-tutor-recommend-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* 推荐列表 */
  .ai-tutor-recommend-list {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-sm);
  }

  /* 单个推荐项 */
  .ai-tutor-rec-item {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid var(--color-border-light);
    background: var(--color-bg);
    text-decoration: none;
    color: var(--color-text);
    transition: all var(--transition-fast);
  }

  .ai-tutor-rec-item:hover {
    border-color: var(--color-primary);
    background: var(--color-bg-hover);
  }

  /* 推荐信息行 */
  .ai-tutor-rec-info {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 4px;
  }

  .ai-tutor-rec-module {
    font-family: var(--font-display);
    font-size: 0.88em;
    font-weight: 600;
    color: var(--color-primary);
  }

  .ai-tutor-rec-slug {
    font-size: 0.82em;
    color: var(--color-text-tertiary);
  }

  /* 推荐理由 */
  .ai-tutor-rec-reason {
    font-size: 0.85em;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  /* 优先级标签 */
  .ai-tutor-rec-priority {
    display: inline-block;
    margin-top: 4px;
    padding: 1px 6px;
    font-size: 0.72em;
    font-family: var(--font-display);
  }

  .ai-tutor-rec-priority.priority-5,
  .ai-tutor-rec-priority.priority-4 {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.3);
  }

  .ai-tutor-rec-priority.priority-3 {
    background: rgba(59, 130, 246, 0.1);
    color: #3b82f6;
    border: 1px solid rgba(59, 130, 246, 0.3);
  }

  .ai-tutor-rec-priority.priority-2,
  .ai-tutor-rec-priority.priority-1 {
    background: var(--color-bg-card);
    color: var(--color-text-tertiary);
    border: 1px solid var(--color-border-light);
  }

  /* 加载状态 */
  .ai-tutor-loading {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-md);
    color: var(--color-text-secondary);
    font-size: 0.9em;
  }

  /* 旋转动画 */
  .ai-tutor-spinner {
    display: inline-block;
    width: 16px;
    height: 16px;
    border: 2px solid var(--color-border-light);
    border-top-color: var(--color-primary);
    border-radius: 50%;
    animation: ai-tutor-spin 0.6s linear infinite;
  }

  @keyframes ai-tutor-spin {
    to {
      transform: rotate(360deg);
    }
  }

  /* 空状态 */
  .ai-tutor-empty {
    padding: var(--spacing-md);
    text-align: center;
    color: var(--color-text-tertiary);
    font-size: 0.9em;
  }

  /* 错误状态 */
  .ai-tutor-error {
    padding: var(--spacing-md);
    text-align: center;
    color: #ef4444;
    font-size: 0.9em;
  }

  /* 移动端适配 */
  @media (max-width: 768px) {
    .ai-tutor {
      padding: var(--spacing-sm);
    }

    .ai-tutor-recommend-header {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
