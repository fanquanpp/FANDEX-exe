---
/**
 * BaseHead 组件 - HTML <head> 元信息聚合
 *
 * 功能概述：
 * - 输出 charset / viewport / CSP / PWA / 字体预加载 / RSS / canonical 等核心 meta
 * - 内联主题防 FOUC 脚本：从 localStorage 读取 fandex-theme，同步设置 .dark class
 * - Tauri 兼容：CSP 允许 tauri: 协议，所有链接使用相对路径
 *
 * Props:
 *   title       - 页面标题
 *   description - 页面描述（默认使用 SITE.description）
 *   image       - 社交分享图片（绝对或相对 URL）
 *   noindex     - 是否禁止搜索引擎索引
 *   canonical   - 规范链接（如未提供则基于当前 URL 生成）
 */
import { SITE } from '@/lib/constants';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const { title, description = SITE.description, image, noindex = false, canonical } = Astro.props;

/** Astro 构建基础路径（GitHub Pages 默认 /FANDEX-exe/，桌面端 ./） */
const base = import.meta.env.BASE_URL;

/** 站点图标与 PWA 资源路径 */
const iconSvg = `${base}icons/icon.svg`;
const icon192 = `${base}icons/icon-192.png`;
const appleTouchIcon = `${base}icons/apple-touch-icon.png`;
const manifestHref = `${base}manifest.json`;

/** 字体预加载（JetBrains Mono 等宽字体，来自 public/fonts/） */
const fontRegular = `${base}fonts/jetbrains-mono-400.woff2`;
const fontBold = `${base}fonts/jetbrains-mono-700.woff2`;
const fontsCss = `${base}fonts/fonts.css`;

/** RSS 订阅链接 */
const rssHref = `${base}rss.xml`;

/** Sitemap 索引 */
const sitemapHref = `${base}sitemap-index.xml`;

/** 完整页面标题（带站点名后缀） */
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.name}`;

/** 规范链接（如未提供则基于当前 URL 与站点 URL 拼接） */
const canonicalUrl = canonical || new URL(Astro.url.pathname, SITE.url).toString();

/** 主题色（移动浏览器地址栏颜色） */
const themeColorLight = SITE.themeColor.light;
const themeColorDark = SITE.themeColor.dark;

/**
 * CSP 内容安全策略
 *
 * 设计要点：
 * - default-src 'self'：默认仅允许同源资源
 * - img-src：允许 data: 与 https: 图片，tauri: 协议用于桌面端本地资源
 * - style-src/script-src 'unsafe-inline'：Astro 内联样式与脚本需要
 * - connect-src 'self' https://giscus.app：Giscus 评论系统 API
 * - frame-src https://giscus.app：Giscus iframe
 * - worker-src 'self' blob:：Pagefind 搜索 worker
 * - manifest-src 'self'：PWA manifest
 */
const csp = [
  "default-src 'self'",
  "img-src 'self' data: https: tauri: asset:",
  "style-src 'self' 'unsafe-inline'",
  "script-src 'self' 'unsafe-inline'",
  "font-src 'self' data:",
  "connect-src 'self' https://giscus.app",
  'frame-src https://giscus.app',
  "worker-src 'self' blob:",
  "manifest-src 'self'",
].join('; ');
---

<!-- 基础元信息 -->
<meta charset="UTF-8" />
<meta
  name="viewport"
  content="width=device-width, initial-scale=1.0, viewport-fit=cover"
/>
<meta name="referrer" content="strict-origin-when-cross-origin" />
<meta name="format-detection" content="telephone=no" />

<!-- CSP 内容安全策略（Tauri 兼容） -->
<meta http-equiv="Content-Security-Policy" content={csp} />

<!-- 页面标题与描述 -->
<title>{fullTitle}</title>
<meta name="description" content={description} />
<meta name="author" content={SITE.author} />

<!-- 搜索引擎索引控制 -->
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- 规范链接 -->
<link rel="canonical" href={canonicalUrl} />

<!-- PWA 配置 -->
<link rel="manifest" href={manifestHref} />
<meta name="theme-color" content={themeColorLight} media="(prefers-color-scheme: light)" />
<meta name="theme-color" content={themeColorDark} media="(prefers-color-scheme: dark)" />
<link rel="apple-touch-icon" href={appleTouchIcon} />
<link rel="icon" type="image/svg+xml" href={iconSvg} />
<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
<link rel="apple-touch-icon" sizes="180x180" href={appleTouchIcon} />
<meta name="apple-mobile-web-app-capable" content="yes" />
<meta name="apple-mobile-web-app-status-bar-style" content="default" />
<meta name="apple-mobile-web-app-title" content={SITE.name} />
<meta name="mobile-web-app-capable" content="yes" />

<!-- RSS 订阅 -->
<link rel="alternate" type="application/rss+xml" title={SITE.title} href={rssHref} />

<!-- Sitemap -->
<link rel="sitemap" type="application/xml" href={sitemapHref} />

<!-- 字体预加载：JetBrains Mono 等宽字体 -->
<link rel="preload" href={fontRegular} as="font" type="font/woff2" crossorigin />
<link rel="preload" href={fontBold} as="font" type="font/woff2" crossorigin />
<link rel="stylesheet" href={fontsCss} />

<!-- 社交分享图片（默认站点图标） -->
<meta property="og:image" content={image || `${base}icons/icon-512.png`} />

<!--
  主题防 FOUC 内联脚本
  - 必须在 <head> 内同步执行，避免亮暗模式闪烁
  - 优先级：localStorage 'fandex-theme' > 系统偏好 prefers-color-scheme
  - 通过 .dark class 切换（globals.css 已配置 @custom-variant dark）
-->
<!--
  data-astro-rerun：ClientRouter 导航时重新执行此内联脚本
  - 作为 view-transitions.ts 的 before-swap 主题保留逻辑的兜底防线
  - 符合 defense-in-depth 原则：即使 view-transitions.ts 失效仍能恢复主题
-->
<script is:inline data-astro-rerun>
  (function () {
    try {
      var raw = localStorage.getItem('fandex-theme');
      var isDark = false;
      if (raw === 'dark') {
        isDark = true;
      } else if (raw === 'light') {
        isDark = false;
      } else if (!raw && window.matchMedia('(prefers-color-scheme: dark)').matches) {
        isDark = true;
      }
      var root = document.documentElement;
      if (isDark) {
        root.classList.add('dark');
        root.style.colorScheme = 'dark';
      } else {
        root.classList.remove('dark');
        root.style.colorScheme = 'light';
      }
    } catch (e) {
      /* localStorage 不可用时静默降级到系统偏好 */
    }
  })();
</script>
