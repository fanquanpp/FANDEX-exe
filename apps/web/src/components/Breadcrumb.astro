---
/**
 * Breadcrumb 面包屑导航组件
 *
 * 功能概述：
 * - 显示当前页面的层级路径（首页 > 模块 > 文档）
 * - 移动端折叠中间层级，仅显示首尾与省略号
 * - 可选侧边栏开关按钮（仅文档页 hasSidebar=true 时显示）
 * - 完整无障碍：nav[aria-label]、aria-current="page"
 * - 基于 Tailwind v4 工具类实现样式
 *
 * Props:
 *   items       - 面包屑层级数组（按从根到当前顺序）
 *   hasSidebar  - 是否包含侧边栏（决定是否显示菜单切换按钮）
 */
import { withBase } from '@/lib/url';

/** 面包屑条目（与 SEO.astro 的 BreadcrumbItem 共用结构） */
interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  items: readonly BreadcrumbItem[];
  hasSidebar?: boolean;
}

const { items, hasSidebar = false } = Astro.props;

/** 计算每个条目是否在移动端折叠（中间层级） */
const shouldCollapseMobile = (index: number): boolean => {
  return items.length > 2 && index > 0 && index < items.length - 1;
};
---

<nav
  aria-label="面包屑导航"
  class="flex items-center gap-1 border-b border-border bg-background/80 px-4 py-2 text-sm backdrop-blur-md md:px-6"
>
  <!-- 侧边栏开关按钮（仅文档页显示，移动端可见） -->
  {
    hasSidebar && (
      <button
        type="button"
        id="breadcrumb-sidebar-toggle"
        class="mr-1 inline-flex h-8 w-8 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground md:hidden"
        aria-label="切换侧边栏"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="3" y1="6" x2="21" y2="6" />
          <line x1="3" y1="12" x2="21" y2="12" />
          <line x1="3" y1="18" x2="21" y2="18" />
        </svg>
      </button>
    )
  }

  <ol class="flex flex-wrap items-center gap-1 min-w-0">
    {
      items.map((item, index) => {
        const isLast = index === items.length - 1;
        const isCollapsedMobile = shouldCollapseMobile(index);
        const href = item.href ? withBase(item.href) : undefined;

        return (
          <li class="flex items-center gap-1 min-w-0">
            {index > 0 && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class={`h-3.5 w-3.5 flex-shrink-0 text-muted-foreground/50 ${isCollapsedMobile ? 'hidden md:inline' : ''}`}
                aria-hidden="true"
              >
                <polyline points="9 18 15 12 9 6" />
              </svg>
            )}
            {isCollapsedMobile && (
              <span
                class="flex items-center text-muted-foreground/60 md:hidden"
                aria-hidden="true"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-3.5 w-3.5"
                >
                  <circle cx="12" cy="12" r="1" />
                  <circle cx="19" cy="12" r="1" />
                  <circle cx="5" cy="12" r="1" />
                </svg>
              </span>
            )}
            {href && !isLast ? (
              <a
                href={href}
                class={`truncate text-muted-foreground transition-colors hover:text-foreground ${isCollapsedMobile ? 'hidden md:inline' : ''}`}
              >
                {item.label}
              </a>
            ) : (
              <span
                aria-current={isLast ? 'page' : undefined}
                class={`truncate font-medium text-foreground ${isCollapsedMobile ? 'hidden md:inline' : ''}`}
              >
                {item.label}
              </span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>
