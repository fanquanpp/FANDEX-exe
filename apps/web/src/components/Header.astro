---
/**
 * Header 顶部导航栏组件
 *
 * 功能概述：
 * - 站点全局顶部导航栏，sticky 定位固定在视口顶部
 * - 左侧：汉堡菜单（移动端，文档页可见）+ Logo
 * - 中部：搜索触发按钮（Ctrl+K 唤起 SearchModal）
 * - 右侧：GitHub 链接 + 文档同步 + 主题切换 React 岛屿（client:load）
 * - 高度 h-14（56px），毛玻璃背景 + 边框
 * - 完整无障碍：header[role="banner"]、aria-label、键盘可达
 * - 基于 Tailwind v4 工具类实现样式
 *
 * Props:
 *   hasSidebar      - 是否包含侧边栏（决定汉堡菜单是否显示）
 *   onToggleSidebar - 侧边栏切换事件名（用于事件委托，可选）
 *
 * React 岛屿水合：
 * - ThemeToggle: client:load（首屏即用，避免主题切换延迟）
 * - SearchModal: client:load（Ctrl+K 全局可用，需立即可触发）
 * - DocSyncPanel: client:idle（空闲时水合，提供应用内文档更新入口）
 */
import DocSyncPanel from '@/islands/DocSyncPanel';
import SearchModal from '@/islands/SearchModal';
import ShortcutHelp from '@/islands/ShortcutHelp';
import ThemeToggle from '@/islands/ThemeToggle';
import { SITE } from '@/lib/constants';
import { withBase } from '@/lib/url';

interface Props {
  hasSidebar?: boolean;
}

const { hasSidebar = false } = Astro.props;

/** GitHub 仓库地址 */
const githubUrl = 'https://github.com/fanquanpp/FANDEX-exe';
---

<header
  role="banner"
  class="sticky top-0 z-40 flex h-14 items-center gap-2 border-b border-border bg-background/80 px-4 backdrop-blur-md md:px-6"
>
  <!-- 左侧：汉堡菜单（移动端文档页） + Logo -->
  <div class="flex items-center gap-2">
    {
      hasSidebar && (
        <button
          type="button"
          id="header-sidebar-toggle"
          class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground md:hidden"
          aria-label="切换侧边栏"
          aria-controls="app-sidebar"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="3" y1="6" x2="21" y2="6" />
            <line x1="3" y1="12" x2="21" y2="12" />
            <line x1="3" y1="18" x2="21" y2="18" />
          </svg>
        </button>
      )
    }

    <a
      href={withBase('/')}
      class="flex items-center gap-2 rounded-md px-1 py-0.5 transition-opacity hover:opacity-80"
      aria-label={`${SITE.name} 首页`}
    >
      <!-- Logo 标识：Sky→Teal 双色渐变方块 + 字母 F（对齐 FANDEX-Web 品牌主色系） -->
      <span
        class="flex h-7 w-7 items-center justify-center rounded-md bg-gradient-to-br from-primary to-secondary text-sm font-bold text-primary-foreground shadow-sm"
        aria-hidden="true"
      >
        F
      </span>
      <span class="hidden text-sm font-semibold tracking-tight text-foreground sm:inline">
        {SITE.name}
      </span>
    </a>
  </div>

  <!-- 中部：搜索触发器（实际为 SearchModal，包含 Ctrl+K 监听与触发按钮） -->
  <div class="ml-4 flex-1 max-w-md">
    <SearchModal client:load />
  </div>

  <!-- 右侧：GitHub 链接 + 主题切换 + 快捷键帮助 -->
  <div class="ml-auto flex items-center gap-1">
    <!-- GitHub 仓库链接 -->
    <a
      href={githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex h-9 w-9 items-center justify-center rounded-md text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
      aria-label="GitHub 源仓库"
      title="GitHub 源仓库"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="currentColor"
        aria-hidden="true"
      >
        <path
          d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
        />
      </svg>
    </a>

    <!-- 快捷键帮助面板（Ctrl+/ 触发，client:idle 等待主线程空闲） -->
    <ShortcutHelp client:idle />

    <!-- 文档同步面板（client:idle，让用户在应用内直接更新文档） -->
    <DocSyncPanel client:idle />

    <!-- 主题切换按钮（client:load，避免首屏主题切换延迟） -->
    <ThemeToggle client:load />
  </div>
</header>

<script>
  /**
   * 汉堡菜单点击事件委托
   *
   * 实现说明：
   * - 通过事件委托减少监听器数量
   * - 派发 'fandex:toggle-sidebar' 自定义事件
   *   由 Layout.astro 中的侧边栏开关逻辑监听
   * - 兼容 View Transitions：监听 astro:page-load 重新绑定
   */
  function initHeaderSidebarToggle(): void {
    const toggle = document.getElementById('header-sidebar-toggle');
    if (!toggle) return;

    toggle.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('fandex:toggle-sidebar'));
    });
  }

  initHeaderSidebarToggle();
  document.addEventListener('astro:page-load', initHeaderSidebarToggle);
</script>
