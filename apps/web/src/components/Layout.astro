---
/**
 * Layout 文档页主布局组件
 *
 * 功能概述：
 * - 文档页 HTML 骨架：BaseHead + Header + Sidebar(slot) + main + Toc(slot) + MobileNavBar + Comments
 * - 使用 Astro 7 `<ClientRouter />` 替代旧版 `<ViewTransitions />`，实现 SPA 式导航
 * - 完全移除 Vue 引用，所有交互岛屿改用 React 19 + shadcn/ui
 * - Tailwind v4 工具类实现布局与样式，移除旧 CSS 变量引用
 * - Tauri 兼容：通过 withBase() 处理路径，CSP 允许 tauri: 协议（BaseHead 已配置）
 * - 完整无障碍：skip link、main[tabindex="-1"]、aria 属性
 * - 保留 Service Worker 注册、代码块复制按钮、侧边栏遮罩等通用功能
 *
 * Props:
 *   title          - 页面标题（必填）
 *   description    - 页面描述（透传给 BaseHead / SEO）
 *   image          - 社交分享图
 *   noindex        - 是否禁止搜索引擎索引
 *   canonical      - 规范链接
 *   showMobileNav  - 是否显示移动端底部导航（默认 true）
 *   showComments   - 是否在正文末尾显示 Giscus 评论（默认 false，需配置 Giscus）
 *   hasSidebar     - 是否启用侧边栏（如未提供则根据 sidebar slot 是否存在自动判断）
 *
 * Slots:
 *   default - 主内容区
 *   head    - 追加到 <head> 的额外元素（如 SEO 组件）
 *   sidebar - 侧边栏内容（Sidebar.astro）
 *   toc     - 右侧目录大纲（Toc.astro，仅桌面端显示）
 *
 * React 岛屿水合：
 * - ThemeToggle / SearchModal：client:load（在 Header 内）
 * - ShortcutHelp：client:idle（在 Layout 末尾）
 * - InstallPrompt：client:idle
 * - Comments：client:visible（仅 showComments=true 时渲染）
 */
import '@/styles/globals.css';
import '@/styles/code.css';
import '@/styles/print.css';

/**
 * View Transitions 增强脚本
 * - 注册 astro:before-swap 钩子，在 DOM 替换前保留 dark class 到 newDocument
 * - 配合 BaseHead.astro 的 data-astro-rerun FOUC 脚本形成 defense-in-depth
 * - 修复 ClientRouter 导航后主题被强制重置为亮色的 bug
 */
import '@/scripts/view-transitions';

import { ClientRouter } from 'astro:transitions';
import BaseHead from '@/components/BaseHead.astro';
import Header from '@/components/Header.astro';
import MobileNavBar from '@/components/MobileNavBar.astro';
import Comments from '@/islands/Comments';
import InstallPrompt from '@/islands/InstallPrompt';
import ShortcutHelp from '@/islands/ShortcutHelp';
import { SITE } from '@/lib/constants';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  showMobileNav?: boolean;
  showComments?: boolean;
  hasSidebar?: boolean;
}

const {
  title,
  description,
  image,
  noindex,
  canonical,
  showMobileNav = true,
  showComments = false,
  hasSidebar = false,
} = Astro.props;

/** 自动检测 slot 是否提供 sidebar / toc 内容 */
const hasSidebarSlot = Astro.slots.has('sidebar');
const hasTocSlot = Astro.slots.has('toc');
const sidebarEnabled = hasSidebar || hasSidebarSlot;

/**
 * Giscus 评论系统配置
 *
 * 配置来源：环境变量（构建时注入）或默认占位值
 * - 当 GISCUS_REPO_ID 与 GISCUS_CATEGORY_ID 均非空时启用 Giscus
 * - 否则降级显示"评论功能待启用"静态提示，避免空配置导致 Giscus 加载失败
 *
 * 启用步骤：
 * 1. 在 GitHub 仓库启用 Discussions 并创建 Comments 分类
 * 2. 访问 https://giscus.app 获取 repoId / categoryId
 * 3. 在仓库根目录创建 .env 文件并填入：
 *    GISCUS_REPO_ID=R_xxx
 *    GISCUS_CATEGORY_ID=DIC_xxx
 * 4. 重新执行 pnpm --filter web build
 */
const GISCUS_CONFIG = {
  repo: 'fanquanpp/FANDEX-exe' as const,
  repoId: import.meta.env.GISCUS_REPO_ID ?? '',
  category: 'Comments',
  categoryId: import.meta.env.GISCUS_CATEGORY_ID ?? '',
} as const;

/** 是否启用 Giscus（仅在 repoId 与 categoryId 均配置时启用） */
const giscusEnabled = GISCUS_CONFIG.repoId !== '' && GISCUS_CONFIG.categoryId !== '';
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <BaseHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
      canonical={canonical}
    />
    <!-- Astro 7 ClientRouter：替代旧版 ViewTransitions，提供 SPA 式导航过渡 -->
    <ClientRouter />
    <slot name="head" />
  </head>
  <body
    class="flex h-screen flex-col overflow-hidden bg-background text-foreground antialiased"
  >
    <!-- 无障碍：跳转到主内容 -->
    <a
      href="#app-main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-[100] focus:rounded-md focus:border focus:border-border focus:bg-background focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:shadow-lg"
    >
      跳转到主内容
    </a>

    <!-- 顶部导航栏（sticky 顶部，含 SearchModal / ThemeToggle / ShortcutHelp / GitHub） -->
    <Header hasSidebar={sidebarEnabled} />

    <!-- PWA 安装提示（延迟弹出，已安装或永久关闭后不渲染） -->
    <InstallPrompt client:idle />

    <!-- 侧边栏遮罩层：移动端 sidebar 打开时显示，点击关闭 -->
    {
      sidebarEnabled && (
        <div
          id="sidebar-backdrop"
          class="fixed inset-0 top-14 z-30 hidden bg-black/40 backdrop-blur-sm md:hidden"
          data-sidebar-backdrop
          aria-hidden="true"
        />
      )
    }

    <!-- 主布局：侧边栏 + 主内容 + 目录大纲 -->
    <div class="flex min-h-0 flex-1">
      <!-- 侧边栏（Sidebar.astro 自身处理 fixed/sticky 定位与移动端滑入） -->
      {sidebarEnabled && <slot name="sidebar" />}

      <!-- 主内容区：唯一滚动容器，Toc / Sidebar 通过 #app-main 引用 -->
      <main
        id="app-main"
        class="min-w-0 flex-1 overflow-y-auto px-4 py-6 pb-20 md:px-8 md:py-8 md:pb-8"
        tabindex="-1"
      >
        <div class="mx-auto flex w-full max-w-5xl gap-8">
          <!-- 文章正文 -->
          <article class="min-w-0 flex-1">
            <slot />

            <!-- 评论区：配置启用时渲染 Giscus，否则显示降级提示 -->
            {showComments && (
              <section
                class="mt-16 border-t border-border pt-8"
                aria-label="评论"
              >
                {giscusEnabled ? (
                  <Comments
                    client:visible
                    repo={GISCUS_CONFIG.repo}
                    repoId={GISCUS_CONFIG.repoId}
                    category={GISCUS_CONFIG.category}
                    categoryId={GISCUS_CONFIG.categoryId}
                  />
                ) : (
                  <div class="rounded-lg border border-dashed border-border bg-muted/30 p-6 text-center">
                    <p class="text-sm font-medium text-foreground">评论功能待启用</p>
                    <p class="mt-1 text-xs text-muted-foreground">
                      仓库管理员配置 Giscus 后将在此显示 GitHub Discussions 评论
                    </p>
                  </div>
                )}
              </section>
            )}
          </article>

          <!-- 右侧目录大纲（仅桌面端 lg+ 显示，由页面通过 slot 提供） -->
          {hasTocSlot && <slot name="toc" />}
        </div>
      </main>
    </div>

    <!-- 移动端底部导航栏（返回顶部 / 上下篇 / 目录 / 分享） -->
    {showMobileNav && <MobileNavBar showToc={hasTocSlot} showPrevNext />}

    <!-- 快捷键帮助面板（Ctrl+/ 触发，client:idle 等待主线程空闲） -->
    <ShortcutHelp client:idle />

    <script>
      /**
       * Layout 客户端脚本
       *
       * 功能模块：
       * 1. 侧边栏遮罩层联动：监听 body.sidebar-open class 切换 backdrop 显隐
       * 2. 代码块复制按钮：为 <pre><code> 添加复制按钮（Clipboard API + execCommand 降级）
       * 3. Service Worker 注册：PWA 离线支持
       *
       * 兼容 Astro ClientRouter：监听 astro:page-load 事件重新初始化
       */

      /** 初始化侧边栏遮罩层联动 */
      function initSidebarBackdrop(): void {
        const backdrop = document.getElementById('sidebar-backdrop');
        if (!backdrop) return;

        /** 点击遮罩关闭侧边栏 */
        backdrop.addEventListener('click', () => {
          document.body.classList.remove('sidebar-open');
          const sidebar = document.getElementById('app-sidebar');
          sidebar?.classList.add('-translate-x-full');
          backdrop.classList.add('hidden');
        });

        /** 监听 fandex:toggle-sidebar 事件同步显隐 */
        document.addEventListener('fandex:toggle-sidebar', () => {
          requestAnimationFrame(() => {
            if (document.body.classList.contains('sidebar-open')) {
              backdrop.classList.remove('hidden');
            } else {
              backdrop.classList.add('hidden');
            }
          });
        });
      }

      /** 为代码块添加复制按钮 */
      function initCopyButtons(): void {
        document.querySelectorAll('pre > code').forEach((codeEl) => {
          const pre = codeEl.parentElement;
          if (!pre || pre.parentElement?.querySelector('.copy-btn')) return;

          const wrapper = document.createElement('div');
          wrapper.className =
            'code-block group relative my-4 overflow-hidden rounded-lg border border-border bg-muted/30';

          /** 提取代码语言标识（language-xxx 类名） */
          const lang = (codeEl.className.match(/language-(\S+)/) || [])[1] || '';
          if (lang) {
            wrapper.setAttribute('data-lang', lang);
          }

          /** 复制按钮 */
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className =
            'copy-btn absolute right-2 top-2 z-10 inline-flex h-7 w-7 items-center justify-center rounded-md border border-border bg-background/80 text-muted-foreground opacity-0 transition-opacity hover:text-foreground group-hover:opacity-100 focus-visible:opacity-100 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring';
          btn.setAttribute('aria-label', '复制代码');
          btn.innerHTML =
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';

          btn.addEventListener('click', async () => {
            const text = codeEl.textContent || '';
            try {
              await navigator.clipboard.writeText(text);
              btn.classList.add('text-emerald-500');
              btn.innerHTML =
                '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>';
              window.setTimeout(() => {
                btn.classList.remove('text-emerald-500');
                btn.innerHTML =
                  '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
              }, 2000);
            } catch {
              /** Clipboard API 不可用时降级到 execCommand */
              const ta = document.createElement('textarea');
              ta.value = text;
              ta.style.cssText = 'position:fixed;opacity:0';
              document.body.appendChild(ta);
              ta.select();
              document.execCommand('copy');
              document.body.removeChild(ta);
              btn.classList.add('text-emerald-500');
              window.setTimeout(() => btn.classList.remove('text-emerald-500'), 2000);
            }
          });

          /** 包裹代码块并插入复制按钮 */
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);
          wrapper.appendChild(btn);
        });
      }

      /** 注册 Service Worker 支持 PWA 离线访问 */
      function registerServiceWorker(): void {
        if (!('serviceWorker' in navigator)) return;
        const base = import.meta.env.BASE_URL;
        navigator.serviceWorker.register(`${base}sw.js`).catch(() => {
          /* Service Worker 注册失败时静默降级到在线模式 */
        });
      }

      /** 初始化所有模块 */
      function initLayout(): void {
        initSidebarBackdrop();
        initCopyButtons();
      }

      // 首屏初始化 + ClientRouter 跳转后重新初始化
      initLayout();
      registerServiceWorker();
      document.addEventListener('astro:page-load', initLayout);
    </script>
  </body>
</html>
