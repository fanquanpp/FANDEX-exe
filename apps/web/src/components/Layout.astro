---
/**
 * 文档页主布局组件
 * 提供文档页面的整体结构：顶部导航栏、侧边栏、主内容区、移动端底部导航
 * 支持暗色模式切换、全屏模式、侧边栏状态持久化、代码复制、Mermaid 图表渲染等功能
 */
import '@/styles/variables.css';
import '@/styles/global.css';
import '@/styles/typography.css';
import '@/styles/code.css';
import '@/styles/components.css';
import '@/styles/reading-mode.css';
import ThemeToggle from '@/islands/ThemeToggle.vue';
import InstallPrompt from '@/islands/InstallPrompt.vue';
import { SITE } from '@packages/shared/constants';

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
// 检测是否包含侧边栏插槽，用于条件渲染遮罩层和移动端导航按钮
const hasSidebar = Astro.slots.has('sidebar');
---

<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- PWA 配置：Web App Manifest、主题色、应用图标 -->
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <meta name="theme-color" content="#3366cc" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a1a1a" media="(prefers-color-scheme: dark)" />
    <link rel="apple-touch-icon" href={`${base}icons/icon-192.png`} />
    <link rel="icon" type="image/svg+xml" href={`${base}icons/icon.svg`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="FANDEX" />
    <meta name="mobile-web-app-capable" content="yes" />
    <!-- 内容安全策略：限制脚本、样式、字体等资源的加载来源 -->
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; img-src 'self' data:; connect-src 'self'"
    />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- 字体资源预加载 -->
    <link rel="stylesheet" href={`${base}fonts/fonts.css`} />
    <link
      rel="preload"
      href={`${base}fonts/jetbrains-mono-400.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={`${base}fonts/jetbrains-mono-700.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!-- 暗色模式初始化脚本：在页面渲染前读取用户偏好，避免闪烁 -->
    <script is:inline>
      (function () {
        const raw = localStorage.getItem('fandex-theme');
        let isDark = false;
        // 优先使用用户手动设置的主题，否则跟随系统偏好
        if (raw === 'dark' || (!raw && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          isDark = true;
        }
        if (isDark) {
          document.documentElement.setAttribute('data-theme', 'dark');
          document.documentElement.style.colorScheme = 'dark';
        }
      })();
    </script>
    <!-- 阅读模式初始化脚本：在页面渲染前读取用户偏好，避免布局闪烁 -->
    <script is:inline>
      (function () {
        const raw = localStorage.getItem('fandex-reading-mode');
        let mode = 'standard';
        if (raw === 'focus' || raw === 'study') mode = raw;
        if (mode !== 'standard') {
          document.documentElement.setAttribute('data-reading-mode', mode);
          document.documentElement.classList.add('mode-' + mode);
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <!-- 确保页面撑满视口高度，禁止 body 自身滚动（由内部容器控制滚动） -->
    <style is:inline>
      html {
        height: 100%;
      }
      body {
        height: 100vh;
        height: 100dvh;
        overflow: hidden;
      }
    </style>
    <!-- 侧边栏遮罩层：移动端打开侧边栏时显示，点击关闭 -->
    {hasSidebar && <div class="sidebar-backdrop" id="sidebar-backdrop" />}
    <!-- 主布局容器：根据是否有侧边栏添加不同类名 -->
    <div class="app-layout" class:list={{ 'no-sidebar': !hasSidebar }}>
      <!-- 顶部导航栏 -->
      <header class="app-nav">
        <div class="nav-left">
          <a href={base} class="nav-logo">
            <span class="logo-mark"></span>
            <span class="logo-text">{SITE.title}<span class="logo-home-suffix">-Index</span></span>
          </a>
        </div>
        <div class="nav-right">
          <!-- 返回顶部按钮 -->
          <button
            class="nav-back-to-top"
            id="nav-back-to-top"
            aria-label="返回顶部"
            title="返回顶部"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
            >
              <polyline points="18 15 12 9 6 15"></polyline>
            </svg>
            <span class="nav-back-to-top-text">返回顶部</span>
          </button>
          <!-- 主题切换按钮（Vue 交互组件） -->
          <ThemeToggle client:load />
        </div>
      </header>
      <!-- PWA 安装提示组件 -->
      <InstallPrompt client:load />
      <!-- 侧边栏插槽 -->
      <slot name="sidebar" />
      <!-- 主内容区域 -->
      <main class="app-main" id="app-main">
        <slot />
      </main>
    </div>
    <!-- 移动端底部导航栏 -->
    <nav class="mobile-nav">
      <a href={base} class="mobile-nav-link">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
        <span>首页</span>
      </a>
      <a href={`${base}search/`} class="mobile-nav-link">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <span>搜索</span>
      </a>
      <a href={`${base}ai-assistant/`} class="mobile-nav-link">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
        </svg>
        <span>AI</span>
      </a>
      <!-- 模块切换按钮：仅在有侧边栏时显示 -->
      {
        hasSidebar && (
          <button class="mobile-nav-link" id="mobile-sidebar-btn" aria-label="模块">
            <svg
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
              <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
            </svg>
            <span>模块</span>
          </button>
        )
      }
      <!-- 全屏切换按钮 -->
      <button class="mobile-nav-link" id="mobile-fullscreen-btn" aria-label="全屏">
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"
          ></path>
        </svg>
        <span>全屏</span>
      </button>
    </nav>
    <!-- 专注模式底部指示器：仅专注模式下显示，提供退出按钮 -->
    <div class="focus-mode-indicator" id="focus-mode-indicator">
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <line x1="12" y1="8" x2="12" y2="12"></line>
        <line x1="12" y1="16" x2="12.01" y2="16"></line>
      </svg>
      <span>专注模式</span>
      <button class="focus-exit-btn" id="focus-exit-btn" aria-label="退出专注模式">Esc 退出</button>
    </div>
  </body>
</html>

<script>
  // ========== 侧边栏开关逻辑 ==========
  const backdrop = document.getElementById('sidebar-backdrop');
  const toggle = document.getElementById('nav-toggle');
  const mobileBtn = document.getElementById('mobile-sidebar-btn');

  /** 打开侧边栏并同步 URL 参数 */
  function openSidebar() {
    document.body.classList.add('sidebar-open');
    syncSidebarUrl();
  }

  /** 关闭侧边栏并同步 URL 参数 */
  function closeSidebar() {
    document.body.classList.remove('sidebar-open');
    syncSidebarUrl();
  }

  /** 将侧边栏开关状态同步到 URL 查询参数，便于刷新后恢复 */
  function syncSidebarUrl() {
    const params = new URLSearchParams(window.location.search);
    if (document.body.classList.contains('sidebar-open')) {
      params.set('sidebar', '1');
    } else {
      params.delete('sidebar');
    }
    const newSearch = params.toString();
    const newUrl = newSearch
      ? window.location.pathname + '?' + newSearch + window.location.hash
      : window.location.pathname + window.location.hash;
    history.replaceState(null, '', newUrl);
  }

  /** 从 URL 查询参数恢复侧边栏状态 */
  function restoreSidebarFromUrl() {
    const params = new URLSearchParams(window.location.search);
    if (params.get('sidebar') === '1') {
      document.body.classList.add('sidebar-open');
    }
  }

  restoreSidebarFromUrl();

  // 顶部菜单按钮：切换章节视图并打开侧边栏
  if (toggle)
    toggle.addEventListener('click', () => {
      if (document.body.classList.contains('sidebar-open')) {
        closeSidebar();
      } else {
        document.dispatchEvent(new CustomEvent('fandex-switch-chapters'));
        openSidebar();
      }
    });

  // 移动端模块按钮：切换模块视图并打开侧边栏
  if (mobileBtn)
    mobileBtn.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('fandex-switch-modules'));
      openSidebar();
    });

  // 点击遮罩层关闭侧边栏
  if (backdrop) backdrop.addEventListener('click', closeSidebar);

  // ========== 返回顶部按钮 ==========
  const backToTopBtn = document.getElementById('nav-back-to-top');
  const mainEl = document.getElementById('app-main');
  if (backToTopBtn && mainEl) {
    backToTopBtn.addEventListener('click', () => {
      mainEl.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }

  // 页面切换时自动关闭侧边栏
  document.addEventListener('astro:page-load', closeSidebar);

  // ========== 全屏模式切换 ==========
  const fullscreenBtn = document.getElementById('mobile-fullscreen-btn');
  if (fullscreenBtn) {
    fullscreenBtn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(() => {});
      } else {
        document.exitFullscreen().catch(() => {});
      }
    });
    // 监听全屏状态变化，更新按钮文字和持久化状态
    document.addEventListener('fullscreenchange', () => {
      const span = fullscreenBtn.querySelector('span');
      if (document.fullscreenElement) {
        span && (span.textContent = '退出');
        try {
          localStorage.setItem('fandex-fullscreen', 'true');
        } catch {}
      } else {
        span && (span.textContent = '全屏');
        try {
          localStorage.removeItem('fandex-fullscreen');
        } catch {}
      }
    });
    // 恢复全屏状态
    if (localStorage.getItem('fandex-fullscreen') === 'true' && !document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch(() => {});
    }
  }

  // ========== 代码块复制按钮 ==========
  function initCopyButtons() {
    document.querySelectorAll('pre > code').forEach((codeEl) => {
      const pre = codeEl.parentElement;
      if (!pre || pre.querySelector('.copy-btn')) return;

      const wrapper = document.createElement('div');
      wrapper.className = 'code-block';

      // 提取代码语言标识
      const lang = (codeEl.className.match(/language-(\S+)/) || [])[1] || '';
      if (lang) wrapper.setAttribute('data-lang', lang);

      const btn = document.createElement('button');
      btn.className = 'copy-btn';
      btn.setAttribute('aria-label', 'Copy code');
      btn.innerHTML =
        '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';

      btn.addEventListener('click', async () => {
        const text = codeEl.textContent || '';
        try {
          // 优先使用 Clipboard API 复制
          await navigator.clipboard.writeText(text);
          btn.classList.add('copied');
          btn.innerHTML =
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>';
          setTimeout(() => {
            btn.classList.remove('copied');
            btn.innerHTML =
              '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
          }, 2000);
        } catch {
          // Clipboard API 不可用时回退到 execCommand
          const ta = document.createElement('textarea');
          ta.value = text;
          ta.style.cssText = 'position:fixed;opacity:0';
          document.body.appendChild(ta);
          ta.select();
          document.execCommand('copy');
          document.body.removeChild(ta);
          btn.classList.add('copied');
          setTimeout(() => btn.classList.remove('copied'), 2000);
        }
      });

      // 将代码块包裹在容器中，并添加复制按钮
      pre.parentNode!.insertBefore(wrapper, pre);
      wrapper.appendChild(pre);
      wrapper.appendChild(btn);
    });
  }

  document.addEventListener('astro:page-load', initCopyButtons);
  initCopyButtons();

  // ========== 术语提示气泡 ==========
  async function initTermTooltip() {
    try {
      const { initTermTooltip: init } = await import('@packages/search/term-tooltip');
      init();
    } catch {
      /* ignore */
    }
  }

  // ========== 微交互动画 ==========
  async function initAnimations() {
    try {
      const { setupMicroInteractions } = await import('@/lib/animations');
      setupMicroInteractions();
    } catch {
      /* ignore */
    }
  }

  // ========== 代码运行器 ==========
  async function initCodeRunners() {
    try {
      const { initCodeRunners: init } = await import('@/lib/code-runner');
      init();
    } catch {
      /* ignore */
    }
  }

  // 注册各功能模块的页面加载回调
  document.addEventListener('astro:page-load', initTermTooltip);
  document.addEventListener('astro:page-load', initAnimations);
  document.addEventListener('astro:page-load', initCodeRunners);
  initTermTooltip();
  initAnimations();
  initCodeRunners();

  // 注册 Service Worker 以支持离线访问
  if ('serviceWorker' in navigator) {
    const base = import.meta.env.BASE_URL;
    navigator.serviceWorker.register(base + 'sw.js').catch(() => {});
  }

  // 快捷键 Ctrl/Cmd + K 跳转到搜索页
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      const base = document.querySelector('a.nav-logo')?.getAttribute('href') || '/';
      window.location.href = base + 'search/';
    }
  });

  // ========== 阅读模式初始化 ==========
  async function initReadingMode() {
    try {
      const { initReadingMode: init } = await import('@/lib/reading-mode');
      init();
    } catch {
      /* ignore */
    }
  }

  // 页面加载时初始化阅读模式
  initReadingMode();
  document.addEventListener('astro:page-load', initReadingMode);

  // ========== 阅读模式快捷键 ==========
  document.addEventListener('keydown', (e) => {
    // 获取当前焦点元素，避免在输入框中触发快捷键
    const target = e.target as HTMLElement;
    const isInputField =
      target.tagName === 'INPUT' || target.tagName === 'TEXTAREA' || target.isContentEditable;

    // F 键切换专注模式（非输入框时生效）
    if (e.key === 'f' && !e.ctrlKey && !e.metaKey && !e.altKey && !isInputField) {
      e.preventDefault();
      import('@/lib/reading-mode')
        .then(({ toggleFocusMode }) => {
          toggleFocusMode();
        })
        .catch(() => {});
    }

    // Esc 键退出专注/学习模式
    if (e.key === 'Escape') {
      import('@/lib/reading-mode')
        .then(({ getReadingMode, setReadingMode }) => {
          const current = getReadingMode();
          if (current !== 'standard') {
            setReadingMode('standard');
          }
        })
        .catch(() => {});
    }
  });

  // ========== 专注模式底部指示器退出按钮 ==========
  const focusExitBtn = document.getElementById('focus-exit-btn');
  if (focusExitBtn) {
    focusExitBtn.addEventListener('click', () => {
      import('@/lib/reading-mode')
        .then(({ setReadingMode }) => {
          setReadingMode('standard');
        })
        .catch(() => {});
    });
  }
</script>

<style>
  /* 侧边栏遮罩层：移动端打开侧边栏时显示半透明背景 */
  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    top: var(--nav-height);
    background: rgba(0, 0, 0, 0.3);
    z-index: 150;
  }
  body.sidebar-open .sidebar-backdrop {
    display: block;
  }

  /* 菜单切换按钮：默认隐藏，移动端显示 */
  .nav-toggle {
    display: none;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }
  }
</style>
