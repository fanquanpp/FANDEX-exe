---
/**
 * MobileNavBar 移动端底部导航栏组件
 *
 * 功能概述：
 * - 移动端（< md 768px）固定底部导航栏，提供 5 个高频操作入口
 * - 5 个按钮：返回顶部 / 上一篇 / 下一篇 / 分享 / 目录大纲
 * - safe-area-inset-bottom 适配 iPhone 等设备底部安全区
 * - 仅在传入对应回调或文档上下文时显示对应按钮（缺省则隐藏）
 * - 完整无障碍：nav[aria-label="底部导航"]、aria-label、键盘可达
 * - 基于 Tailwind v4 工具类实现样式
 *
 * Props:
 *   showToc     - 是否显示目录按钮（文档页有 Toc 时为 true）
 *   showPrevNext - 是否显示上一篇/下一篇按钮（文档页为 true）
 *
 * 注：具体导航逻辑通过事件委托触发，由 Layout 监听并处理
 */
interface Props {
  showToc?: boolean;
  showPrevNext?: boolean;
}

const { showToc = false, showPrevNext = false } = Astro.props;
---

<nav
  aria-label="底部导航"
  class="fixed inset-x-0 bottom-0 z-40 flex h-14 items-stretch border-t border-border bg-background/95 backdrop-blur-md md:hidden"
  style="padding-bottom: env(safe-area-inset-bottom);"
>
  <!-- 返回顶部 -->
  <button
    type="button"
    id="mobile-back-to-top"
    class="flex flex-1 flex-col items-center justify-center gap-0.5 text-[10px] text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
    aria-label="返回顶部"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <line x1="12" y1="19" x2="12" y2="5" />
      <polyline points="5 12 12 5 19 12" />
    </svg>
    <span>顶部</span>
  </button>

  {
    showPrevNext && (
      <>
        <!-- 上一篇 -->
        <button
          type="button"
          id="mobile-prev-doc"
          class="flex flex-1 flex-col items-center justify-center gap-0.5 text-[10px] text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          aria-label="上一篇文档"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="15 18 9 12 15 6" />
          </svg>
          <span>上一篇</span>
        </button>

        <!-- 下一篇 -->
        <button
          type="button"
          id="mobile-next-doc"
          class="flex flex-1 flex-col items-center justify-center gap-0.5 text-[10px] text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
          aria-label="下一篇文档"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <polyline points="9 18 15 12 9 6" />
          </svg>
          <span>下一篇</span>
        </button>
      </>
    )
  }

  {
    showToc && (
      <button
        type="button"
        id="mobile-toc"
        class="flex flex-1 flex-col items-center justify-center gap-0.5 text-[10px] text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
        aria-label="打开目录大纲"
        aria-haspopup="dialog"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <line x1="8" y1="6" x2="21" y2="6" />
          <line x1="8" y1="12" x2="21" y2="12" />
          <line x1="8" y1="18" x2="21" y2="18" />
          <line x1="3" y1="6" x2="3.01" y2="6" />
          <line x1="3" y1="12" x2="3.01" y2="12" />
          <line x1="3" y1="18" x2="3.01" y2="18" />
        </svg>
        <span>目录</span>
      </button>
    )
  }

  <!-- 分享按钮 -->
  <button
    type="button"
    id="mobile-share"
    class="flex flex-1 flex-col items-center justify-center gap-0.5 text-[10px] text-muted-foreground transition-colors hover:bg-accent hover:text-foreground"
    aria-label="分享当前页面"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="18" cy="5" r="3" />
      <circle cx="6" cy="12" r="3" />
      <circle cx="18" cy="19" r="3" />
      <line x1="8.59" y1="13.51" x2="15.42" y2="17.49" />
      <line x1="15.41" y1="6.51" x2="8.59" y2="10.49" />
    </svg>
    <span>分享</span>
  </button>
</nav>

<script>
  /**
   * 移动端底部导航交互逻辑
   *
   * 实现说明：
   * - 返回顶部：滚动主内容区到顶部
   * - 上一篇/下一篇：派发自定义事件，由文档页脚本监听跳转
   * - 目录：派发自定义事件，由 Layout 弹出移动端目录 Sheet
   * - 分享：调用 Web Share API，不支持时复制 URL 到剪贴板
   * - 兼容 View Transitions：监听 astro:page-load 重新绑定
   */
  function initMobileNavBar(): void {
    /** 返回顶部 */
    const backToTop = document.getElementById('mobile-back-to-top');
    backToTop?.addEventListener('click', () => {
      const main = document.getElementById('app-main');
      if (main) {
        main.scrollTo({ top: 0, behavior: 'smooth' });
      } else {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      }
    });

    /** 上一篇：派发自定义事件，由 DocNav 或文档页脚本处理 */
    document.getElementById('mobile-prev-doc')?.addEventListener('click', () => {
      const prevLink = document.querySelector<HTMLAnchorElement>('a[rel="prev"]');
      if (prevLink?.href) {
        window.location.href = prevLink.href;
      }
    });

    /** 下一篇：派发自定义事件 */
    document.getElementById('mobile-next-doc')?.addEventListener('click', () => {
      const nextLink = document.querySelector<HTMLAnchorElement>('a[rel="next"]');
      if (nextLink?.href) {
        window.location.href = nextLink.href;
      }
    });

    /** 目录：派发 'fandex:open-mobile-toc' 自定义事件，由 Layout 监听 */
    document.getElementById('mobile-toc')?.addEventListener('click', () => {
      document.dispatchEvent(new CustomEvent('fandex:open-mobile-toc'));
    });

    /** 分享：Web Share API + 剪贴板降级 */
    document.getElementById('mobile-share')?.addEventListener('click', async () => {
      const shareData = {
        title: document.title,
        url: window.location.href,
      };

      if (navigator.share) {
        try {
          await navigator.share(shareData);
        } catch {
          /* 用户取消分享时静默忽略 */
        }
        return;
      }

      // 降级：复制 URL 到剪贴板
      try {
        await navigator.clipboard.writeText(window.location.href);
        // 简单的视觉反馈：按钮文字临时改变
        const btn = document.getElementById('mobile-share');
        const span = btn?.querySelector('span');
        if (span) {
          const original = span.textContent;
          span.textContent = '已复制';
          window.setTimeout(() => {
            span.textContent = original;
          }, 1500);
        }
      } catch {
        /* 剪贴板不可用时静默忽略 */
      }
    });
  }

  initMobileNavBar();
  document.addEventListener('astro:page-load', initMobileNavBar);
</script>
