---
/**
 * RelatedDocs 相关文档组件
 *
 * 功能概述：
 * - 在文档末尾展示相关文档网格，帮助用户横向探索
 * - 1/2/3 列响应式布局（mobile / tablet / desktop）
 * - 数据源：文档 frontmatter 的 `related` 字段（slug 数组）
 * - 通过 getCollection 查询匹配的文档元数据
 * - 无相关文档时不渲染（不输出空容器）
 * - 基于 Tailwind v4 工具类实现样式
 *
 * Props:
 *   currentModule - 当前模块 ID（用于在模块内查找文档）
 *   relatedSlugs  - 相关文档 slug 数组（来自 frontmatter.related）
 *   title         - 区块标题（默认"相关文档"）
 */
import { type CollectionEntry, getCollection } from 'astro:content';
import { withBase } from '@/lib/url';

interface Props {
  currentModule: string;
  relatedSlugs: readonly string[];
  title?: string;
}

const { currentModule, relatedSlugs, title = '相关文档' } = Astro.props;

/** 仅在传入非空数组时才查询，避免无谓的集合遍历 */
const hasRelated = relatedSlugs.length > 0;

/** 查询当前模块下所有文档，过滤出 slug 匹配的相关文档 */
const relatedDocs: CollectionEntry<'docs'>[] = hasRelated
  ? (await getCollection('docs', ({ data }) => data.module === currentModule)).filter((doc) => {
      const slug =
        doc.id
          .split('/')
          .pop()
          ?.replace(/\.(md|mdx)$/, '') ?? '';
      return relatedSlugs.includes(slug);
    })
  : [];

/** 构建文档链接（withBase 兼容 Tauri/Web） */
function docHref(doc: CollectionEntry<'docs'>): string {
  const slug =
    doc.id
      .split('/')
      .pop()
      ?.replace(/\.(md|mdx)$/, '') ?? '';
  return withBase(`/${currentModule}/${slug}/`);
}
---

{
  relatedDocs.length > 0 && (
    <section class="mt-12" aria-labelledby="related-docs-heading">
      <h2
        id="related-docs-heading"
        class="mb-4 text-base font-semibold text-foreground"
      >
        {title}
      </h2>
      <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {relatedDocs.map((doc) => (
          <li>
            <a
              href={docHref(doc)}
              class="group flex h-full flex-col gap-1.5 rounded-lg border border-border bg-card p-4 transition-all duration-200 hover:-translate-y-0.5 hover:border-primary/40 hover:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
            >
              <div class="flex items-start justify-between gap-2">
                <h3 class="line-clamp-2 text-sm font-medium text-foreground">
                  {doc.data.title}
                </h3>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="h-4 w-4 flex-shrink-0 text-muted-foreground transition-transform group-hover:translate-x-0.5 group-hover:text-primary"
                  aria-hidden="true"
                >
                  <line x1="7" y1="17" x2="17" y2="7" />
                  <polyline points="7 7 17 7 17 17" />
                </svg>
              </div>
              {doc.data.description && (
                <p class="line-clamp-2 text-xs text-muted-foreground">
                  {doc.data.description}
                </p>
              )}
              {doc.data.tags && doc.data.tags.length > 0 && (
                <ul class="mt-auto flex flex-wrap gap-1 pt-2">
                  {doc.data.tags.slice(0, 3).map((tag) => (
                    <li class="rounded-md bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                      #{tag}
                    </li>
                  ))}
                </ul>
              )}
            </a>
          </li>
        ))}
      </ul>
    </section>
  )
}
