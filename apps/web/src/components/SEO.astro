---
/**
 * SEO 组件 - 社交分享与结构化数据
 *
 * 功能概述：
 * - 输出 Open Graph / Twitter Card 元数据，提升社交平台分享体验
 * - 输出 JSON-LD 结构化数据（Article / WebSite / BreadcrumbList），增强搜索引擎理解
 * - 根据 type 切换 Article / WebSite schema
 * - 与 BaseHead 互补：BaseHead 负责 title/description/canonical 等基础元信息
 *   本组件专注于社交图谱与结构化数据
 *
 * Props:
 *   title          - 页面标题（不含站点后缀）
 *   description    - 页面描述
 *   image          - 社交分享图（绝对或相对 URL）
 *   type           - 页面类型（article / website，默认 website）
 *   publishedTime  - 文章发布时间（ISO 8601 字符串，仅 article 类型使用）
 *   modifiedTime   - 文章修改时间（ISO 8601 字符串，仅 article 类型使用）
 *   author         - 文章作者
 *   tags           - 文章标签数组
 *   module         - 所属模块名（用于 Article schema 的 articleSection）
 *   canonical      - 规范链接
 *   breadcrumbs    - 面包屑层级数组，用于 BreadcrumbList JSON-LD
 */
import { SITE } from '@/lib/constants';

/** 面包屑条目（与 Breadcrumb.astro 共用结构） */
export interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: readonly string[];
  module?: string;
  canonical?: string;
  breadcrumbs?: readonly BreadcrumbItem[];
}

const {
  title,
  description = SITE.description,
  image,
  type = 'website',
  publishedTime,
  modifiedTime,
  author = SITE.author,
  tags,
  module,
  canonical,
  breadcrumbs,
} = Astro.props;

/** Astro 基础路径 */
const base = import.meta.env.BASE_URL;

/** 完整页面标题（带站点名后缀） */
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.name}`;

/** 规范链接（如未提供则基于当前 URL 与站点 URL 拼接） */
const canonicalUrl = canonical || new URL(Astro.url.pathname, SITE.url).toString();

/** 社交分享图片（默认站点 512 图标） */
const imageUrl = image || new URL(`${base}icons/icon-512.png`, SITE.url).toString();

/** 站点 Logo（用于 JSON-LD publisher.logo） */
const logoUrl = new URL(`${base}icons/icon-512.png`, SITE.url).toString();

/**
 * JSON-LD Publisher（Organization）
 * 在 Article 与 WebSite schema 中复用
 */
const publisher = {
  '@type': 'Organization',
  name: SITE.name,
  url: SITE.url,
  logo: {
    '@type': 'ImageObject',
    url: logoUrl,
  },
} as const;

/**
 * JSON-LD Author（Person）
 * 默认使用 SITE.author
 */
const authorSchema = {
  '@type': 'Person',
  name: author,
  url: SITE.url,
} as const;

/**
 * 根据 type 生成主 schema
 * - article: Article schema，包含 headline / datePublished / dateModified / author / image
 * - website: WebSite schema，包含 name / url / description
 */
const mainSchema =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description,
        image: imageUrl,
        url: canonicalUrl,
        datePublished: publishedTime,
        dateModified: modifiedTime || publishedTime,
        author: authorSchema,
        publisher,
        ...(module ? { articleSection: module } : {}),
        ...(tags && tags.length > 0 ? { keywords: tags.join(', ') } : {}),
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': canonicalUrl,
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE.name,
        alternateName: SITE.title,
        url: SITE.url,
        description: SITE.description,
        publisher,
        potentialAction: {
          '@type': 'SearchAction',
          target: {
            '@type': 'EntryPoint',
            urlTemplate: new URL(`${base}search/?q={search_term_string}`, SITE.url).toString(),
          },
          'query-input': 'required name=search_term_string',
        },
      };

/**
 * BreadcrumbList JSON-LD
 * 仅当传入 breadcrumbs 时输出，提升搜索引擎对站点层级的理解
 */
const breadcrumbSchema =
  breadcrumbs && breadcrumbs.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: breadcrumbs.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.label,
          ...(item.href ? { item: new URL(item.href, SITE.url).toString() } : {}),
        })),
      }
    : null;
---

<!-- Open Graph 元数据 -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={description} />
<meta property="og:type" content={type === 'article' ? 'article' : 'website'} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={imageUrl} />
<meta property="og:site_name" content={SITE.name} />
<meta property="og:locale" content={SITE.locale.replace('-', '_')} />
{type === 'article' && publishedTime && (
  <meta property="article:published_time" content={publishedTime} />
)}
{type === 'article' && modifiedTime && (
  <meta property="article:modified_time" content={modifiedTime} />
)}
{type === 'article' && author && <meta property="article:author" content={author} />}
{type === 'article' && module && <meta property="article:section" content={module} />}
{type === 'article' && tags && tags.map((tag) => <meta property="article:tag" content={tag} />)}

<!-- Twitter Card 元数据 -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={fullTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={imageUrl} />
<meta name="twitter:site" content="@fanquanpp" />
<meta name="twitter:creator" content="@fanquanpp" />

<!-- 结构化数据：Article / WebSite -->
<script type="application/ld+json" set:html={JSON.stringify(mainSchema)} />

<!-- 结构化数据：BreadcrumbList -->
{breadcrumbSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
)}
