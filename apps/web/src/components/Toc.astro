---
/**
 * Toc 目录大纲组件（Table of Contents）
 *
 * 功能概述：
 * - 在文档右侧显示当前页面的标题大纲（h2 / h3）
 * - sticky 定位，跟随滚动保持在视口内（top-20 避让 Header）
 * - IntersectionObserver 监听主内容区标题可见性，高亮当前章节
 * - 点击大纲项平滑滚动到对应标题
 * - 仅在传入标题数量 >= 3 时显示（避免短文档出现冗余大纲）
 * - 完整无障碍：nav[aria-label]、aria-current="location"
 * - 基于 Tailwind v4 工具类实现样式
 *
 * Props:
 *   headings - 标题数组（来自 Astro 执行 getHeadings() / Markdown headings）
 *              字段：{ depth: number; slug: string; text: string }
 *   maxDepth - 显示的最大标题深度（默认 3，即 h2 与 h3）
 */
interface TocHeading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: readonly TocHeading[];
  maxDepth?: number;
}

const { headings, maxDepth = 3 } = Astro.props;

/** 过滤可见标题：depth 在 [2, maxDepth] 区间 */
const visibleHeadings = headings.filter((h) => h.depth >= 2 && h.depth <= maxDepth);

/** 是否显示大纲（标题数 >= 3 才显示） */
const shouldRender = visibleHeadings.length >= 3;
---

{
  shouldRender && (
    <aside
      class="hidden w-56 flex-shrink-0 lg:block xl:w-64"
      aria-label="本页目录"
    >
      <nav
        id="toc-nav"
        class="sticky top-20 max-h-[calc(100vh-6rem)] overflow-y-auto pb-8"
      >
        <h2 class="mb-3 text-xs font-semibold uppercase tracking-wide text-muted-foreground">
          本页目录
        </h2>
        <ul class="space-y-0.5 text-sm">
          {visibleHeadings.map((h) => (
            <li
              class="min-w-0"
              style={h.depth === 3 ? 'padding-left:0.75rem' : ''}
            >
              <a
                href={`#${h.slug}`}
                data-toc-slug={h.slug}
                class="toc-link block truncate border-l-2 border-transparent py-1 pl-3 -ml-px text-muted-foreground transition-colors hover:text-foreground"
              >
                {h.text}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </aside>
  )
}

<style is:global>
  /**
   * 当前章节高亮样式（由 JS 在 IntersectionObserver 回调中切换）
   * - 左侧色条显示
   * - 文字颜色变为主色
   * - 字重加粗
   */
  .toc-link.is-active {
    border-left-color: var(--primary);
    color: var(--primary);
    font-weight: 500;
  }
</style>

<script>
  /**
   * 目录大纲滚动监听与高亮逻辑
   *
   * 实现说明：
   * - 通过 IntersectionObserver 监听主内容区标题进入视口
   * - 当标题进入视口底部 60% 区域时，标记为当前章节
   * - 同步高亮对应的大纲链接（添加 is-active 类）
   * - 点击大纲项时阻止默认跳转，改为平滑滚动到标题位置
   * - 兼容 View Transitions：监听 astro:page-load 事件重新初始化
   */
  function initTocHighlight(): void {
    const tocLinks = document.querySelectorAll<HTMLAnchorElement>('a[data-toc-slug]');
    if (tocLinks.length === 0) return;

    /** 主内容区滚动容器（用于 IntersectionObserver root） */
    const mainEl = document.getElementById('app-main') || document.documentElement;

    /** 收集对应的标题 DOM */
    const headingElements: HTMLElement[] = [];
    tocLinks.forEach((link) => {
      const slug = link.getAttribute('data-toc-slug');
      if (!slug) return;
      const target = document.getElementById(slug);
      if (target) headingElements.push(target);
    });

    if (headingElements.length === 0) return;

    /** 当前激活的 slug */
    let activeSlug = '';

    /** 高亮指定 slug 对应的大纲链接，移除其他链接的高亮 */
    function highlightActive(slug: string): void {
      if (slug === activeSlug) return;
      activeSlug = slug;
      tocLinks.forEach((link) => {
        const linkSlug = link.getAttribute('data-toc-slug');
        if (linkSlug === slug) {
          link.classList.add('is-active');
          link.setAttribute('aria-current', 'location');
        } else {
          link.classList.remove('is-active');
          link.removeAttribute('aria-current');
        }
      });
    }

    /** 点击大纲项时平滑滚动到标题 */
    tocLinks.forEach((link) => {
      link.addEventListener('click', (event) => {
        const slug = link.getAttribute('data-toc-slug');
        if (!slug) return;
        const target = document.getElementById(slug);
        if (!target) return;

        event.preventDefault();
        const mainRect = mainEl.getBoundingClientRect();
        const targetRect = target.getBoundingClientRect();
        const offset = targetRect.top - mainRect.top + mainEl.scrollTop - 80;

        mainEl.scrollTo({ top: offset, behavior: 'smooth' });
        // 同步更新 URL hash（不触发滚动）
        history.replaceState(null, '', `#${slug}`);
      });
    });

    /** IntersectionObserver：监听标题可见性 */
    const observer = new IntersectionObserver(
      (entries) => {
        // 找到当前最靠近视口顶部且可见的标题
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);

        if (visible.length > 0) {
          const target = visible[0];
          if (target.target.id) {
            highlightActive(target.target.id);
          }
        }
      },
      {
        root: mainEl === document.documentElement ? null : mainEl,
        rootMargin: '0px 0px -60% 0px',
        threshold: 0,
      },
    );

    headingElements.forEach((el) => observer.observe(el));
  }

  // 初始化（首屏与 View Transitions 跳转后均触发）
  initTocHighlight();
  document.addEventListener('astro:page-load', initTocHighlight);
</script>
