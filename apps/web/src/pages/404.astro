---
/**
 * 404.astro 错误页（Phase 8a 重写版）
 *
 * 功能概述：
 * - 大号 404 数字 + 友好提示文案
 * - 推荐模块网格：使用 ModuleCard 组件渲染 6 个模块作为快速跳转入口
 * - 返回首页按钮 + 搜索提示（Ctrl+K）
 * - 完全移除 Vue 与旧版 @fandex/shared 依赖
 * - Tailwind v4 工具类实现布局
 * - Tauri 兼容：ModuleCard 内部已通过 withBase() 处理路径
 *
 * SEO 策略：
 * - noindex=true 防止 404 页被搜索引擎收录
 *
 * 数据源：
 * - MODULES：取前 6 个作为推荐（按 modules.json 中的顺序，覆盖入门/工具/前端核心模块）
 */
import HomeLayout from '@/components/HomeLayout.astro';
import ModuleCard from '@/components/ModuleCard.astro';
import SEO from '@/components/SEO.astro';
import { MODULES } from '@/lib/modules';
import { withBase } from '@/lib/url';

/** 取前 6 个模块作为推荐跳转 */
const recommendedModules = MODULES.slice(0, 6);

/** 面包屑层级（用于 SEO 结构化数据） */
const breadcrumbs = [{ label: '首页', href: '/' }, { label: '页面未找到' }] as const;
---

<HomeLayout title="404 - 页面未找到 - FANDEX" description="您访问的页面不存在或已被移动" noindex={true}>
  <SEO
    slot="head"
    title="404 - 页面未找到 - FANDEX"
    description="您访问的页面不存在或已被移动。请尝试搜索或浏览推荐模块。"
    type="website"
    breadcrumbs={breadcrumbs}
  />

  <section class="mx-auto flex min-h-[calc(100vh-3.5rem)] w-full max-w-5xl flex-col items-center justify-center gap-8 px-4 py-12 md:px-6 md:py-16">
    <!-- 错误码 + 提示文案 -->
    <div class="flex flex-col items-center gap-3 text-center">
      <h1
        class="select-none text-[8rem] font-bold leading-none tracking-tighter text-primary/20 md:text-[12rem]"
        aria-hidden="true"
      >
        404
      </h1>
      <h2 class="text-xl font-semibold tracking-tight md:text-2xl">页面未找到</h2>
      <p class="max-w-md text-sm text-muted-foreground md:text-base">
        您访问的页面不存在或已被移动。可以尝试搜索，或浏览下方推荐模块继续学习。
      </p>

      <!-- 操作按钮 -->
      <div class="mt-2 flex flex-wrap items-center justify-center gap-2">
        <a
          href={withBase('/')}
          class="inline-flex items-center gap-1.5 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow-sm transition-opacity hover:opacity-90"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
            <polyline points="9 22 9 12 15 12 15 22" />
          </svg>
          返回首页
        </a>
        <span class="inline-flex items-center gap-1 text-xs text-muted-foreground">
          或按
          <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[11px] font-medium text-foreground">Ctrl</kbd>
          +
          <kbd class="rounded border border-border bg-muted px-1.5 py-0.5 font-mono text-[11px] font-medium text-foreground">K</kbd>
          搜索
        </span>
      </div>
    </div>

    <!-- 推荐模块网格（使用 ModuleCard 组件） -->
    <div class="w-full space-y-3">
      <div class="flex items-center justify-between gap-2">
        <h3 class="text-sm font-semibold text-muted-foreground">推荐模块</h3>
        <a
          href={withBase('/roadmap/')}
          class="text-xs text-primary transition-opacity hover:opacity-80"
        >
          查看全部 →
        </a>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {recommendedModules.map((mod) => (
          <ModuleCard mod={mod} />
        ))}
      </div>
    </div>
  </section>
</HomeLayout>
