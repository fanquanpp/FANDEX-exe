---
import { type CollectionEntry, getCollection } from 'astro:content';
import Breadcrumb from '@/components/Breadcrumb.astro';
/**
 * 模块知识地图路由（Phase 8b 重写）
 *
 * 功能概述：
 * - 动态路由 [module]/map，为每个模块生成知识地图页面
 * - 顶部页面头部：模块名 + 类别 Badge + 文档数 + 描述
 * - MermaidLazy 岛屿：根据模块文档 prerequisites 生成 graph TD 字符串，渲染文档依赖关系
 * - 图例说明：已读 / 在读 / 未读 三种状态颜色含义
 * - 文档列表表格：文档名、前置依赖、状态、阅读时间
 * - 客户端脚本：从 localStorage 读取进度，更新表格状态指示器颜色
 *
 * 数据源：
 * - modules: @/lib/modules 的 MODULES / getModule / MODULE_CATEGORIES
 * - docs: astro:content 的 getCollection('docs')，按 module 过滤
 * - 路径处理：withBase() 兼容 Tauri/Web 双环境
 *
 * 岛屿水合：
 * - MermaidLazy: client:visible（视口可见时水合，初始显示源码占位 + 渲染按钮）
 *
 * Skill 偏差报备：
 * 旧版引用 @fandex/shared 与 @fandex/markdown 已废弃，改用 @/lib/modules。
 * 旧版使用 hsl(var(--card)) 等旧 CSS 变量，本版改为 Tailwind v4 工具类与 bg-card/border-border 等语义类。
 * 旧版构建时调用 renderMermaidDualTheme 预渲染 SVG，本版改为 MermaidLazy 岛屿客户端懒加载，
 * 减少构建时依赖与 SSR 包体积，与 Phase 8b 岛屿架构统一。
 */
import Layout from '@/components/Layout.astro';
import SEO from '@/components/SEO.astro';
import Sidebar from '@/components/Sidebar.astro';
import MermaidLazy from '@/islands/MermaidLazy';
import { getModule, MODULE_CATEGORIES, MODULES } from '@/lib/modules';
import { withBase } from '@/lib/url';

/**
 * 生成静态路径：为每个模块生成一个知识地图页面
 *
 * 实现说明：
 * - 从 MODULES 静态注册表生成 51 个路径
 * - params.module 取模块 ID（单段 slug，如 `javascript`）
 */
export async function getStaticPaths() {
  return MODULES.map((m) => ({ params: { module: m.id } }));
}

/** 路由参数：当前模块 ID */
const { module } = Astro.params as { module: string };
const meta = getModule(module);

/** 模块不存在时跳转 404 */
if (!meta) {
  return Astro.redirect(withBase('/404'));
}

/** 获取该模块下所有文档，按 order 升序排列 */
const docs = await getCollection('docs', ({ data }) => data.module === module);
const sortedDocs: CollectionEntry<'docs'>[] = docs.sort(
  (a, b) => (a.data.order || 0) - (b.data.order || 0),
);

/**
 * 从文档 ID 中提取 slug
 *
 * @param id - 文档 ID（如 `javascript/概述`）
 * @returns slug（如 `概述`）
 */
function slug(id: string): string {
  return (id.split('/').pop() || id).replace(/\.(md|mdx)$/, '');
}

/**
 * 文档 ID 短名（用于 Mermaid 节点显示）
 *
 * 实现说明：
 * - 取 slug 末段
 * - 移除文件扩展名
 * - 截断超长名（避免 Mermaid 节点过宽）
 *
 * @param id - 文档 ID
 * @returns 短名（最长 20 字符）
 */
function shortName(id: string): string {
  const s = slug(id);
  return s.length > 20 ? `${s.slice(0, 18)}…` : s;
}

/**
 * 构建 Mermaid graph TD 字符串
 *
 * 实现说明：
 * - 节点 ID 使用文档索引（doc_0、doc_1...）避免中文 / 特殊字符破坏语法
 * - 节点 label 使用 shortName()
 * - 边表示 prerequisites 依赖关系（A 依赖 B → B --> A，即先学 B 再学 A）
 * - 仅渲染该模块内文档间的依赖关系（跨模块依赖不展示）
 *
 * @returns Mermaid 源码字符串
 */
function buildMermaidGraph(): string {
  const lines: string[] = ['graph TD'];

  // 节点定义（使用方括号语法，含 shortName）
  sortedDocs.forEach((doc, idx) => {
    const label = shortName(doc.id).replace(/[[\]]/g, '');
    lines.push(`  doc_${idx}["${label}"]`);
  });

  // 依赖边：遍历每篇文档的 prerequisites，匹配同模块内文档
  const slugToIdx = new Map<string, number>();
  sortedDocs.forEach((doc, idx) => {
    slugToIdx.set(slug(doc.id), idx);
  });

  sortedDocs.forEach((doc, idx) => {
    const prereqs = doc.data.prerequisites || [];
    prereqs.forEach((prereq) => {
      // prereq 可能是 slug 形式或文档 ID 形式
      const prereqSlug = (prereq.split('/').pop() || prereq).replace(/\.(md|mdx)$/, '');
      const prereqIdx = slugToIdx.get(prereqSlug);
      if (prereqIdx !== undefined && prereqIdx !== idx) {
        // 前置 --> 当前（学习顺序：先 prereq 后当前）
        lines.push(`  doc_${prereqIdx} --> doc_${idx}`);
      }
    });
  });

  // 样式定义：节点默认样式
  lines.push('  classDef default fill:bg-card,stroke:border,color:foreground;');

  return lines.join('\n');
}

/** Mermaid 图表源码 */
const mermaidGraph = buildMermaidGraph();

/** Mermaid 图表唯一 ID（用于 SVG 选择器） */
const mermaidId = `map-mermaid-${module}`;

/** 难度标签文案映射 */
const difficultyLabel: Record<'beginner' | 'intermediate' | 'advanced', string> = {
  beginner: '入门',
  intermediate: '进阶',
  advanced: '高级',
};

/** 难度标签样式（Tailwind 类名） */
const difficultyClass: Record<'beginner' | 'intermediate' | 'advanced', string> = {
  beginner: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-950/60 dark:text-emerald-300',
  intermediate: 'bg-amber-100 text-amber-700 dark:bg-amber-950/60 dark:text-amber-300',
  advanced: 'bg-rose-100 text-rose-700 dark:bg-rose-950/60 dark:text-rose-300',
};

/** 当前模块所属分类元数据（用于面包屑） */
const categoryMeta = MODULE_CATEGORIES.find((c) => c.id === meta.category);

/** 面包屑导航项 */
const breadcrumb = [
  { label: '首页', href: withBase('/') },
  ...(categoryMeta ? [{ label: categoryMeta.name, href: withBase(`/#${categoryMeta.id}`) }] : []),
  { label: meta.name, href: withBase(`/${module}/`) },
  { label: '知识地图' },
];

/** SEO 面包屑（用于结构化数据） */
const seoBreadcrumbs = [
  { label: '首页', href: '/' },
  ...(categoryMeta ? [{ label: categoryMeta.name, href: `/#${categoryMeta.id}` }] : []),
  { label: meta.name, href: `/${module}/` },
  { label: '知识地图', href: `/${module}/map/` },
];

/** 文档状态指示器类名映射（与表格 status 列对应） */
const statusDotClass: Record<string, string> = {
  read: 'bg-emerald-500',
  reading: 'bg-amber-500',
  unread: 'bg-muted-foreground/40',
};

/** Mermaid 图表是否为空（无文档时不渲染） */
const hasMermaid = sortedDocs.length > 0;
---

<Layout
  title={`知识地图 - ${meta.name} - FANDEX`}
  description={`${meta.name} 模块知识结构与学习路径地图`}
  canonical={withBase(`/${module}/map/`)}
  hasSidebar
>
  <SEO
    slot="head"
    title={`知识地图 - ${meta.name} - FANDEX`}
    description={`${meta.name} 模块知识结构与学习路径地图`}
    type="article"
    breadcrumbs={seoBreadcrumbs}
  />
  <Sidebar slot="sidebar" moduleId={module} sortedDocs={sortedDocs} />

  <div class="flex flex-col gap-6 pb-12">
    {/* 面包屑导航 */}
    <Breadcrumb items={breadcrumb} hasSidebar />

    {/* ============================================================
     * 页面头部：模块名 + 类别 Badge + 文档数 + 描述
     * ============================================================ */}
    <header
      class="relative overflow-hidden rounded-xl border border-border bg-card shadow-sm"
    >
      <span
        class="absolute inset-x-0 top-0 h-1"
        style={`background-color:${meta.color}`}
        aria-hidden="true"
      />
      <div class="flex flex-col gap-2 p-6 md:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="text-2xl font-bold text-foreground md:text-3xl">
            知识地图 - {meta.name}
          </h1>
          {categoryMeta && (
            <span
              class="inline-flex items-center gap-1 rounded-md px-2 py-0.5 text-xs font-medium"
              style={`background-color:${meta.color}20;color:${meta.color}`}
            >
              <span
                class="h-1.5 w-1.5 rounded-full"
                style={`background-color:${meta.color}`}
                aria-hidden="true"
              />
              {categoryMeta.name}
            </span>
          )}
          <span
            class="inline-flex items-center rounded-md bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground"
          >
            {sortedDocs.length} 篇文档
          </span>
        </div>
        <p class="text-sm text-muted-foreground md:text-base">
          {meta.name} 模块知识结构与学习路径地图，可视化展示文档间的依赖关系。
        </p>
      </div>
    </header>

    {/* ============================================================
     * Mermaid 图表：文档依赖关系
     * ============================================================ */}
    {hasMermaid ? (
      <section class="flex flex-col gap-3" aria-label="文档依赖关系图">
        <MermaidLazy
          client:visible
          chart={mermaidGraph}
          id={mermaidId}
          className="bg-card"
        />

        {/* 图例说明 */}
        <div
          class="flex flex-wrap items-center gap-4 rounded-lg border border-border bg-card p-3 text-xs text-muted-foreground"
          aria-label="状态图例"
        >
          <span class="font-medium text-foreground">状态图例：</span>
          <span class="inline-flex items-center gap-1.5">
            <span
              class="h-2.5 w-2.5 rounded-full bg-emerald-500"
              aria-hidden="true"
            />
            已读
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span
              class="h-2.5 w-2.5 rounded-full bg-amber-500"
              aria-hidden="true"
            />
            在读
          </span>
          <span class="inline-flex items-center gap-1.5">
            <span
              class="h-2.5 w-2.5 rounded-full bg-muted-foreground/40"
              aria-hidden="true"
            />
            未读
          </span>
          <span class="ml-auto text-[11px] text-muted-foreground/80">
            滚轮缩放 · 拖拽平移 · 点击「查看交互版」渲染
          </span>
        </div>
      </section>
    ) : (
      <div
        class="rounded-xl border border-dashed border-border p-12 text-center text-sm text-muted-foreground"
      >
        该模块暂无文档，无法生成知识地图
      </div>
    )}

    {/* ============================================================
     * 文档列表表格：文档名、前置依赖、状态、阅读时间
     * ============================================================ */}
    {sortedDocs.length > 0 && (
      <section class="flex flex-col gap-3" aria-label="文档索引表">
        <h2 class="text-base font-semibold text-foreground md:text-lg">
          文档索引
        </h2>
        <div class="overflow-x-auto rounded-xl border border-border bg-card">
          <table class="w-full text-sm">
            <thead class="border-b border-border bg-muted/30 text-xs text-muted-foreground">
              <tr>
                <th class="px-4 py-3 text-left font-medium">状态</th>
                <th class="px-4 py-3 text-left font-medium">序号</th>
                <th class="px-4 py-3 text-left font-medium">文档名</th>
                <th class="px-4 py-3 text-left font-medium">难度</th>
                <th class="px-4 py-3 text-left font-medium">前置依赖</th>
                <th class="px-4 py-3 text-right font-medium">阅读时间</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border">
              {sortedDocs.map((doc, idx) => {
                const docSlug = slug(doc.id);
                const docDifficulty = doc.data.difficulty || 'intermediate';
                // 解析前置依赖：同模块内匹配
                const slugToTitle = new Map(
                  sortedDocs.map((d) => [slug(d.id), d.data.title]),
                );
                const prereqs = (doc.data.prerequisites || [])
                  .map((p) => {
                    const pSlug = (p.split('/').pop() || p).replace(/\.(md|mdx)$/, '');
                    return slugToTitle.get(pSlug);
                  })
                  .filter((t): t is string => Boolean(t));
                return (
                  <tr
                    class="transition-colors hover:bg-accent/30"
                    data-progress-slug={`${module}/${docSlug}`}
                  >
                    {/* 状态指示器（客户端由脚本更新颜色） */}
                    <td class="px-4 py-3">
                      <span
                        class={`map-status-dot inline-flex h-2.5 w-2.5 rounded-full ${statusDotClass.unread}`}
                        aria-label="未读"
                      />
                    </td>
                    {/* 序号 */}
                    <td class="px-4 py-3 text-xs tabular-nums text-muted-foreground">
                      {String(idx + 1).padStart(2, '0')}
                    </td>
                    {/* 文档名（链接） */}
                    <td class="px-4 py-3">
                      <a
                        href={withBase(`/${module}/${docSlug}/`)}
                        class="font-medium text-foreground transition-colors hover:text-primary"
                      >
                        {doc.data.title}
                      </a>
                      {doc.data.description && (
                        <p class="mt-0.5 line-clamp-1 text-xs text-muted-foreground">
                          {doc.data.description}
                        </p>
                      )}
                    </td>
                    {/* 难度 Badge */}
                    <td class="px-4 py-3">
                      <span
                        class={`inline-flex items-center rounded-md px-1.5 py-0.5 text-[10px] font-medium ${difficultyClass[docDifficulty]}`}
                      >
                        {difficultyLabel[docDifficulty]}
                      </span>
                    </td>
                    {/* 前置依赖 */}
                    <td class="px-4 py-3">
                      {prereqs.length === 0 ? (
                        <span class="text-xs text-muted-foreground/70">—</span>
                      ) : (
                        <ul class="flex flex-wrap gap-1">
                          {prereqs.map((p) => (
                            <li class="rounded-md bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground">
                              {p}
                            </li>
                          ))}
                        </ul>
                      )}
                    </td>
                    {/* 阅读时间 */}
                    <td class="px-4 py-3 text-right text-xs tabular-nums text-muted-foreground">
                      {doc.data.readingTime && doc.data.readingTime > 0
                        ? `${doc.data.readingTime} min`
                        : '—'}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
    )}

    {/* 底部：返回文档列表 + 术语表入口 */}
    <nav class="mt-4 flex flex-wrap gap-3" aria-label="模块导航">
      <a
        href={withBase(`/${module}/`)}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:bg-accent/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <polyline points="18 6 6 12 18 18" />
        </svg>
        返回文档列表
      </a>
      <a
        href={withBase(`/${module}/glossary/`)}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:bg-accent/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
          <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
        </svg>
        术语表
      </a>
    </nav>
  </div>
</Layout>

<script>
  /**
   * 知识地图客户端脚本
   *
   * 功能：
   * - 从 localStorage 读取阅读进度
   * - 更新文档表格状态指示器颜色（已读/在读/未读）
   * - 兼容 Astro ClientRouter：监听 astro:page-load 事件重新初始化
   */
  function initMapStatus(): void {
    const rows = document.querySelectorAll<HTMLElement>('[data-progress-slug]');
    if (rows.length === 0) return;

    /** 状态颜色映射 */
    const statusClass: Record<string, string> = {
      read: 'bg-emerald-500',
      reading: 'bg-amber-500',
      unread: 'bg-muted-foreground/40',
    };

    /** 状态 ARIA 标签映射 */
    const statusLabel: Record<string, string> = {
      read: '已读',
      reading: '在读',
      unread: '未读',
    };

    let progressMap: Record<string, { status?: string }> = {};

    try {
      const raw = localStorage.getItem('fandex-progress');
      if (raw) {
        const parsed = JSON.parse(raw) as {
          state?: { progress?: Record<string, { status?: string }> };
          progress?: Record<string, { status?: string }>;
        };
        progressMap = parsed.state?.progress ?? parsed.progress ?? {};
      }
    } catch {
      progressMap = {};
    }

    rows.forEach((row) => {
      const slug = row.getAttribute('data-progress-slug');
      if (!slug) return;
      const entry = progressMap[slug];
      const status = entry?.status ?? 'unread';

      const dot = row.querySelector<HTMLElement>('.map-status-dot');
      if (!dot) return;

      // 清除旧的状态类，添加新状态类
      dot.classList.remove(
        ...Object.values(statusClass),
      );
      dot.classList.add(statusClass[status] || statusClass.unread);
      dot.setAttribute('aria-label', statusLabel[status] || statusLabel.unread);
    });
  }

  initMapStatus();
  document.addEventListener('astro:page-load', initMapStatus);
  document.addEventListener('fandex-progress-change', initMapStatus);
</script>
