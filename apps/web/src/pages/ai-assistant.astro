---
/**
 * AI 助手页面
 *
 * 基于 GraphRAG 的知识图谱问答页面。
 * 提供对话式问答界面，用户输入问题后，
 * AI 基于知识图谱上下文生成结构化回答。
 */
import Layout from '@/components/Layout.astro';
import SEO from '@/components/SEO.astro';
import AIGraphRAG from '@/components/AIGraphRAG.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="AI 助手">
  <SEO slot="head" title="AI 助手" description="FANDEX 知识库 AI 助手，基于知识图谱的智能问答" />

  <div class="ai-assistant-page">
    <div class="ai-assistant-header">
      <div class="ai-assistant-title-row">
        <h1 class="ai-assistant-title">AI 助手</h1>
        <a href={base} class="back-home-btn">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"><polyline points="18 6 6 12 18 18"></polyline></svg
          >
          返回主页
        </a>
      </div>
      <p class="ai-assistant-desc">基于知识图谱的智能问答，支持编程、技术栈、学习路线等话题</p>
    </div>

    <AIGraphRAG />
  </div>
</Layout>

<style>
  .ai-assistant-page {
    padding: var(--spacing-lg) var(--spacing-2xl);
    max-width: 960px;
    margin: 0 auto;
  }

  .ai-assistant-header {
    margin-bottom: var(--spacing-lg);
    padding-bottom: var(--spacing-md);
    border-bottom: 1px solid var(--color-border-light);
  }

  .ai-assistant-title-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .ai-assistant-title {
    font-family: var(--font-display);
    font-size: 1.8em;
    margin: 0;
    letter-spacing: 0.02em;
  }

  .back-home-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 12px;
    color: var(--color-text-secondary);
    font-size: 0.85em;
    border: 1px solid var(--color-border-light);
    background: var(--color-bg-card);
    text-decoration: none;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast);
  }

  .back-home-btn:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
  }

  .ai-assistant-desc {
    font-size: 0.9em;
    color: var(--color-text-secondary);
    margin: var(--spacing-sm) 0 0;
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .ai-assistant-page {
      padding: var(--spacing-md);
    }

    .ai-assistant-title {
      font-size: 1.4em;
    }

    .ai-assistant-desc {
      display: none;
    }
  }
</style>
