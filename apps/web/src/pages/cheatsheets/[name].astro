---
import Breadcrumb from '@/components/Breadcrumb.astro';
/**
 * 速查表详情页路由（Phase 8b 新建）
 *
 * 功能概述：
 * - 动态路由 [name]，从 data/cheatsheets/*.json 文件名生成 9 个静态路径
 * - 页面头部：速查表标题 + 版本 + 最后更新 + 前置知识 + 推荐学习顺序
 * - 主体：CheatSheet 岛屿（client:load 立即水合，支持搜索 / Tabs / 复制 / 打印）
 * - 底部：返回速查表列表 / 全文搜索 入口
 *
 * 数据源：
 * - data/cheatsheets/*.json：使用 import.meta.glob eager 模式同步加载所有 JSON
 * - JSON 内中文 key 与 CheatsheetData 英文接口通过 mapCheatsheet() 转换：
 *   - 元数据.模块名称 → title
 *   - 分组[].分组名 → sections[].title
 *   - 分组[].分组说明 → sections[].description（仅展示用，不传入岛屿）
 *   - 分组[].条目[].描述 → items[].syntax（顶部 code 字体的简短描述）
 *   - 分组[].条目[].使用场景 → items[].description（详细说明）
 *   - 分组[].条目[].代码 → items[].example（折叠的示例代码）
 *
 * React 岛屿水合策略：
 * - CheatSheet: client:load（速查表是页面主体，首屏即用，包含搜索 / 复制等核心交互）
 *
 * Skill 偏差报备：
 * - 旧版引用 @fandex/shared 与 @fandex/markdown 已废弃，本版改用 @/lib/modules 与本地工具
 * - 旧版 CSS 变量 hsl(var(--card)) 已替换为 Tailwind v4 语义类（bg-card / border-border 等）
 * - import.meta.glob 使用 eager:true 直接返回模块对象，参考 astro-framework Skill 推荐
 */
import Layout from '@/components/Layout.astro';
import SEO from '@/components/SEO.astro';
import CheatSheet from '@/islands/CheatSheet';
import { getModule } from '@/lib/modules';
import { withBase } from '@/lib/url';
import type { CheatsheetData, CheatsheetItem, CheatsheetSection } from '@/types';

/**
 * 速查表 JSON 原始数据结构（中文 key）
 *
 * 与 data/cheatsheets/*.json 实际结构对齐，仅声明使用到的字段。
 */
interface CheatsheetJsonMeta {
  模块名称?: string;
  版本?: string;
  最后更新?: string;
  前置知识?: string[];
  推荐学习顺序?: string[];
}

interface CheatsheetJsonItem {
  描述?: string;
  代码?: string;
  高亮代码?: string;
  预期输出?: string;
  使用场景?: string;
  常见错误?: Array<{
    错误示例?: string;
    错误信息?: string;
    解决方法?: string;
  }>;
  进阶提示?: string;
  搜索关键词?: string[];
}

interface CheatsheetJsonGroup {
  分组名?: string;
  分组说明?: string;
  条目?: CheatsheetJsonItem[];
}

interface CheatsheetJson {
  元数据?: CheatsheetJsonMeta;
  分组?: CheatsheetJsonGroup[];
}

/**
 * 生成静态路径：从 9 个 JSON 文件名生成路径
 *
 * 实现说明：
 * - getStaticPaths 在 Astro 7 预渲染时运行于独立上下文，
 *   不能访问模块级变量，因此 import.meta.glob 必须在函数内部调用。
 * - glob 返回的对象 key 是文件路径（如 `../data/cheatsheets/javascript.json`）
 * - 提取文件名作为 params.name（如 `javascript`）
 * - props 同时携带原始 JSON 数据与文件名，供页面直接消费
 */
export async function getStaticPaths() {
  // 加载所有速查表 JSON 文件（eager 模式）
  // - import.meta.glob 第一个参数为相对当前文件的 glob 模式
  // - eager:true 直接返回模块对象（非 Promise）
  // - import:'default' 直接取 default 导出（JSON 文件的 default 即为整个对象）
  const cheatsheetModules = import.meta.glob<CheatsheetJson>('../data/cheatsheets/*.json', {
    eager: true,
    import: 'default',
  });

  return Object.entries(cheatsheetModules).map(([path, data]) => {
    // 路径示例：../data/cheatsheets/javascript.json → javascript
    const name =
      path
        .split('/')
        .pop()
        ?.replace(/\.json$/, '') ?? 'unknown';
    return {
      params: { name },
      props: { name, raw: data },
    };
  });
}

/** 页面 Props 类型 */
interface Props {
  name: string;
  raw: CheatsheetJson;
}

const { name, raw } = Astro.props as Props;

/**
 * 将中文 key 的 JSON 数据映射为 CheatsheetData 英文接口
 *
 * 映射规则：
 * - 元数据.模块名称 → title（缺失则回退到 name）
 * - 分组 → sections（过滤掉无条目的空分组）
 * - 分组.分组名 → section.title
 * - 分组.条目 → section.items
 * - 条目.描述 → item.syntax（顶部一行 code 字体显示的简短描述）
 * - 条目.使用场景 → item.description（缺失则回退到描述或空字符串）
 * - 条目.代码 → item.example（仅在非空时设置，触发岛屿的折叠示例代码块）
 *
 * @param name - 速查表标识（文件名）
 * @param json - 原始 JSON 数据
 * @returns 与 CheatsheetData 接口对齐的结构化数据
 */
function mapCheatsheet(name: string, json: CheatsheetJson): CheatsheetData {
  const meta = json.元数据 ?? {};
  const groups = json.分组 ?? [];

  const sections: CheatsheetSection[] = groups
    .filter((g) => Array.isArray(g.条目) && g.条目.length > 0)
    .map((group) => {
      const items: CheatsheetItem[] = (group.条目 ?? []).map((entry) => {
        const syntax = entry.描述?.trim() ?? '';
        const description = entry.使用场景?.trim() || entry.描述?.trim() || '';
        const example = entry.代码?.trim() || undefined;

        return {
          syntax,
          description,
          // 仅在存在代码时设置 example，避免岛屿误判为可折叠
          ...(example ? { example } : {}),
        };
      });

      return {
        title: group.分组名?.trim() ?? '未命名分组',
        items,
      };
    });

  return {
    name,
    title: meta.模块名称?.trim() || name,
    sections,
  };
}

/** 转换后的速查表数据（传给 CheatSheet 岛屿） */
const cheatsheetData = mapCheatsheet(name, raw);

/** 元数据（用于页面头部展示） */
const meta = raw.元数据 ?? {};
const moduleTitle = meta.模块名称?.trim() || name;
const version = meta.版本?.trim() || '';
const updatedAt = meta.最后更新?.trim() || '';
const prerequisites = meta.前置知识 ?? [];
const learningOrder = meta.推荐学习顺序 ?? [];

/** 关联模块（用于颜色与图标匹配） */
const moduleMeta = getModule(name);
const moduleColor = moduleMeta?.color ?? '#4f5bd5';
const moduleIcon = moduleMeta?.icon ?? name.charAt(0).toUpperCase();

/** 章节统计 */
const sectionCount = cheatsheetData.sections.length;
const itemCount = cheatsheetData.sections.reduce((sum, s) => sum + s.items.length, 0);

/** 章节分组说明（用于页面头部展示，与岛屿内容互补） */
const sectionDescriptions = (raw.分组 ?? [])
  .filter((g) => g.分组名 && g.分组说明)
  .map((g) => ({
    title: g.分组名 as string,
    description: g.分组说明 as string,
  }));

/** 面包屑导航项 */
const breadcrumb = [
  { label: '首页', href: withBase('/') },
  { label: '速查表', href: withBase('/cheatsheets/') },
  { label: moduleTitle },
];

/** SEO 面包屑（用于结构化数据） */
const seoBreadcrumbs = [
  { label: '首页', href: '/' },
  { label: '速查表', href: '/cheatsheets/' },
  { label: moduleTitle, href: `/cheatsheets/${name}/` },
];

/** 规范链接 */
const canonical = withBase(`/cheatsheets/${name}/`);

/** 页面描述（用于 SEO） */
const description = `${moduleTitle} 速查表，共 ${sectionCount} 章节 ${itemCount} 个代码片段，快速查阅常用语法与示例。`;
---

<Layout
  title={`${moduleTitle} 速查表 - FANDEX`}
  description={description}
  canonical={canonical}
>
  <SEO
    slot="head"
    title={`${moduleTitle} 速查表 - FANDEX`}
    description={description}
    type="article"
    canonical={canonical}
    breadcrumbs={seoBreadcrumbs}
  />

  <div class="mx-auto w-full max-w-5xl px-4 pb-12 md:px-8">
    {/* 面包屑导航 */}
    <Breadcrumb items={breadcrumb} />

    {/* ============================================================
     * 页面头部：标题 + 元数据（版本 / 最后更新 / 前置知识 / 推荐学习顺序）
     * ============================================================ */}
    <header
      class="relative overflow-hidden rounded-xl border border-border bg-card shadow-sm"
    >
      {/* 顶部色条：使用关联模块颜色 */}
      <span
        class="absolute inset-x-0 top-0 h-1"
        style={`background-color:${moduleColor}`}
        aria-hidden="true"
      />

      <div class="flex flex-col gap-4 p-6 md:p-8">
        {/* 标题行：图标 + 标题 + 版本 + 章节统计 */}
        <div class="flex flex-wrap items-center gap-3">
          <span
            class="flex h-12 w-12 flex-shrink-0 items-center justify-center rounded-lg text-base font-bold text-white shadow-sm"
            style={`background-color:${moduleColor}`}
            aria-hidden="true"
          >
            {moduleIcon}
          </span>
          <div class="min-w-0 flex-1">
            <div class="flex flex-wrap items-center gap-2">
              <h1 class="text-2xl font-bold text-foreground md:text-3xl">
                {moduleTitle}
              </h1>
              {version && (
                <span
                  class="inline-flex items-center rounded-md bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground"
                >
                  v{version}
                </span>
              )}
            </div>
            <p class="mt-1 text-xs text-muted-foreground md:text-sm">
              速查表 · 共
              <span class="font-medium text-foreground tabular-nums">
                {sectionCount}
              </span>
              章节 ·
              <span class="font-medium text-foreground tabular-nums">
                {itemCount}
              </span>
              个代码片段
            </p>
          </div>
        </div>

        {/* 元信息行：最后更新日期 */}
        {updatedAt && (
          <div class="flex flex-wrap items-center gap-3 text-xs text-muted-foreground">
            <span class="inline-flex items-center gap-1.5">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-3.5 w-3.5"
                aria-hidden="true"
              >
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
                <line x1="16" y1="2" x2="16" y2="6" />
                <line x1="8" y1="2" x2="8" y2="6" />
                <line x1="3" y1="10" x2="21" y2="10" />
              </svg>
              <span class="tabular-nums">最后更新：{updatedAt}</span>
            </span>
          </div>
        )}

        {/* 前置知识 */}
        {prerequisites.length > 0 && (
          <section aria-label="前置知识">
            <p
              class="mb-1.5 text-[11px] font-medium uppercase tracking-wider text-muted-foreground"
            >
              前置知识
            </p>
            <ul class="flex flex-wrap gap-1.5">
              {prerequisites.map((p) => (
                <li
                  class="inline-flex items-center rounded-md border border-border bg-muted/40 px-2 py-0.5 text-xs text-muted-foreground"
                >
                  {p}
                </li>
              ))}
            </ul>
          </section>
        )}

        {/* 推荐学习顺序 */}
        {learningOrder.length > 0 && (
          <section
            class="rounded-lg border border-primary/20 bg-primary/5 p-3"
            aria-label="推荐学习顺序"
          >
            <p
              class="mb-1.5 flex items-center gap-1 text-[11px] font-medium uppercase tracking-wider text-primary"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="h-3 w-3"
                aria-hidden="true"
              >
                <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
                <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
              </svg>
              推荐学习顺序
            </p>
            <ol class="ml-4 list-decimal space-y-0.5 text-xs text-foreground/90 md:text-sm">
              {learningOrder.map((step) => (
                <li>{step}</li>
              ))}
            </ol>
          </section>
        )}
      </div>
    </header>

    {/* ============================================================
     * 章节分组说明（可折叠列表，作为速查表岛屿的补充上下文）
     * ============================================================ */}
    {sectionDescriptions.length > 0 && (
      <details
        class="mt-4 rounded-xl border border-border bg-card shadow-sm"
      >
        <summary
          class="flex cursor-pointer items-center justify-between gap-2 p-4 text-sm font-medium text-foreground transition-colors hover:bg-accent/30"
        >
          <span>章节分组说明（{sectionDescriptions.length} 个分组）</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="h-4 w-4 text-muted-foreground transition-transform"
            aria-hidden="true"
          >
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </summary>
        <ul class="divide-y divide-border border-t border-border">
          {sectionDescriptions.map((s) => (
            <li class="px-4 py-3">
              <p class="text-xs font-semibold text-foreground md:text-sm">
                {s.title}
              </p>
              <p class="mt-1 text-xs text-muted-foreground md:text-sm">
                {s.description}
              </p>
            </li>
          ))}
        </ul>
      </details>
    )}

    {/* ============================================================
     * 速查表主体：CheatSheet 岛屿（client:load 立即水合）
     * 包含 Tabs 切换 / 搜索 / 复制 / 打印 / 折叠示例 等核心交互
     * ============================================================ */}
    <section
      class="mt-6 rounded-xl border border-border bg-card p-4 shadow-sm md:p-6"
      aria-label={`${moduleTitle} 速查表内容`}
    >
      <CheatSheet client:load cheatsheet={cheatsheetData} />
    </section>

    {/* ============================================================
     * 底部：返回速查表列表 / 返回首页 / 全文搜索
     * ============================================================ */}
    <nav
      class="mt-12 flex flex-wrap gap-3"
      aria-label="页面导航"
    >
      <a
        href={withBase('/cheatsheets/')}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:bg-accent/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <polyline points="18 6 6 12 18 18" />
        </svg>
        所有速查表
      </a>
      <a
        href={withBase('/')}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:bg-accent/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        返回首页
      </a>
      <a
        href={withBase('/search/')}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:bg-accent/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.3-4.3" />
        </svg>
        全文搜索
      </a>
    </nav>
  </div>
</Layout>
