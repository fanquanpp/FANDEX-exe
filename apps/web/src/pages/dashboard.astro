---
import { getCollection } from 'astro:content';
import Breadcrumb from '@/components/Breadcrumb.astro';
/**
 * 学习仪表盘路由（Phase 8a 新建）
 *
 * 功能概述：
 * - 页面标题 + 面包屑（首页 / 仪表盘）
 * - DashboardStats 岛屿：环形进度图 + 连续学习天数 + 三态统计 + 模块完成度概览 + 最近活动
 * - ModuleProgressList 岛屿：按分类分组折叠展示各模块完成度
 * - RecentActivity 岛屿：最近阅读记录时间线
 * - 快捷操作：导出笔记（Tauri 命令） / 重置进度（确认对话框）
 *
 * 数据源：
 * - docs: astro:content 的 getCollection('docs')（构建 allDocIds）
 * - MODULES: @/lib/modules（用于 ModuleProgressList）
 *
 * 岛屿水合：
 * - DashboardStats: client:load（首屏关键统计，立即水合）
 * - ModuleProgressList: client:visible（可见时水合，减少初始 JS 执行）
 * - RecentActivity: client:visible（可见时水合）
 *
 * Tauri 兼容：
 * - 所有链接使用 withBase() 处理
 * - 导出笔记按钮通过 data-tauri-command 属性标记，由客户端脚本（Phase 10）调用 Tauri invoke
 * - 重置进度按钮通过 confirm 对话框确认后清空 progress-store
 */
import Layout from '@/components/Layout.astro';
import SEO from '@/components/SEO.astro';
import DashboardStats from '@/islands/DashboardStats';
import ModuleProgressList from '@/islands/ModuleProgressList';
import RecentActivity from '@/islands/RecentActivity';
import { SITE } from '@/lib/constants';
import { MODULES } from '@/lib/modules';
import { withBase } from '@/lib/url';

/** 获取所有文档集合，构建全站文档 ID 列表（用于进度统计） */
const allDocs = await getCollection('docs');
const allDocIds: readonly string[] = allDocs.map((doc) => doc.id);

/** 面包屑层级 */
const breadcrumbs = [{ label: '首页', href: '/' }, { label: '仪表盘' }];

/** SEO 文档描述 */
const seoDescription = `${SITE.name} 学习仪表盘 - 总体进度、连续学习天数、各模块完成度与最近阅读活动一览。`;
---

<Layout
  title={`学习仪表盘 - ${SITE.name}`}
  description={seoDescription}
  hasSidebar={false}
>
  <SEO
    slot="head"
    title={`学习仪表盘 - ${SITE.name}`}
    description={seoDescription}
    type="website"
    breadcrumbs={breadcrumbs}
  />

  {/* ============================================================
   * 面包屑导航
   * ============================================================ */}
  <Breadcrumb items={breadcrumbs} />

  <div class="mx-auto w-full max-w-5xl px-4 py-6 md:px-8 md:py-8">
    {/* ============================================================
     * 页面标题 + 快捷操作
     * ============================================================ */}
    <header class="mb-6 flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
      <div>
        <h1 class="text-2xl font-bold tracking-tight text-foreground md:text-3xl">
          学习仪表盘
        </h1>
        <p class="mt-1 text-sm text-muted-foreground">
          追踪你的学习进度，保持每日学习习惯
        </p>
      </div>

      {/* 快捷操作按钮组 */}
      <div class="flex flex-wrap items-center gap-2">
        <button
          type="button"
          id="dashboard-export-btn"
          data-tauri-command="export_notes"
          class="inline-flex items-center gap-1.5 rounded-md border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition-colors hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
          aria-label="导出学习笔记"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
            <polyline points="7 10 12 15 17 10" />
            <line x1="12" y1="15" x2="12" y2="3" />
          </svg>
          导出笔记
        </button>
        <button
          type="button"
          id="dashboard-reset-btn"
          class="inline-flex items-center gap-1.5 rounded-md border border-destructive/30 bg-destructive/5 px-3 py-1.5 text-xs font-medium text-destructive transition-colors hover:bg-destructive/10 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-destructive"
          aria-label="重置所有学习进度"
        >
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path d="M3 6h18M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
            <line x1="10" y1="11" x2="10" y2="17" />
            <line x1="14" y1="11" x2="14" y2="17" />
          </svg>
          重置进度
        </button>
      </div>
    </header>

    {/* ============================================================
     * DashboardStats 岛屿：环形进度图 + 三态统计 + 模块完成度概览 + 最近活动
     * client:load 立即水合，首屏关键统计
     * ============================================================ */}
    <section class="mb-8" aria-label="总体统计">
      <DashboardStats
        client:load
        allDocIds={allDocIds}
        topModules={5}
        recentCount={5}
      />
    </section>

    {/* ============================================================
     * ModuleProgressList 岛屿：按分类分组展示各模块完成度
     * client:visible 可见时水合
     * ============================================================ */}
    <section class="mb-8" aria-label="模块完成度列表">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-foreground">模块完成度详情</h2>
        <a
          href={withBase('/roadmap/')}
          class="text-xs text-muted-foreground transition-colors hover:text-primary"
        >
          查看学习路线 →
        </a>
      </div>
      <ModuleProgressList
        client:visible
        modules={MODULES}
        allDocIds={allDocIds}
        defaultExpanded={true}
        sortByProgress={true}
      />
    </section>

    {/* ============================================================
     * RecentActivity 岛屿：最近阅读记录时间线
     * client:visible 可见时水合
     * ============================================================ */}
    <section class="mb-8" aria-label="最近活动">
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold text-foreground">最近阅读</h2>
      </div>
      <RecentActivity
        client:visible
        limit={10}
        showModuleTag={true}
        emptyCtaHref="/"
        emptyCtaText="浏览学习模块"
      />
    </section>

    {/* ============================================================
     * 学习建议卡片
     * ============================================================ */}
    <section class="mb-4" aria-label="学习建议">
      <div
        class="rounded-lg border border-primary/20 bg-primary/5 p-5"
      >
        <div class="flex items-start gap-3">
          <span
            class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary"
            aria-hidden="true"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M9 18h6M10 22h4M12 2a7 7 0 0 0-4 12.7V17a1 1 0 0 0 1 1h6a1 1 0 0 0 1-1v-2.3A7 7 0 0 0 12 2z" />
            </svg>
          </span>
          <div class="flex-1">
            <h3 class="text-sm font-semibold text-foreground">学习建议</h3>
            <ul class="mt-2 space-y-1 text-xs text-muted-foreground">
              <li>每日坚持阅读 1-2 篇文档，保持学习的连续性</li>
              <li>遇到难懂的概念可标记为"在读"，便于后续回顾</li>
              <li>完成一个模块后，对照学习路线图查看下一个推荐模块</li>
              <li>善用 Ctrl+K 命令面板快速跳转到任意文档</li>
            </ul>
          </div>
        </div>
      </div>
    </section>
  </div>

  {/* ============================================================
   * 重置进度确认对话框（HTML5 dialog 元素，无 JS 框架依赖）
   * ============================================================ */}
  <dialog
    id="dashboard-reset-dialog"
    class="rounded-lg border border-border bg-background p-6 shadow-xl backdrop:bg-black/50"
    aria-labelledby="dashboard-reset-dialog-title"
  >
    <div class="flex flex-col gap-4">
      <div class="flex items-start gap-3">
        <span
          class="flex h-10 w-10 flex-shrink-0 items-center justify-center rounded-full bg-destructive/10 text-destructive"
          aria-hidden="true"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z" />
            <line x1="12" y1="9" x2="12" y2="13" />
            <line x1="12" y1="17" x2="12.01" y2="17" />
          </svg>
        </span>
        <div>
          <h2
            id="dashboard-reset-dialog-title"
            class="text-base font-semibold text-foreground"
          >
            确认重置所有学习进度？
          </h2>
          <p class="mt-1 text-sm text-muted-foreground">
            此操作将清空所有文档的阅读状态、最近阅读记录与连续学习天数。该操作不可撤销，确定继续吗？
          </p>
        </div>
      </div>
      <div class="flex justify-end gap-2">
        <button
          type="button"
          id="dashboard-reset-cancel"
          class="inline-flex items-center rounded-md border border-border bg-background px-3 py-1.5 text-xs font-medium text-foreground transition-colors hover:bg-accent focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          取消
        </button>
        <button
          type="button"
          id="dashboard-reset-confirm"
          class="inline-flex items-center rounded-md bg-destructive px-3 py-1.5 text-xs font-medium text-destructive-foreground transition-colors hover:bg-destructive/90 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-destructive"
        >
          确认重置
        </button>
      </div>
    </div>
  </dialog>
</Layout>

<script>
  /**
   * 仪表盘页面客户端脚本
   *
   * 功能模块：
   * 1. 重置进度确认对话框：点击"重置进度"按钮打开 dialog，确认后清空 localStorage
   * 2. 导出笔记按钮：触发 Tauri 命令（如可用）或下载 JSON 文件作为降级
   *
   * 兼容 Astro ClientRouter：监听 astro:page-load 事件重新初始化
   */

  /** 初始化重置进度对话框交互 */
  function initResetDialog(): void {
    const resetBtn = document.getElementById('dashboard-reset-btn');
    const dialog = document.getElementById(
      'dashboard-reset-dialog',
    ) as HTMLDialogElement | null;
    const cancelBtn = document.getElementById('dashboard-reset-cancel');
    const confirmBtn = document.getElementById('dashboard-reset-confirm');

    if (!resetBtn || !dialog || !cancelBtn || !confirmBtn) return;

    /** 已绑定标记，避免重复添加监听器 */
    if (resetBtn.dataset.bound === 'true') return;
    resetBtn.dataset.bound = 'true';

    /** 打开对话框 */
    resetBtn.addEventListener('click', () => {
      dialog.showModal();
    });

    /** 取消按钮关闭对话框 */
    cancelBtn.addEventListener('click', () => {
      dialog.close();
    });

    /** 确认按钮：清空进度数据并关闭对话框 */
    confirmBtn.addEventListener('click', () => {
      try {
        /** 清空 progress-store 持久化数据 */
        localStorage.removeItem('fandex-progress');
        /** 触发全局事件，通知岛屿组件重新读取 */
        document.dispatchEvent(new CustomEvent('fandex-progress-change'));
        /** 重新加载页面以同步所有岛屿状态 */
        window.location.reload();
      } catch {
        /* localStorage 不可用时静默降级 */
      }
      dialog.close();
    });

    /** 点击对话框外部关闭 */
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) {
        dialog.close();
      }
    });
  }

  /**
   * 初始化导出笔记按钮
   *
   * 策略：
   * - Tauri 环境：调用 invoke('export_notes') 命令（由 Phase 10 客户端脚本接管）
   * - Web 环境：将 localStorage 中的 progress + annotations 数据导出为 JSON 文件
   */
  function initExportButton(): void {
    const exportBtn = document.getElementById('dashboard-export-btn');
    if (!exportBtn) return;

    if (exportBtn.dataset.bound === 'true') return;
    exportBtn.dataset.bound = 'true';

    exportBtn.addEventListener('click', () => {
      try {
        /** 收集本地存储的学习数据 */
        const progress = localStorage.getItem('fandex-progress');
        const annotations = localStorage.getItem('fandex-annotations');
        const exportData = {
          exportedAt: new Date().toISOString(),
          version: '1.0.0',
          progress: progress ? JSON.parse(progress) : null,
          annotations: annotations ? JSON.parse(annotations) : null,
        };

        /** 生成 JSON 文件并触发下载 */
        const blob = new Blob([JSON.stringify(exportData, null, 2)], {
          type: 'application/json',
        });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `fandex-backup-${new Date().toISOString().slice(0, 10)}.json`;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
      } catch {
        /* 导出失败时静默处理 */
      }
    });
  }

  /** 初始化所有模块 */
  function initDashboard(): void {
    initResetDialog();
    initExportButton();
  }

  // 首屏初始化 + ClientRouter 跳转后重新初始化
  initDashboard();
  document.addEventListener('astro:page-load', initDashboard);
</script>
