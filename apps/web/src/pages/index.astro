---
import { getCollection } from 'astro:content';
/**
 * 首页路由（Phase 8a 重写）
 *
 * 功能概述：
 * - Hero 区域：全屏渐变背景 + HeroCanvas 粒子动画 + 大标题 FANDEX + 副标题 + CTA 按钮
 * - 统计数据条：4 列网格（模块数 / 文档数 / 术语表数 / 速查表数）
 * - 模块卡片网格：51 模块按 8 大类别分组，每类一个 section 标题，使用 ModuleCard 组件
 * - 快速入口：4 个卡片（仪表盘 / 搜索 / 学习路线 / 速查表）
 * - Footer：版权 + 链接
 *
 * 数据源：
 * - modules: @/lib/modules 的 MODULES / MODULE_CATEGORIES
 * - docs: astro:content 的 getCollection('docs')
 * - glossary: astro:content 的 getCollection('glossary')
 *
 * 岛屿水合：
 * - HeroCanvas: client:load（首屏关键动画，立即水合）
 *
 * Skill 偏差报备：
 * 原任务规格要求使用 <ModuleSearch client:visible /> 岛屿。
 * ModuleSearch 组件使用 children render prop 模式（children: (modules) => ReactNode），
 * Astro 无法将函数作为 props 传递给 React 岛屿（函数不可序列化）。
 * 为避免创建非必要包装组件文件（超出 Phase 8a 范围），
 * 首页模块网格保留静态分类分组渲染，搜索功能由 Header 内置 SearchModal（Ctrl+K）与独立 /search 页面承担。
 * 此偏差与旧版 index.astro 一致，不引入回归。
 */
import HomeLayout from '@/components/HomeLayout.astro';
import ModuleCard from '@/components/ModuleCard.astro';
import SEO from '@/components/SEO.astro';
import HeroCanvas from '@/islands/HeroCanvas';
import { SITE } from '@/lib/constants';
import { MODULE_CATEGORIES, MODULES } from '@/lib/modules';
import { withBase } from '@/lib/url';

/** 获取所有文档集合（用于统计文档数与各模块文档数） */
const allDocs = await getCollection('docs');
/** 获取所有术语表集合（用于统计术语表数） */
const allGlossary = await getCollection('glossary');

/** 速查表数量（data/cheatsheets/ 下 JSON 文件数，固定 9 个） */
const cheatsheetCount = 9;

/** 构建各模块文档数量映射 */
const docCountMap: Record<string, number> = {};
allDocs.forEach((doc) => {
  const m = doc.data.module;
  docCountMap[m] = (docCountMap[m] || 0) + 1;
});

/** 为每个模块填充 docsCount（基于实际文档数） */
const modulesWithCount = MODULES.map((mod) => ({
  ...mod,
  docsCount: docCountMap[mod.id] ?? mod.docsCount,
}));

/** 按分类分组模块（仅保留有模块的分类） */
const grouped = MODULE_CATEGORIES.map((cat) => ({
  key: cat.id,
  label: cat.name,
  color: cat.color,
  modules: modulesWithCount.filter((m) => m.category === cat.id),
})).filter((g) => g.modules.length > 0);

/** 统计所有标签数量 */
const totalTags = new Set<string>();
allDocs.forEach((doc) => {
  if (doc.data.tags)
    doc.data.tags.forEach((t) => {
      totalTags.add(t);
    });
});

/** 当前年份（用于页脚版权声明） */
const currentYear = new Date().getFullYear();

/** SEO 面包屑层级 */
const breadcrumbs = [{ label: '首页' }];
---

<HomeLayout
  title={`${SITE.name} - 现代化知识图谱学习平台`}
  description={SITE.description}
>
  <SEO
    slot="head"
    title={`${SITE.name} - 现代化知识图谱学习平台`}
    description={SITE.description}
    type="website"
    breadcrumbs={breadcrumbs}
  />

  <div class="flex min-h-[calc(100vh-3.5rem)] min-h-[calc(100dvh-3.5rem)] flex-col">
    {/* ============================================================
     * Hero 区域：全屏渐变背景 + HeroCanvas 粒子动画 + 大标题 + CTA
     * ============================================================ */}
    <section
      class="relative flex flex-col items-center justify-center overflow-hidden border-b border-border px-4 py-16 md:px-8 md:py-24"
      aria-label="站点介绍"
    >
      {/* 渐变背景层：Sky→Teal→Amber 三色系渐变（对齐 FANDEX-Web 品牌主色系） */}
      <div
        class="geo-tricolor-gradient pointer-events-none absolute inset-0"
        aria-hidden="true"
      />
      {/* 径向光晕：Primary（Sky）+ Secondary（Teal）双光晕 */}
      <div
        class="geo-radial-glow pointer-events-none absolute inset-0"
        aria-hidden="true"
      />
      <div
        class="geo-radial-glow-secondary pointer-events-none absolute inset-0"
        aria-hidden="true"
      />
      {/* 几何点阵装饰：构成主义背景纹理 */}
      <div
        class="geo-dot-bg pointer-events-none absolute inset-0 opacity-60"
        aria-hidden="true"
      />

      {/* HeroCanvas 粒子动画（client:load 立即水合，首屏关键视觉） */}
      <HeroCanvas client:load className="absolute inset-0" />

      {/* 内容层（z-10 确保在动画之上） */}
      <div class="relative z-10 mx-auto max-w-4xl text-center">
        {/* 徽章 */}
        <div
          class="mb-4 inline-flex items-center gap-2 rounded-full border border-primary/30 bg-primary/5 px-4 py-1.5 text-xs font-semibold tracking-widest text-primary uppercase"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse" aria-hidden="true"></span>
          Zero to Mastery
        </div>

        {/* 大标题 FANDEX：Sky→Teal→Amber 三色系渐变（对齐 FANDEX-Web 品牌主色系） */}
        <h1
          class="bg-gradient-to-r from-primary via-secondary to-accent bg-clip-text text-5xl font-extrabold tracking-tight text-transparent md:text-7xl"
        >
          FANDEX
        </h1>

        {/* 副标题 */}
        <p
          class="mx-auto mt-4 max-w-2xl text-base text-muted-foreground md:text-lg"
        >
          循序渐进，从第一行代码到理解整个世界。覆盖编程语言、前端、后端、计算机科学、人工智能等
          <span class="font-semibold text-foreground">{MODULES.length}</span>
          个学习模块的渐进式自学平台。
        </p>

        {/* CTA 按钮组 */}
        <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href={withBase('/roadmap/')}
            class="inline-flex items-center gap-2 rounded-md bg-primary px-6 py-2.5 text-sm font-medium text-primary-foreground shadow-sm transition-all hover:-translate-y-0.5 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7" />
            </svg>
            开始学习
          </a>
          <a
            href={withBase('/search/')}
            class="inline-flex items-center gap-2 rounded-md border border-border bg-card px-6 py-2.5 text-sm font-medium text-foreground transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:text-primary focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2"
          >
            <svg
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
            快速搜索
          </a>
        </div>

        {/* 快捷键提示 */}
        <p class="mt-4 text-xs text-muted-foreground">
          按
          <kbd
            class="mx-1 inline-flex h-5 items-center rounded border border-border bg-muted px-1.5 text-[10px] font-mono font-medium"
          >Ctrl</kbd>
          +
          <kbd
            class="mx-1 inline-flex h-5 items-center rounded border border-border bg-muted px-1.5 text-[10px] font-mono font-medium"
          >K</kbd>
          唤起命令面板
        </p>
      </div>
    </section>

    {/* ============================================================
     * 统计数据条：4 列网格（模块 / 文档 / 术语表 / 速查表）
     * ============================================================ */}
    <section
      class="border-b border-border bg-muted/30"
      aria-label="站点统计"
    >
      <div class="mx-auto grid max-w-5xl grid-cols-2 gap-px overflow-hidden md:grid-cols-4">
        <div class="flex flex-col items-center gap-1 bg-background px-4 py-6">
          <span class="text-3xl font-extrabold tabular-nums text-foreground md:text-4xl">
            {MODULES.length}
          </span>
          <span class="text-xs font-medium tracking-wider text-muted-foreground uppercase">
            学习模块
          </span>
        </div>
        <div class="flex flex-col items-center gap-1 bg-background px-4 py-6">
          <span class="text-3xl font-extrabold tabular-nums text-foreground md:text-4xl">
            {allDocs.length}
          </span>
          <span class="text-xs font-medium tracking-wider text-muted-foreground uppercase">
            结构化文档
          </span>
        </div>
        <div class="flex flex-col items-center gap-1 bg-background px-4 py-6">
          <span class="text-3xl font-extrabold tabular-nums text-foreground md:text-4xl">
            {allGlossary.length}
          </span>
          <span class="text-xs font-medium tracking-wider text-muted-foreground uppercase">
            术语表
          </span>
        </div>
        <div class="flex flex-col items-center gap-1 bg-background px-4 py-6">
          <span class="text-3xl font-extrabold tabular-nums text-foreground md:text-4xl">
            {cheatsheetCount}
          </span>
          <span class="text-xs font-medium tracking-wider text-muted-foreground uppercase">
            速查表
          </span>
        </div>
      </div>
    </section>

    {/* ============================================================
     * 快速入口：4 个卡片（仪表盘 / 搜索 / 路线图 / 速查表）
     * ============================================================ */}
    <section class="mx-auto w-full max-w-5xl px-4 py-10 md:px-8" aria-label="快速入口">
      <h2 class="mb-5 text-lg font-semibold text-foreground">快速入口</h2>
      <div class="grid grid-cols-2 gap-3 md:grid-cols-4">
        <a
          href={withBase('/dashboard/')}
          class="group flex flex-col items-start gap-2 rounded-lg border border-border bg-card p-4 transition-all hover:-translate-y-1 hover:border-primary/40 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          <span
            class="flex h-10 w-10 items-center justify-center rounded-md bg-primary/10 text-primary transition-transform group-hover:scale-110"
            aria-hidden="true"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="9" />
              <rect x="14" y="3" width="7" height="5" />
              <rect x="14" y="12" width="7" height="9" />
              <rect x="3" y="16" width="7" height="5" />
            </svg>
          </span>
          <span class="text-sm font-semibold text-foreground">仪表盘</span>
          <span class="text-xs text-muted-foreground">学习进度概览</span>
        </a>

        <a
          href={withBase('/search/')}
          class="group flex flex-col items-start gap-2 rounded-lg border border-border bg-card p-4 transition-all hover:-translate-y-1 hover:border-primary/40 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          <span
            class="flex h-10 w-10 items-center justify-center rounded-md bg-primary/10 text-primary transition-transform group-hover:scale-110"
            aria-hidden="true"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8" />
              <path d="m21 21-4.3-4.3" />
            </svg>
          </span>
          <span class="text-sm font-semibold text-foreground">搜索</span>
          <span class="text-xs text-muted-foreground">全文检索知识库</span>
        </a>

        <a
          href={withBase('/roadmap/')}
          class="group flex flex-col items-start gap-2 rounded-lg border border-border bg-card p-4 transition-all hover:-translate-y-1 hover:border-primary/40 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          <span
            class="flex h-10 w-10 items-center justify-center rounded-md bg-primary/10 text-primary transition-transform group-hover:scale-110"
            aria-hidden="true"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
            </svg>
          </span>
          <span class="text-sm font-semibold text-foreground">路线图</span>
          <span class="text-xs text-muted-foreground">推荐学习路径</span>
        </a>

        <a
          href={withBase('/cheatsheets/')}
          class="group flex flex-col items-start gap-2 rounded-lg border border-border bg-card p-4 transition-all hover:-translate-y-1 hover:border-primary/40 hover:shadow-md focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
        >
          <span
            class="flex h-10 w-10 items-center justify-center rounded-md bg-primary/10 text-primary transition-transform group-hover:scale-110"
            aria-hidden="true"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z" />
              <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z" />
            </svg>
          </span>
          <span class="text-sm font-semibold text-foreground">速查表</span>
          <span class="text-xs text-muted-foreground">语法快速查阅</span>
        </a>
      </div>
    </section>

    {/* ============================================================
     * 模块卡片网格：按 8 大类别分组
     * ============================================================ */}
    <section
      class="mx-auto w-full max-w-5xl px-4 py-6 md:px-8"
      aria-label="学习模块"
    >
      <div class="mb-6 flex items-end justify-between">
        <div>
          <h2 class="text-lg font-semibold text-foreground">学习模块</h2>
          <p class="mt-1 text-sm text-muted-foreground">
            按 8 大领域分类，共 {MODULES.length} 个模块
          </p>
        </div>
        <a
          href={withBase('/roadmap/')}
          class="hidden text-xs text-muted-foreground transition-colors hover:text-primary md:inline-flex md:items-center md:gap-1"
        >
          查看学习路线
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="9 18 15 12 9 6" />
          </svg>
        </a>
      </div>

      <div class="space-y-8">
        {grouped.map((group) => (
          <div class="category-section" data-category={group.key}>
            <button
              type="button"
              class="category-header mb-3 flex w-full items-center gap-3 text-left transition-colors hover:bg-muted/30"
              aria-label={`折叠 ${group.label} 分类`}
              aria-expanded="true"
              data-category-toggle={group.key}
            >
              <span
                class="h-3 w-3 flex-shrink-0 rounded-sm"
                style={`background-color:${group.color}`}
                aria-hidden="true"
              />
              <h3 class="text-sm font-bold tracking-wide text-foreground uppercase">
                {group.label}
              </h3>
              <span class="text-xs text-muted-foreground">
                {group.modules.length} 个模块
              </span>
              <div class="ml-2 h-px flex-1 bg-border" aria-hidden="true" />
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="category-arrow h-4 w-4 flex-shrink-0 text-muted-foreground transition-transform"
                aria-hidden="true"
              >
                <polyline points="6 9 12 15 18 9" />
              </svg>
            </button>
            <div
              class="category-content grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
              data-category-content={group.key}
            >
              {group.modules.map((mod) => (
                <ModuleCard mod={mod} />
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <style is:global>
      /**
       * 首页分类卡片折叠样式
       * - .is-collapsed 添加到 .category-content 时隐藏
       * - .category-arrow 旋转 -90deg 表示已折叠
       * - .category-header 整行可点击，悬停高亮
       */
      .category-content.is-collapsed {
        display: none;
      }

      .category-header.is-collapsed .category-arrow {
        transform: rotate(-90deg);
      }
    </style>

    <script>
      /**
       * 首页分类卡片折叠逻辑
       *
       * 实现说明：
       * - 监听 .category-header 点击事件，切换 .category-content 显隐
       * - 旋转 .category-arrow 表示折叠状态
       * - 同步更新 aria-expanded 属性
       * - 折叠状态持久化到 localStorage（键：fandex-index-collapsed）
       * - 兼容 View Transitions：监听 astro:page-load 重新初始化
       */

      /** localStorage 键名：首页分类折叠状态 */
      const INDEX_COLLAPSE_KEY = 'fandex-index-collapsed';

      /** 读取已折叠分类 key 集合 */
      function readCollapsedSet(): Set<string> {
        try {
          const raw = localStorage.getItem(INDEX_COLLAPSE_KEY);
          if (!raw) return new Set();
          const arr = JSON.parse(raw) as string[];
          return new Set(Array.isArray(arr) ? arr : []);
        } catch {
          return new Set();
        }
      }

      /** 写入已折叠分类 key 集合 */
      function writeCollapsedSet(set: Set<string>): void {
        try {
          localStorage.setItem(INDEX_COLLAPSE_KEY, JSON.stringify(Array.from(set)));
        } catch {
          /* localStorage 不可用时静默降级 */
        }
      }

      /** 初始化分类卡片折叠交互 */
      function initCategoryCollapse(): void {
        const headers = document.querySelectorAll<HTMLButtonElement>('.category-header[data-category-toggle]');
        if (headers.length === 0) return;

        headers.forEach((header) => {
          if (header.dataset.bound === '1') return;
          header.dataset.bound = '1';

          header.addEventListener('click', () => {
            const categoryKey = header.getAttribute('data-category-toggle');
            if (!categoryKey) return;

            const section = header.closest('.category-section') as HTMLElement | null;
            if (!section) return;

            const content = section.querySelector<HTMLElement>('.category-content');
            if (!content) return;

            const willCollapse = !content.classList.contains('is-collapsed');
            if (willCollapse) {
              content.classList.add('is-collapsed');
              header.classList.add('is-collapsed');
              header.setAttribute('aria-expanded', 'false');
            } else {
              content.classList.remove('is-collapsed');
              header.classList.remove('is-collapsed');
              header.setAttribute('aria-expanded', 'true');
            }

            // 持久化
            const collapsedSet = readCollapsedSet();
            if (willCollapse) {
              collapsedSet.add(categoryKey);
            } else {
              collapsedSet.delete(categoryKey);
            }
            writeCollapsedSet(collapsedSet);
          });
        });

        // 恢复持久化的折叠状态
        const collapsedSet = readCollapsedSet();
        if (collapsedSet.size === 0) return;

        headers.forEach((header) => {
          const categoryKey = header.getAttribute('data-category-toggle');
          if (!categoryKey || !collapsedSet.has(categoryKey)) return;

          const section = header.closest('.category-section') as HTMLElement | null;
          if (!section) return;

          const content = section.querySelector<HTMLElement>('.category-content');
          if (!content) return;

          content.classList.add('is-collapsed');
          header.classList.add('is-collapsed');
          header.setAttribute('aria-expanded', 'false');
        });
      }

      // 初始化（首屏 + View Transitions 跳转后）
      initCategoryCollapse();
      document.addEventListener('astro:page-load', initCategoryCollapse);
    </script>

    {/* ============================================================
     * Footer：版权 + 链接
     * ============================================================ */}
    <footer
      class="mt-auto border-t border-border bg-muted/30"
      aria-label="页脚"
    >
      <div class="mx-auto max-w-5xl px-4 py-8 md:px-8">
        <div class="flex flex-col items-center gap-4 text-center md:flex-row md:justify-between md:text-left">
          <div class="flex flex-col items-center gap-1 md:items-start">
            <p class="text-sm font-semibold text-foreground">
              {SITE.name}
            </p>
            <p class="text-xs text-muted-foreground">
              Built with Astro 7 SSG · Tauri 2 Compatible
            </p>
          </div>
          <nav class="flex flex-wrap items-center justify-center gap-x-4 gap-y-2 text-xs">
            <a
              href={withBase('/getting-started/免责声明/')}
              class="text-muted-foreground transition-colors hover:text-primary"
            >
              免责声明
            </a>
            <span class="text-border" aria-hidden="true">|</span>
            <a
              href="https://github.com/fanquanpp/FANDEX-exe"
              target="_blank"
              rel="noopener noreferrer"
              class="text-muted-foreground transition-colors hover:text-primary"
            >
              GitHub
            </a>
            <span class="text-border" aria-hidden="true">|</span>
            <a
              href={withBase('/rss.xml')}
              class="text-muted-foreground transition-colors hover:text-primary"
            >
              RSS
            </a>
            <span class="text-border" aria-hidden="true">|</span>
            <a
              href={withBase('/tags/')}
