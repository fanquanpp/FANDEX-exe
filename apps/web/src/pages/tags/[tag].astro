---
import { type CollectionEntry, getCollection } from 'astro:content';
import Breadcrumb from '@/components/Breadcrumb.astro';
/**
 * 标签详情页路由（Phase 8b 重写）
 *
 * 功能概述：
 * - 动态路由 [tag]，为每个标签生成独立详情页
 * - 顶部头部：标签名 + 文档数 + 模块数
 * - 文档列表：按模块分组渲染，每模块一个 section
 * - 相关标签：根据共现关系推荐相关标签
 * - 面包屑：首页 / 标签 / 当前标签
 *
 * 数据源：
 * - docs: astro:content 的 getCollection('docs')
 * - modules: @/lib/modules 的 getModule / MODULE_CATEGORIES
 *
 * Skill 偏差报备：
 * 旧版引用 @fandex/shared 与旧 CSS 变量，本版改用 @/lib/modules 与 Tailwind v4 语义类。
 * 旧版从 metadata/tags/tag-index.json 读取预生成索引获取相关标签，
 * 本版改为运行时计算共现关系（同文档中同时出现的标签视为相关），
 * 减少构建依赖与外部数据源耦合。
 */
import Layout from '@/components/Layout.astro';
import SEO from '@/components/SEO.astro';
import { getModule, MODULE_CATEGORIES } from '@/lib/modules';
import { withBase } from '@/lib/url';

/**
 * 生成静态路径：从所有文档聚合 tags
 *
 * 实现说明：
 * - 遍历所有 docs，收集所有 tags
 * - 为每个 tag 生成一个路径，附带该 tag 下的所有文档
 */
export async function getStaticPaths() {
  const allDocs = await getCollection('docs');

  /** tag → 文档列表 映射 */
  const tagMap = new Map<string, CollectionEntry<'docs'>[]>();

  for (const doc of allDocs) {
    const tags = doc.data.tags || [];
    for (const tag of tags) {
      if (!tagMap.has(tag)) tagMap.set(tag, []);
      tagMap.get(tag)?.push(doc);
    }
  }

  return Array.from(tagMap.entries()).map(([tag, tagDocs]) => ({
    params: { tag },
    props: { tag, docs: tagDocs },
  }));
}

/** 路由参数与 props */
const { tag, docs } = Astro.props as {
  tag: string;
  docs: CollectionEntry<'docs'>[];
};

/** 按 order 升序排序 */
const sortedDocs = docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

/** 按模块分组 */
const moduleGroups = new Map<string, CollectionEntry<'docs'>[]>();
for (const doc of sortedDocs) {
  const mod = doc.data.module;
  if (!moduleGroups.has(mod)) moduleGroups.set(mod, []);
  moduleGroups.get(mod)?.push(doc);
}

/**
 * 从文档 ID 中提取 slug
 *
 * @param id - 文档 ID（如 `javascript/概述`）
 * @returns slug（如 `概述`）
 */
function slug(id: string): string {
  return (id.split('/').pop() || id).replace(/\.(md|mdx)$/, '');
}

/**
 * 计算相关标签：基于共现关系
 *
 * 实现说明：
 * - 遍历当前 tag 下的所有文档
 * - 收集这些文档中的其他 tags
 * - 按共现次数降序排序，取前 12 个
 *
 * @returns 相关标签数组（[tag, count] 二元组）
 */
function computeRelatedTags(): Array<[string, number]> {
  const relatedMap = new Map<string, number>();
  for (const doc of sortedDocs) {
    const tags = doc.data.tags || [];
    for (const t of tags) {
      if (t === tag) continue;
      relatedMap.set(t, (relatedMap.get(t) || 0) + 1);
    }
  }
  return Array.from(relatedMap.entries())
    .sort((a, b) => b[1] - a[1])
    .slice(0, 12);
}

/** 相关标签列表 */
const relatedTags = computeRelatedTags();

/** 难度标签文案映射 */
const difficultyLabel: Record<'beginner' | 'intermediate' | 'advanced', string> = {
  beginner: '入门',
  intermediate: '进阶',
  advanced: '高级',
};

/** 难度标签样式（Tailwind 类名） */
const difficultyClass: Record<'beginner' | 'intermediate' | 'advanced', string> = {
  beginner: 'bg-emerald-100 text-emerald-700 dark:bg-emerald-950/60 dark:text-emerald-300',
  intermediate: 'bg-amber-100 text-amber-700 dark:bg-amber-950/60 dark:text-amber-300',
  advanced: 'bg-rose-100 text-rose-700 dark:bg-rose-950/60 dark:text-rose-300',
};

/** 面包屑导航项 */
const breadcrumb = [
  { label: '首页', href: withBase('/') },
  { label: '标签', href: withBase('/tags/') },
  { label: `#${tag}` },
];

/** SEO 面包屑 */
const seoBreadcrumbs = [
  { label: '首页', href: '/' },
  { label: '标签', href: '/tags/' },
  { label: `#${tag}`, href: `/tags/${tag}/` },
];
---

<Layout
  title={`#${tag} - 标签 - FANDEX`}
  description={`包含标签 "${tag}" 的所有文档，共 ${sortedDocs.length} 篇`}
  canonical={withBase(`/tags/${tag}/`)}
>
  <SEO
    slot="head"
    title={`#${tag} - 标签 - FANDEX`}
    description={`包含标签 "${tag}" 的所有文档，共 ${sortedDocs.length} 篇`}
    type="website"
    breadcrumbs={seoBreadcrumbs}
  />

  <div class="mx-auto w-full max-w-5xl px-4 pb-12 md:px-8">
    {/* 面包屑导航 */}
    <Breadcrumb items={breadcrumb} />

    {/* ============================================================
     * 页面头部：标签名 + 文档数 + 模块数
     * ============================================================ */}
    <header
      class="relative overflow-hidden rounded-xl border border-border bg-card shadow-sm"
    >
      <span
        class="absolute inset-x-0 top-0 h-1 bg-primary"
        aria-hidden="true"
      />
      <div class="flex flex-col gap-2 p-6 md:p-8">
        <div class="flex flex-wrap items-center gap-2">
          <h1 class="text-2xl font-bold text-foreground md:text-3xl">
            <span class="text-primary">#</span>{tag}
          </h1>
          <span
            class="inline-flex items-center rounded-md bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground"
          >
            {sortedDocs.length} 篇文档
          </span>
          <span
            class="inline-flex items-center rounded-md bg-muted px-2 py-0.5 text-xs font-medium text-muted-foreground"
          >
            {moduleGroups.size} 个模块
          </span>
        </div>
        <p class="text-sm text-muted-foreground md:text-base">
          跨模块聚合 · 包含标签 <span class="font-medium text-foreground">#{tag}</span> 的所有文档列表
        </p>
      </div>
    </header>

    {/* ============================================================
     * 文档列表：按模块分组渲染
     * ============================================================ */}
    {sortedDocs.length === 0 ? (
      <div
        class="mt-6 rounded-xl border border-dashed border-border p-12 text-center text-sm text-muted-foreground"
      >
        该标签下暂无文档
      </div>
    ) : (
      <div class="mt-6 flex flex-col gap-6">
        {Array.from(moduleGroups.entries()).map(([mod, modDocs]) => {
          const meta = getModule(mod);
          const categoryMeta = meta
            ? MODULE_CATEGORIES.find((c) => c.id === meta.category)
            : undefined;
          return (
            <section
              class="overflow-hidden rounded-xl border border-border bg-card"
              aria-label={meta?.name ?? mod}
            >
              {/* 模块标题 */}
              <h2 class="flex items-center gap-2 border-b border-border bg-muted/30 px-5 py-3">
                <span
                  class="inline-flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-md text-xs font-bold text-white"
                  style={`background-color:${meta?.color ?? '#4f5bd5'}`}
                  aria-hidden="true"
                >
                  {meta?.icon ?? mod.charAt(0).toUpperCase()}
                </span>
                <a
                  href={withBase(`/${mod}/`)}
                  class="text-sm font-semibold text-foreground transition-colors hover:text-primary md:text-base"
                >
                  {meta?.name ?? mod}
                </a>
                {categoryMeta && (
                  <span
                    class="inline-flex items-center gap-1 rounded-md px-1.5 py-0.5 text-[10px] font-medium"
                    style={`background-color:${meta?.color ?? '#4f5bd5'}20;color:${meta?.color ?? '#4f5bd5'}`}
                  >
                    {categoryMeta.name}
                  </span>
                )}
                <span class="ml-auto text-xs text-muted-foreground tabular-nums">
                  {modDocs.length} 篇
                </span>
              </h2>

              {/* 文档列表 */}
              <ul class="divide-y divide-border">
                {modDocs.map((doc) => {
                  const docSlug = slug(doc.id);
                  const docDifficulty = doc.data.difficulty || 'intermediate';
                  return (
                    <li>
                      <a
                        href={withBase(`/${mod}/${docSlug}/`)}
                        class="group flex items-start gap-3 px-5 py-3 transition-colors hover:bg-accent/30"
                      >
                        {/* 主信息 */}
                        <div class="min-w-0 flex-1">
                          <div class="flex flex-wrap items-center gap-2">
                            <h3 class="text-sm font-medium text-foreground transition-colors group-hover:text-primary md:text-base">
                              {doc.data.title}
                            </h3>
                            <span
                              class={`inline-flex items-center rounded-md px-1.5 py-0.5 text-[10px] font-medium ${difficultyClass[docDifficulty]}`}
                            >
                              {difficultyLabel[docDifficulty]}
                            </span>
                          </div>
                          {doc.data.description && (
                            <p class="mt-1 line-clamp-2 text-xs text-muted-foreground md:text-sm">
                              {doc.data.description}
                            </p>
                          )}
                          {/* 元信息行 */}
                          <div class="mt-1.5 flex flex-wrap items-center gap-3 text-[11px] text-muted-foreground">
                            {doc.data.readingTime && doc.data.readingTime > 0 && (
                              <span class="inline-flex items-center gap-1">
                                <svg
                                  xmlns="http://www.w3.org/2000/svg"
                                  viewBox="0 0 24 24"
                                  fill="none"
                                  stroke="currentColor"
                                  stroke-width="2"
                                  stroke-linecap="round"
                                  stroke-linejoin="round"
                                  class="h-3 w-3"
                                  aria-hidden="true"
                                >
                                  <circle cx="12" cy="12" r="10" />
                                  <polyline points="12 6 12 12 16 14" />
                                </svg>
                                <span class="tabular-nums">{doc.data.readingTime} min</span>
                              </span>
                            )}
                            {/* 其他标签 */}
                            {(doc.data.tags || [])
                              .filter((t) => t !== tag)
                              .slice(0, 3)
                              .map((t) => (
                                <a
                                  href={withBase(`/tags/${t}/`)}
                                  class="inline-flex items-center rounded-md bg-muted px-1.5 py-0.5 text-[10px] text-muted-foreground transition-colors hover:bg-accent hover:text-primary"
                                  onclick="event.stopPropagation()"
                                >
                                  #{t}
                                </a>
                              ))}
                          </div>
                        </div>

                        {/* 右侧箭头 */}
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          class="mt-1 h-4 w-4 flex-shrink-0 text-muted-foreground/60 transition-transform group-hover:translate-x-0.5 group-hover:text-primary"
                          aria-hidden="true"
                        >
                          <polyline points="9 18 15 12 9 6" />
                        </svg>
                      </a>
                    </li>
                  );
                })}
              </ul>
            </section>
          );
        })}
      </div>
    )}

    {/* ============================================================
     * 相关标签：基于共现关系推荐
     * ============================================================ */}
    {relatedTags.length > 0 && (
      <section class="mt-8" aria-label="相关标签">
        <h2 class="mb-3 flex items-center gap-2 border-b border-border pb-2 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
          <span
            class="inline-flex h-2 w-2 rounded-full bg-primary"
            aria-hidden="true"
          />
          相关标签
        </h2>
        <ul class="flex flex-wrap items-center gap-2">
          {relatedTags.map(([relatedTag, count]) => (
            <li>
              <a
                href={withBase(`/tags/${relatedTag}/`)}
                class="inline-flex items-baseline gap-1.5 rounded-md border border-border bg-card px-2.5 py-1 text-xs font-medium text-muted-foreground transition-all hover:-translate-y-0.5 hover:border-primary/40 hover:text-primary hover:shadow-sm"
                title={`共现 ${count} 次`}
              >
                <span>#{relatedTag}</span>
                <span class="text-[10px] text-muted-foreground/70 tabular-nums">
                  {count}
                </span>
              </a>
            </li>
          ))}
        </ul>
      </section>
    )}

    {/* 底部：返回标签索引 */}
    <nav class="mt-12 flex flex-wrap gap-3" aria-label="页面导航">
      <a
        href={withBase('/tags/')}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:bg-accent/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <polyline points="18 6 6 12 18 18" />
        </svg>
        全部标签
      </a>
      <a
        href={withBase('/')}
        class="inline-flex items-center gap-2 rounded-lg border border-border bg-card px-4 py-2 text-sm font-medium text-foreground transition-colors hover:border-primary/40 hover:bg-accent/50"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-4 w-4"
          aria-hidden="true"
        >
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        返回首页
      </a>
    </nav>
  </div>
</Layout>
