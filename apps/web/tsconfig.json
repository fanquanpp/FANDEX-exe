{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "target": "ES2024",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "lib": ["ES2024", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "noUncheckedIndexedAccess": false,
    "noImplicitOverride": false,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "verbatimModuleSyntax": true,
    "allowImportingTsExtensions": false,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@/*": ["./src/*"],
      "@modules": ["../../metadata/modules.json"],
      "@fandex/markdown": ["../../packages/markdown/index.ts"],
      "@fandex/markdown/*": ["../../packages/markdown/*"],
      "@fandex/shared": ["../../packages/shared/index.ts"],
      "@fandex/shared/*": ["../../packages/shared/*"],
      "@fandex/search": ["../../packages/search/index.ts"],
      "@fandex/search/*": ["../../packages/search/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist", "node_modules"]
}
