{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FANDEX",
  "version": "3.0.0",
  "identifier": "com.fandex.app",
  "build": {
    "beforeDevCommand": "pnpm --filter web dev",
    "devUrl": "http://localhost:4321",
    "beforeBuildCommand": "pnpm --filter web build",
    "frontendDist": "../apps/web/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FANDEX - 渐进式自学平台",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 640,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "maximized": false,
        "windowEffects": {
          "effects": ["acrylic"],
          "state": "active"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data: blob:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost https://api.github.com; media-src 'self'",
      "assetProtocol": {
        "enable": true,
        "scope": ["$RESOURCE/**"]
      },
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "publisher": "fanquanpp",
    "copyright": "Copyright (c) 2026 fanquanpp. All rights reserved.",
    "category": "Education",
    "shortDescription": "FANDEX - 渐进式自学平台",
    "longDescription": "FANDEX 是一款零基础到本科毕业的渐进式自学平台，含 51 模块与 1996 篇文档，基于 Tauri 2 + Astro 7 + React 19 技术栈，完全离线可用。",
    "homepage": "https://github.com/fanquanpp/FANDEX-exe",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "languages": ["SimpChinese", "English"],
        "displayLanguageSelector": false
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "resources": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "active": true,
      "endOnExit": true,
      "pubkey": "",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
