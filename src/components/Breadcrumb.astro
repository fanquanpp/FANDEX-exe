---
const { items } = Astro.props as { items: { label: string; href?: string }[] }
---

<nav class="breadcrumb">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="bc-sep">/</span>}
      {item.href ? (
        <a href={item.href} class="bc-link">{item.label}</a>
      ) : (
        <span class="bc-current">{item.label}</span>
      )}
    </>
  ))}
</nav>

<style>
.bc-sep { color: var(--color-text-tertiary); opacity: 0.4; font-family: var(--font-display); }
.bc-link { color: var(--color-text-secondary); }
.bc-link:hover { color: var(--color-primary); }
.bc-current { color: var(--color-text); font-weight: 500; font-family: var(--font-display); }
</style>
