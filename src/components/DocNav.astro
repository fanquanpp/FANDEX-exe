---
const { prev, next } = Astro.props as { prev?: { slug: string; title: string }; next?: { slug: string; title: string } }
---

<nav class="doc-nav">
  {prev ? (
    <a href={prev.slug} class="nav-btn">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 6 6 12 18 18"/></svg>
      <div>
        <span class="nav-label">上一篇</span>
        <span class="nav-title">{prev.title}</span>
      </div>
    </a>
  ) : <div></div>}
  {next ? (
    <a href={next.slug} class="nav-btn" style="text-align:right">
      <div>
        <span class="nav-label">下一篇</span>
        <span class="nav-title">{next.title}</span>
      </div>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 6 18 12 6 18"/></svg>
    </a>
  ) : <div></div>}
</nav>

<style>
.doc-nav { display: flex; justify-content: space-between; gap: var(--spacing-md); margin-top: var(--spacing-lg); padding-top: var(--spacing-lg); border-top: 1px solid var(--color-border-light); max-width: var(--content-width); margin-left: auto; margin-right: auto; }
.nav-btn { display: flex; align-items: center; gap: var(--spacing-sm); padding: var(--spacing-sm) var(--spacing-md); border: 1px solid var(--color-border); background: var(--color-bg-card); color: var(--color-text-secondary); text-decoration: none; max-width: 45%; }
.nav-btn:hover { border-color: var(--color-primary); color: var(--color-primary); }
.nav-label { font-size: 0.68em; color: var(--color-text-tertiary); display: block; }
.nav-title { font-size: 0.82em; font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200px; display: block; }
</style>
