---
const { mod } = Astro.props as { mod: { id: string; title: string; description: string; color: string } }
---

<a href={`${import.meta.env.BASE_URL}${mod.id}`} class="module-card">
  <span class="card-icon" style={`background:${mod.color}`}>#</span>
  <div class="card-body">
    <h3 class="card-title">{mod.title}</h3>
    <p class="card-desc">{mod.description}</p>
  </div>
</a>

<style>
.module-card {
  padding: var(--spacing-md);
  text-decoration: none;
  transition: background var(--transition-fast);
  display: flex; flex-direction: column; gap: var(--spacing-sm);
}
.module-card:hover { background: var(--color-bg-hover); }
.card-icon { width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; color: #fff; font-family: var(--font-display); font-weight: 700; font-size: 0.75rem; }
.card-title { font-family: var(--font-display); font-size: 0.9rem; color: var(--color-text); margin: 0; }
.card-desc { font-size: 0.78rem; color: var(--color-text-secondary); margin: 0; line-height: 1.4; }
</style>
