---
import { getCollection } from 'astro:content'

const { moduleId } = Astro.props

const docs = await getCollection('docs', ({ data }) => data.module === moduleId)
const sorted = docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
function docSlug(id: string) { return (id.split('/').pop() || id).replace(/\.md$/, '') }
---

<aside class="app-sidebar">
  <nav class="sidebar-nav">
    <a href={`${import.meta.env.BASE_URL}${moduleId}`} class="sidebar-back">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
        <polyline points="18 6 6 12 18 18" />
      </svg>
      <span>返回模块</span>
    </a>
    <ul class="file-list">
      {sorted.map(doc => (
        <li>
          <a href={`${import.meta.env.BASE_URL}${moduleId}/${docSlug(doc.id)}`} class="sidebar-file-link">
            {doc.data.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</aside>

<style>
.sidebar-nav { display: flex; flex-direction: column; gap: 2px; }
.sidebar-back { display: flex; align-items: center; gap: var(--spacing-sm); padding: var(--spacing-sm); margin-bottom: var(--spacing-sm); color: var(--color-text-secondary); font-size: 0.85em; }
.sidebar-back:hover { color: var(--color-primary); }
.file-list { list-style: none; padding: 0; margin: 0; }
</style>
