---
const { headings } = Astro.props as { headings: { depth: number; slug: string; text: string }[] }
---

<nav class="toc">
  <h4 class="toc-title">目录</h4>
  <ul class="toc-list">
    {headings.filter((h: any) => h.depth <= 3).map((h: any) => (
      <li style={`padding-left: ${(h.depth - 1) * 12}px`}>
        <a href={`#${h.slug}`} class="toc-link">{h.text}</a>
      </li>
    ))}
  </ul>
</nav>

<style>
.toc { margin-bottom: var(--spacing-lg); }
.toc-title { font-family: var(--font-display); font-size: 0.85em; margin: 0 0 var(--spacing-sm); color: var(--color-text-secondary); }
.toc-list { list-style: none; padding: 0; }
</style>
