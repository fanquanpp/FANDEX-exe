---
import Layout from '@/components/Layout.astro'
---

<Layout title="页面未找到">
  <div class="not-found">
    <h1>404</h1>
    <p>页面不存在</p>
    <a href={`${import.meta.env.BASE_URL}`}>返回首页</a>
  </div>
</Layout>

<style>
.not-found { text-align: center; padding: var(--spacing-3xl); }
.not-found h1 { font-family: var(--font-display); font-size: 3em; margin-bottom: var(--spacing-md); }
.not-found p { color: var(--color-text-secondary); margin-bottom: var(--spacing-lg); }
.not-found a { display: inline-block; padding: var(--spacing-sm) var(--spacing-lg); border: 1px solid var(--color-primary); color: var(--color-primary); font-family: var(--font-display); }
.not-found a:hover { background: var(--color-primary); color: #fff; }
</style>
