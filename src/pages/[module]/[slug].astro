---
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
import Sidebar from '@/components/Sidebar.astro'
import TOC from '@/components/TOC.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import DocNav from '@/components/DocNav.astro'
import BackToTop from '@/components/BackToTop.astro'
import { getModule } from '@/lib/modules'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  return docs.map(doc => {
    const slug = (doc.id.split('/').pop() || doc.id).replace(/\.md$/, '')
    return {
      params: { module: doc.data.module, slug },
      props: { doc },
    }
  })
}

const { doc } = Astro.props as any
const { module } = Astro.params as { module: string; slug: string }
const { Content, headings } = await doc.render()
const meta = getModule(module || '')

const breadcrumb = [
  { label: '首页', href: `${import.meta.env.BASE_URL}` },
  { label: meta?.title || module, href: `${import.meta.env.BASE_URL}${module}` },
  { label: doc.data.title },
]
---

<Layout title={doc.data.title}>
  <SEO
    slot="head"
    title={doc.data.title}
    description={doc.data.description}
    canonical={`${Astro.site}${Astro.url.pathname}`}
  />
  <Sidebar slot="sidebar" moduleId={module} />

  <div class="doc-page">
    <Breadcrumb items={breadcrumb} />
    <article class="prose">
      <TOC headings={headings} />
      <Content />
    </article>
    <DocNav />
    <BackToTop />
  </div>
</Layout>

<style>
.doc-page { padding: var(--spacing-md) var(--spacing-lg) var(--spacing-2xl); }
</style>
