---
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import { getModule } from '@/lib/modules'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const { modules } = await import('@/lib/modules')
  return modules.map(m => ({ params: { module: m.id } }))
}

const { module } = Astro.params as { module: string }
const meta = getModule(module || '')

if (!meta) {
  return Astro.redirect('/MyNotebook/404')
}

const docs = await getCollection('docs', ({ data }) => data.module === module)
function slug(id: string) { return (id.split('/').pop() || id).replace(/\.md$/, '') }

const breadcrumb = [
  { label: '首页', href: '/MyNotebook/' },
  { label: meta.title },
]
---

<Layout title={meta.title}>
  <SEO slot="head" title={meta.title} description={meta.description} canonical={`${Astro.site}${Astro.url.pathname}`} />
  <div class="module-page">
    <Breadcrumb items={breadcrumb} />
    <div class="module-header">
      <span class="header-bar" style={`background:${meta.color}`}></span>
      <div class="header-body">
        <h1 class="header-title">{meta.title}</h1>
        <p class="header-desc">{meta.description}</p>
      </div>
    </div>
    <table class="file-table">
      <thead>
        <tr>
          <th>标题</th>
        </tr>
      </thead>
      <tbody>
        {docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0)).map(doc => (
          <tr class="file-row">
            <td>
              <a href={`${import.meta.env.BASE_URL}${module}/${slug(doc.id)}`} class="file-link">
                {doc.data.title}
              </a>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Layout>

<style>
.module-page { padding: var(--spacing-md) var(--spacing-lg); max-width: var(--content-width); margin: 0 auto; }
.module-header { display: flex; margin-bottom: var(--spacing-lg); background: var(--color-bg-card); border: 1px solid var(--color-border-light); }
.header-bar { width: 5px; flex-shrink: 0; }
.header-body { padding: var(--spacing-lg); }
.header-title { font-family: var(--font-display); font-size: 1.4em; margin: 0 0 var(--spacing-xs); }
.header-desc { font-size: 0.88em; color: var(--color-text-secondary); margin: 0; }
.file-table { width: 100%; border-collapse: collapse; border: 1px solid var(--color-border-light); }
.file-table th { padding: var(--spacing-sm) var(--spacing-md); text-align: left; font-size: 0.75em; font-weight: 700; color: #fff; background: var(--color-text); font-family: var(--font-display); }
.file-table td { padding: var(--spacing-sm) var(--spacing-md); border-bottom: 1px solid var(--color-border-light); }
.file-row:hover { background: var(--color-bg-hover); }
.file-link { color: var(--color-text); display: block; }
.file-link:hover { color: var(--color-primary); }
</style>
