---
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
import ModuleCard from '@/components/ModuleCard.astro'
import { modules, categoryLabels, getModulesByCategory, categoryOrder } from '@/lib/modules'

const grouped = categoryOrder
  .map(cat => ({
    key: cat,
    label: categoryLabels[cat],
    modules: getModulesByCategory(cat),
  }))
  .filter(g => g.modules.length > 0)
---

<Layout title="首页">
  <SEO slot="head" title="首页" description="开发者知识库 - 17个模块的技术学习笔记" type="website" />

  <div class="home-page">
    <section class="home-header">
      <h1 class="site-title">CODEX</h1>
      <p class="site-subtitle">开发者知识库</p>
      <div class="stats">
        <span><strong>{modules.length}</strong> 模块</span>
      </div>
    </section>

    {grouped.map(group => (
      <section class="category-section">
        <div class="category-header">
          <span class="category-tag">{group.label}</span>
          <span class="category-count">{group.modules.length}</span>
        </div>
        <div class="module-grid">
          {group.modules.map(mod => <ModuleCard mod={mod} />)}
        </div>
      </section>
    ))}
  </div>
</Layout>

<style>
.home-page { max-width: 960px; margin: 0 auto; padding: var(--spacing-xl) var(--spacing-lg); }
.home-header { text-align: center; padding: var(--spacing-xl) 0 var(--spacing-lg); border-bottom: 1px solid var(--color-border-light); margin-bottom: var(--spacing-lg); }
.site-title { font-family: var(--font-display); font-size: 2rem; font-weight: 700; letter-spacing: 0.2em; margin: 0; }
.site-subtitle { font-size: 0.9rem; color: var(--color-text-secondary); margin: var(--spacing-xs) 0 var(--spacing-md); }
.stats { font-family: var(--font-display); font-size: 0.78rem; color: var(--color-text-tertiary); }
.stats strong { color: var(--color-text); }
.category-section { margin-bottom: var(--spacing-lg); }
.category-header { display: flex; align-items: center; gap: var(--spacing-sm); padding: var(--spacing-sm) var(--spacing-md); background: var(--color-bg-card); margin-bottom: 0; }
.category-tag { font-family: var(--font-display); font-size: 0.72rem; font-weight: 700; color: #6366f1; }
.category-count { font-family: var(--font-display); font-size: 0.72rem; color: var(--color-text-tertiary); }
</style>
