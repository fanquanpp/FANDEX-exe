---
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
import { modules, categoryLabels, categoryOrder, categoryColors, getPrimaryCategory } from '@/lib/modules'

const base = import.meta.env.BASE_URL

const roadmap = [
  {
    phase: 'Phase 0',
    label: '编程准备',
    desc: '零基础入门：环境搭建、工具配置与学习路线规划',
    color: categoryColors.toolchain,
    items: [
      { id: 'getting-started', arrow: null },
    ],
  },
  {
    phase: 'Phase 1',
    label: '开发工具链',
    desc: '文档写作与版本控制是所有协作开发的基础，建议最先掌握',
    color: categoryColors.toolchain,
    items: [
      { id: 'markdown', arrow: 'right' },
      { id: 'git', arrow: 'right' },
      { id: 'github', arrow: null },
